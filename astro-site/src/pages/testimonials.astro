---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { REVIEWS, GOOGLE_REVIEWS_URL } from '~/data/reviews';

const title = 'Client reviews — Imverica Legal Solutions';
const description =
  'Real reviews from Imverica Legal Solutions clients across USCIS, EOIR, and California court document preparation — in English, Russian, Ukrainian, and Spanish.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Client reviews — Imverica Legal Solutions',
  url: 'https://imverica.com/testimonials',
  about: { '@type': 'LegalService', name: 'Imverica Legal Solutions', url: 'https://imverica.com' }
};
---
<BaseLayout title={title} description={description} canonical="https://imverica.com/testimonials" jsonLd={[schema]}>
  <section class="reviews-page">
    <div class="reviews-inner">
      <div class="reviews-head">
        <div class="reviews-kicker">Client reviews</div>
        <h1>What our clients say</h1>
        <p>Real feedback from clients across immigration and California court document preparation — in the language they speak. These reviews are published on our Google Business Profile.</p>
        <a class="reviews-google-cta" href={GOOGLE_REVIEWS_URL} target="_blank" rel="noopener noreferrer">
          <span class="reviews-google-stars" aria-hidden="true">★★★★★</span> Read &amp; leave a review on Google <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="reviews-grid">
        {REVIEWS.map((item) => (
          <article class="testimonial-card">
            <div class="testimonial-stars" aria-label={`${item.stars} out of 5`}>
              {'★'.repeat(item.stars)}<span class="testimonial-stars-dim">{'★'.repeat(5 - item.stars)}</span>
            </div>
            <p>{item.body}</p>
            <div class="testimonial-author">
              <span class="testimonial-name">{item.name}</span>
              <span class="testimonial-meta">{item.meta}</span>
            </div>
          </article>
        ))}
      </div>

      <div class="reviews-foot">
        <a class="reviews-google-cta" href={GOOGLE_REVIEWS_URL} target="_blank" rel="noopener noreferrer">
          <span class="reviews-google-stars" aria-hidden="true">★★★★★</span> See all reviews on Google <span aria-hidden="true">→</span>
        </a>
        <a class="reviews-back" href="/">← Back to home</a>
        <p class="reviews-disclaimer">Document preparation only · No legal advice · We are not a law firm.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .reviews-page { background: #fff; padding: var(--space-section) 1.5rem; }
  .reviews-inner { max-width: 1200px; margin: 0 auto; }

  .reviews-head { max-width: 780px; margin: 0 auto 36px; text-align: center; }
  .reviews-kicker {
    color: var(--terracotta-deep);
    font-size: 11px; font-weight: 700; letter-spacing: 1.6px;
    text-transform: uppercase; margin-bottom: 10px;
  }
  .reviews-head h1 { font-size: var(--fs-h1); margin-bottom: 14px; text-wrap: balance; }
  .reviews-head p { color: #3a4a5e; font-size: 15.5px; line-height: 1.7; margin: 0 0 22px; }

  .reviews-google-cta {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--navy); color: #fff; font-weight: 700; font-size: 14.5px;
    text-decoration: none; padding: 12px 24px; border-radius: 10px;
    border: 1px solid var(--navy); transition: background 0.18s ease, transform 0.18s ease;
  }
  .reviews-google-cta:hover { background: var(--navy-dark); transform: translateY(-1px); }
  .reviews-google-stars { color: var(--gold); letter-spacing: 1px; }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .testimonial-card {
    display: flex; flex-direction: column;
    background: #fffaf2; border: 1px solid rgba(40, 30, 20, 0.1);
    border-radius: 12px; padding: 24px;
    box-shadow: 0 6px 20px rgba(40, 30, 20, 0.04);
  }
  .testimonial-stars { color: #e0a64a; font-size: 15px; letter-spacing: 2px; margin-bottom: 12px; }
  .testimonial-stars-dim { color: #e0a64a; opacity: 0.28; }
  .testimonial-card p { color: #2a3140; font-size: 14.5px; line-height: 1.65; margin: 0 0 18px; flex: 1; }
  .testimonial-author { border-top: 1px solid rgba(40, 30, 20, 0.08); padding-top: 12px; }
  .testimonial-name { display: block; font-weight: 700; font-size: 14px; color: var(--navy-dark); }
  .testimonial-meta { display: block; font-size: 12px; color: var(--muted); margin-top: 2px; }

  .reviews-foot { text-align: center; margin-top: 36px; }
  .reviews-back {
    display: inline-block; margin-left: 22px; color: #3a4a5e;
    font-size: 14px; font-weight: 600; text-decoration: none;
  }
  .reviews-back:hover { color: var(--navy-dark); }
  .reviews-disclaimer { color: var(--muted); font-size: 12.5px; margin-top: 18px; }

  @media (max-width: 820px) {
    .reviews-page { padding: var(--space-section) 1.25rem; }
    .reviews-grid { grid-template-columns: 1fr; }
    .reviews-back { display: block; margin: 14px 0 0; }
  }
</style>
