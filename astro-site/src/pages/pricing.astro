            <tr><td><strong>LLC-12</strong> Statement of Information</td><td class="num"><span class="price">$99</span></td><td class="num gov">$20</td></tr>
            <tr><td><strong>SS-4 EIN</strong> application</td><td class="num"><span class="price">$79</span></td><td class="num gov">$0</td></tr>
