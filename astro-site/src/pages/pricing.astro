    /* ===== Outer section ===== */
    .pricing-section {
      background: linear-gradient(180deg, #fafaf7 0%, #fff 280px);
      padding: 56px 1.5rem 80px;
    }
    .pricing-inner {
      max-width: 1180px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 36px;
    }

    /* ===== Category card ===== */
    .price-card {
      position: relative;
      background: #fff;
      border-radius: 18px;
      overflow: hidden;
      border: 1px solid rgba(40,30,20,0.08);
      box-shadow: 0 10px 28px rgba(40,30,20,0.06);
      transition: box-shadow 0.2s ease, transform 0.2s ease;
    }
    .price-card:hover {
      box-shadow: 0 16px 38px rgba(40,30,20,0.10);
      transform: translateY(-2px);
    }
    .price-card-stripe {
      height: 6px;
      width: 100%;
    }
    .price-card--navy .price-card-stripe          { background: linear-gradient(90deg, var(--navy-dark) 0%, var(--navy) 100%); }
    .price-card--terracotta .price-card-stripe    { background: linear-gradient(90deg, #c46a3c 0%, var(--terracotta) 100%); }
    .price-card--terracotta-deep .price-card-stripe { background: linear-gradient(90deg, #8a3f1f 0%, var(--terracotta-deep) 100%); }
    .price-card--sage .price-card-stripe          { background: linear-gradient(90deg, #3a5a44 0%, var(--sage) 100%); }
    .price-card--gold .price-card-stripe          { background: linear-gradient(90deg, #b48a36 0%, var(--gold) 100%); }

    .price-card-head {
      display: grid;
      grid-template-columns: 64px 1fr;
      gap: 18px;
      padding: 26px 28px 18px;
      align-items: start;
    }
    .price-card-icon {
      width: 56px; height: 56px;
      border-radius: 14px;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 28px;
      color: #fff;
      box-shadow: 0 6px 16px rgba(40,30,20,0.18);
    }
    .price-card--navy .price-card-icon          { background: var(--navy-dark); }
    .price-card--terracotta .price-card-icon    { background: var(--terracotta); }
    .price-card--terracotta-deep .price-card-icon { background: var(--terracotta-deep); }
    .price-card--sage .price-card-icon          { background: #3a5a44; }
    .price-card--gold .price-card-icon          { background: #7a5a18; }

    .price-card-kicker {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.4px;
      text-transform: uppercase;
      color: var(--terracotta-deep);
      margin-bottom: 4px;
    }
    .price-card--navy .price-card-kicker     { color: var(--navy); }
    .price-card--sage .price-card-kicker     { color: #3a5a44; }
    .price-card--gold .price-card-kicker     { color: #7a5a18; }
    .price-card-head h2 {
      font-family: var(--font-display);
      font-size: 24px;
      font-weight: 700;
      color: var(--navy-dark);
      margin: 0 0 4px;
      line-height: 1.15;
    }
    .price-card-sub {
      color: #4a5a6e;
      font-size: 14px;
      line-height: 1.55;
      margin: 4px 0 0;
    }

    /* ===== Price table ===== */
    .price-table {
      width: 100%;
      border-collapse: collapse;
      margin: 4px 0 0;
    }
    .price-table thead th {
      background: rgba(40,30,20,0.03);
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 0.6px;
      text-transform: uppercase;
      text-align: left;
      padding: 12px 20px;
      color: #6b7a8a;
      border-top: 1px solid rgba(40,30,20,0.07);
      border-bottom: 1px solid rgba(40,30,20,0.07);
    }
    .price-table thead th.num { text-align: right; }
    .price-table tbody td {
      padding: 14px 20px;
      font-size: 14.5px;
      line-height: 1.5;
      color: #2a3140;
      border-bottom: 1px solid rgba(40,30,20,0.06);
      vertical-align: middle;
    }
    .price-table tbody tr:last-child td { border-bottom: 0; }
    .price-table .num { text-align: right; white-space: nowrap; }
    .price-table .price {
      display: inline-block;
      padding: 4px 12px;
      background: rgba(26,46,74,0.07);
      color: var(--navy-dark);
      border-radius: 999px;
      font-weight: 700;
      font-size: 14px;
      font-feature-settings: 'tnum';
    }
    .price-card--terracotta .price-table .price,
    .price-card--terracotta-deep .price-table .price {
      background: rgba(164,91,52,0.10);
      color: var(--terracotta-deep);
    }
    .price-card--sage .price-table .price {
      background: rgba(125,156,122,0.16);
      color: #2c4633;
    }
    .price-card--gold .price-table .price {
      background: rgba(212,175,86,0.20);
      color: #6f4f10;
    }
    .price-table .gov {
      color: #8a93a3;
      font-size: 13px;
      font-feature-settings: 'tnum';
    }
    .price-table .quote {
      font-style: italic;
      color: #6b7a8a;
      font-size: 13px;
    }
    .price-row-popular { background: rgba(255,247,235,0.55); }
    .price-row-popular td:first-child {
      position: relative;
      padding-right: 110px;
    }
    .price-popular-pill {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      background: var(--terracotta-deep);
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 999px;
      white-space: nowrap;
    }
    .price-row-meta {
      display: block;
      font-size: 12.5px;
      color: #6b7a8a;
      font-weight: 400;
      margin-top: 2px;
    }
    .price-table-divider {
      background: rgba(40,30,20,0.04);
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      color: #6b7a8a;
      padding: 10px 20px;
    }

    .price-card-disclaimer {
      padding: 14px 28px 24px;
      margin: 0;
      font-size: 12.5px;
      line-height: 1.6;
      color: #6b7a8a;
      background: rgba(40,30,20,0.025);
      border-top: 1px solid rgba(40,30,20,0.06);
    }

    /* ===== Mobile — collapse tables to vertical card rows ===== */
    @media (max-width: 640px) {
      .price-card-head {
        grid-template-columns: 52px 1fr;
        gap: 14px;
        padding: 22px 18px 14px;
      }
      .price-card-icon { width: 48px; height: 48px; font-size: 24px; border-radius: 12px; }
      .price-card-head h2 { font-size: 20px; }
      .price-table thead { display: none; }
      .price-table, .price-table tbody, .price-table tr, .price-table td { display: block; width: 100%; }
      .price-table tr {
        padding: 14px 18px;
        border-bottom: 1px solid rgba(40,30,20,0.06);
      }
      .price-table tr:last-child { border-bottom: 0; }
      .price-table td {
        padding: 4px 0;
        border: 0;
        text-align: left;
      }
      .price-table td.num { text-align: left; }
      .price-row-popular td:first-child { padding-right: 0; }
      .price-popular-pill {
        position: static;
        transform: none;
        display: inline-block;
        margin-top: 6px;
      }
      .price-card-disclaimer { padding: 12px 18px 20px; }
    }

    /* ===== Discounts strip ===== */
    .discounts-strip {
      background: linear-gradient(135deg, #fffaf2 0%, #fff5e8 100%);
      border: 1px solid rgba(164,91,52,0.18);
      border-radius: 18px;
      padding: 32px 30px;
    }
    .discounts-strip-head { text-align: center; margin-bottom: 22px; }
    .discounts-strip-head h2 {
      font-family: var(--font-display);
      font-size: 26px;
      font-weight: 700;
      color: var(--navy-dark);
      margin: 0 0 6px;
    }
    .discounts-strip-head p {
      color: #6b7a8a;
      font-size: 14.5px;
      margin: 0;
    }
    .discounts-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }
    @media (max-width: 860px) { .discounts-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 520px) { .discounts-grid { grid-template-columns: 1fr; } }
    .discount-card {
      background: #fff;
      border-radius: 12px;
      padding: 18px 18px 16px;
      border: 1px solid rgba(40,30,20,0.08);
      box-shadow: 0 6px 16px rgba(40,30,20,0.04);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .discount-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 24px rgba(40,30,20,0.10);
    }
    .discount-card--b2b {
      background: var(--navy-dark);
      color: #e8eef7;
      border-color: var(--navy-dark);
    }
    .discount-card--b2b .discount-title,
    .discount-card--b2b .discount-pct { color: #fff; }
    .discount-card--b2b .discount-desc { color: #c5d1e0; }
    .discount-card--b2b a { color: var(--gold); text-decoration: underline; }
    .discount-pct {
      font-family: var(--font-display);
      font-size: 32px;
      font-weight: 700;
      color: var(--terracotta-deep);
      line-height: 1;
      margin-bottom: 6px;
    }
    .discount-title {
      font-weight: 700;
      font-size: 14.5px;
      color: var(--navy-dark);
      margin-bottom: 4px;
    }
    .discount-desc {
      font-size: 13px;
      line-height: 1.55;
      color: #4a5a6e;
    }

    /* ===== Compare strip ===== */
    .compare-strip {
      background: var(--navy-dark);
      color: #e8eef7;
      border-radius: 18px;
      padding: 36px 30px;
    }
    .compare-strip h2 {
      font-family: var(--font-display);
      color: #fff;
      font-size: 26px;
      font-weight: 700;
      margin: 0 0 6px;
      text-align: center;
    }
    .compare-intro {
      text-align: center;
      max-width: 700px;
      margin: 0 auto 26px;
      color: #c5d1e0;
      font-size: 14.5px;
      line-height: 1.65;
    }
    .compare-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }
    @media (max-width: 820px) { .compare-grid { grid-template-columns: 1fr; } }
    .compare-col {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: 12px;
      padding: 22px 20px;
    }
    .compare-col--imverica {
      background: rgba(212,175,86,0.10);
      border-color: var(--gold);
      box-shadow: 0 0 0 1px rgba(212,175,86,0.18) inset, 0 12px 24px rgba(0,0,0,0.18);
      transform: translateY(-4px);
    }
    .compare-tier {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.4px;
      text-transform: uppercase;
      color: #8a93a3;
      margin-bottom: 4px;
    }
    .compare-tier--featured {
      color: var(--gold);
    }
    .compare-name {
      font-family: var(--font-display);
      font-size: 17px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 12px;
    }
    .compare-col ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .compare-col li {
      padding: 7px 0 7px 22px;
      position: relative;
      font-size: 13.5px;
      line-height: 1.5;
      color: #c5d1e0;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .compare-col li:first-child { border-top: 0; }
    .compare-col li::before {
      content: "→";
      position: absolute;
      left: 0;
      top: 7px;
      color: var(--gold);
      font-weight: 700;
    }
    .compare-col--imverica li { color: #f2e9cf; }

    /* ===== FAQ ===== */
    .pricing-faq {
      background: #fff;
      border: 1px solid rgba(40,30,20,0.08);
      border-radius: 18px;
      padding: 30px 30px 24px;
    }
    .pricing-faq h2 {
      font-family: var(--font-display);
      font-size: 24px;
      font-weight: 700;
      color: var(--navy-dark);
      margin: 0 0 18px;
      text-align: center;
    }
    .pricing-faq details {
      border-bottom: 1px solid rgba(40,30,20,0.08);
      padding: 14px 4px;
    }
    .pricing-faq details:last-of-type { border-bottom: 0; }
    .pricing-faq summary {
      cursor: pointer;
      font-weight: 600;
      font-size: 15px;
      color: var(--navy-dark);
      list-style: none;
      padding-right: 28px;
      position: relative;
    }
    .pricing-faq summary::-webkit-details-marker { display: none; }
    .pricing-faq summary::after {
      content: "+";
      position: absolute;
      right: 6px;
      top: 50%;
      transform: translateY(-50%);
      width: 22px;
      height: 22px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(26,46,74,0.08);
      color: var(--navy-dark);
      border-radius: 50%;
      font-size: 17px;
      font-weight: 700;
      line-height: 1;
      transition: transform 0.2s ease, background 0.2s ease;
    }
    .pricing-faq details[open] summary::after {
      transform: translateY(-50%) rotate(45deg);
      background: var(--terracotta-deep);
      color: #fff;
    }
    .pricing-faq details p {
      margin: 10px 0 0;
      font-size: 14px;
      line-height: 1.65;
      color: #4a5a6e;
    }
    .pricing-faq details a { color: var(--navy); }

    /* ===== Legal block ===== */
    .pricing-legal {
      background: #fcf5e6;
      border-left: 4px solid var(--terracotta-deep);
      border-radius: 8px;
      padding: 22px 26px;
      font-size: 13px;
      line-height: 1.65;
      color: #5a4a30;
    }
    .pricing-legal h3 {
      font-family: var(--font-display);
      font-size: 14px;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      color: var(--terracotta-deep);
      margin: 0 0 10px;
    }
    .pricing-legal p { margin: 0 0 10px; }
    .pricing-legal p:last-child { margin-bottom: 0; }
  </style>
</BaseLayout>
