---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import CTAStrip from '~/components/CTAStrip.astro';

const title = 'Pricing — Flat-Fee Document Preparation | Imverica Legal Solutions';
const description = 'Transparent flat-fee pricing for USCIS, EOIR, California family law, small claims, probate, and business document preparation. Simple forms from $49. USCIS packages from $199. Family law from $349. Complex cases by custom quote. No hidden fees, no hourly creep. Imverica is not a law firm.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Imverica Document Preparation Pricing',
  provider: { '@type': 'LegalService', name: 'Imverica Legal Solutions', legalName: 'Imverica LLC', url: 'https://imverica.com', telephone: '+1-916-399-3992' },
  description: 'Flat-fee document preparation for USCIS, EOIR, and California state-court forms. Imverica is a California-registered Legal Document Assistant and Immigration Consultant — not a law firm. Documents prepared at client direction. Government filing fees are separate.',
  areaServed: [
    { '@type': 'Country', name: 'United States' },
    { '@type': 'State', name: 'California' }
  ],
  offers: [
    { '@type': 'Offer', name: 'I-90 Green Card Renewal',       priceCurrency: 'USD', price: '199' },
    { '@type': 'Offer', name: 'I-765 Work Permit',             priceCurrency: 'USD', price: '199' },
    { '@type': 'Offer', name: 'I-130 Family Petition',         priceCurrency: 'USD', price: '499' },
    { '@type': 'Offer', name: 'I-485 Adjustment (single)',     priceCurrency: 'USD', price: '999' },
    { '@type': 'Offer', name: 'I-485 Marriage AOS Package',    priceCurrency: 'USD', price: '1799' },
    { '@type': 'Offer', name: 'N-400 Naturalization',          priceCurrency: 'USD', price: '599' },
    { '@type': 'Offer', name: 'SC-100 Small Claims Package',   priceCurrency: 'USD', price: '249' },
    { '@type': 'Offer', name: 'FL-100 Simple Divorce',         priceCurrency: 'USD', price: '349' },
    { '@type': 'Offer', name: 'LLC Launch Package',            priceCurrency: 'USD', price: '449' }
  ]
};
---
<BaseLayout title={title} description={description} canonical="https://imverica.com/pricing"
  slug="/pricing" availableLocales={['en']} jsonLd={[schema]}>
  <Hero
    eyebrow="Transparent flat-fee pricing · no hourly creep · no surprises"
    heading="What does it cost?"
    sub="Flat fees per document or matter. Government filing fees are paid separately to USCIS, the court, or the Secretary of State. Documents are prepared at your direction — Imverica is not a law firm and does not provide legal advice."
    ctaPrimary={{ href: '/#get-started', text: 'Start your case' }}
    ctaSecondary={{ href: 'tel:+19163993992', text: '📞 +1 (916) 399-3992' }}
  />

  <section class="pricing-section">
    <div class="pricing-inner">

      <!-- ─────────────────────────────────────────────────────────────
           CATEGORY 1 — Simple USCIS forms (navy)
           ───────────────────────────────────────────────────────────── -->
      <div class="price-card price-card--navy">
        <div class="price-card-stripe"></div>
        <div class="price-card-head">
          <div class="price-card-icon" aria-hidden="true">🛂</div>
          <div>
            <div class="price-card-kicker">Federal · all 50 states</div>
            <h2>Simple USCIS forms</h2>
            <p class="price-card-sub">One form, straightforward situation. Most prepared in 24–48 hours.</p>
          </div>
        </div>
        <table class="price-table">
          <thead>
            <tr><th>Service</th><th class="num">Imverica fee</th><th class="num">Gov. fee*</th></tr>
          </thead>
          <tbody>
            <tr data-prefill="I need help with I-90 Green Card renewal" data-formcode="I-90"><td><strong>I-90</strong> Green Card renewal / replacement</td><td class="num"><span class="price">$199</span></td><td class="num gov">$415</td></tr>
            <tr data-prefill="I need an I-765 Work Permit (EAD)" data-formcode="I-765"><td><strong>I-765</strong> Work Permit / EAD</td><td class="num"><span class="price">$199</span></td><td class="num gov">$520</td></tr>
            <tr data-prefill="I need an I-131 travel document / re-entry permit" data-formcode="I-131"><td><strong>I-131</strong> Travel Document / Re-entry Permit</td><td class="num"><span class="price">$179</span></td><td class="num gov">$630</td></tr>
            <tr data-prefill="I need an I-864 Affidavit of Support" data-formcode="I-864"><td><strong>I-864</strong> Affidavit of Support (standalone)</td><td class="num"><span class="price">$149</span></td><td class="num gov">$0</td></tr>
            <tr data-prefill="I need help coordinating the I-693 medical exam package" data-formcode="I-693"><td><strong>I-693</strong> Medical Exam package coordination</td><td class="num"><span class="price">$99</span></td><td class="num gov">—</td></tr>
            <tr data-prefill="I need a G-639 FOIA request to USCIS" data-formcode="G-639"><td><strong>G-639</strong> FOIA Request to USCIS</td><td class="num"><span class="price">$129</span></td><td class="num gov">$0</td></tr>
            <tr data-prefill="I need an AR-11 change-of-address with USCIS" data-formcode="AR-11"><td><strong>AR-11</strong> Change of Address</td><td class="num"><span class="price">$49</span></td><td class="num gov">$0</td></tr>
          </tbody>
        </table>
        <p class="price-card-disclaimer">
          Document preparation only — no legal advice, no form selection on your behalf, no outcome guarantees. Imverica is not a law firm.
        </p>
      </div>

      <!-- ─────────────────────────────────────────────────────────────
           CATEGORY 2 — Family-based immigration (terracotta)
           ───────────────────────────────────────────────────────────── -->
      <div class="price-card price-card--terracotta">
        <div class="price-card-stripe"></div>
        <div class="price-card-head">
          <div class="price-card-icon" aria-hidden="true">👨‍👩‍👧</div>
          <div>
            <div class="price-card-kicker">Federal · all 50 states</div>
            <h2>Family-based immigration</h2>
            <p class="price-card-sub">Petitions, adjustment of status, naturalization. Multi-form packages save money vs filing each form separately.</p>
          </div>
        </div>
        <table class="price-table">
          <thead>
            <tr><th>Service</th><th class="num">Imverica fee</th><th class="num">Gov. fee*</th></tr>
          </thead>
          <tbody>
            <tr data-prefill="I need help with I-130 family petition" data-formcode="I-130"><td><strong>I-130</strong> Family Petition (standalone)</td><td class="num"><span class="price">$499</span></td><td class="num gov">$675</td></tr>
            <tr data-prefill="I need help with I-485 adjustment of status (single applicant)" data-formcode="I-485"><td><strong>I-485</strong> Adjustment of Status (single applicant)</td><td class="num"><span class="price">$999</span></td><td class="num gov">$1,440</td></tr>
            <tr class="price-row-popular" data-prefill="I need the full I-485 marriage-based AOS package (I-130 + I-485 + I-765 + I-864 + evidence)" data-formcode="I-485">
              <td><strong>I-485 Marriage-Based AOS Package</strong><br><span class="price-row-meta">I-130 + I-485 + I-765 + I-864 + evidence binder</span><span class="price-popular-pill">Most popular</span></td>
              <td class="num"><span class="price">$1,799</span></td>
              <td class="num gov">$2,090</td>
            </tr>
            <tr data-prefill="I need help with I-751 remove conditions on green card" data-formcode="I-751"><td><strong>I-751</strong> Remove Conditions on Green Card</td><td class="num"><span class="price">$899</span></td><td class="num gov">$750</td></tr>
            <tr data-prefill="I need help with N-400 naturalization application" data-formcode="N-400"><td><strong>N-400</strong> Naturalization</td><td class="num"><span class="price">$599</span></td><td class="num gov">$760</td></tr>
            <tr data-prefill="I need an I-824 action on approved application" data-formcode="I-824"><td><strong>I-824</strong> Action on Approved Application</td><td class="num"><span class="price">$249</span></td><td class="num gov">$620</td></tr>
          </tbody>
        </table>
        <p class="price-card-disclaimer">
          Final pricing depends on dependents, prior denials, complex history. Government filing fees paid directly to USCIS. Imverica is not a law firm.
        </p>
      </div>

      <!-- ─────────────────────────────────────────────────────────────
           CATEGORY 3 — Complex immigration (terracotta-deep)
           ───────────────────────────────────────────────────────────── -->
      <div class="price-card price-card--terracotta-deep">
        <div class="price-card-stripe"></div>
        <div class="price-card-head">
          <div class="price-card-icon" aria-hidden="true">📋</div>
          <div>
            <div class="price-card-kicker">Federal · custom quote after document review</div>
            <h2>Complex immigration document packages</h2>
            <p class="price-card-sub">Asylum, RFE responses, country-conditions evidence, motions. We quote after reviewing your facts — these vary too much for fixed prices.</p>
          </div>
        </div>
        <table class="price-table">
          <thead>
            <tr><th>Service</th><th class="num">Starting at</th><th class="num">Gov. fee*</th></tr>
          </thead>
          <tbody>
            <tr data-prefill="I need I-589 asylum document preparation" data-formcode="I-589"><td><strong>I-589</strong> Asylum document preparation</td><td class="num"><span class="price">from $1,599</span></td><td class="num gov">$0</td></tr>
            <tr data-prefill="I received a USCIS Request for Evidence (RFE) and need a response prepared"><td><strong>RFE Response</strong> package</td><td class="num"><span class="price">$399–$899</span></td><td class="num gov">$0</td></tr>
            <tr data-prefill="I need a country-conditions evidence packet"><td><strong>Country conditions</strong> evidence packet</td><td class="num"><span class="price">from $599</span></td><td class="num gov">$0</td></tr>
            <tr data-prefill="I need to file EOIR-29 Notice of Appeal to the BIA" data-formcode="EOIR-29"><td><strong>EOIR-29</strong> Notice of Appeal to BIA</td><td class="num"><span class="price">from $799</span></td><td class="num gov">$110</td></tr>
            <tr data-prefill="I need help with EOIR-42A or EOIR-42B Cancellation of Removal"><td><strong>EOIR-42A / 42B</strong> Cancellation of Removal</td><td class="num quote">custom quote</td><td class="num gov">$100</td></tr>
            <tr data-prefill="I need help with EOIR-40 Suspension of Deportation" data-formcode="EOIR-40"><td><strong>EOIR-40</strong> Suspension of Deportation</td><td class="num quote">custom quote</td><td class="num gov">$0</td></tr>
            <tr data-prefill="I need to file a motion to reopen or reconsider in immigration court"><td><strong>Motion to Reopen / Reconsider</strong></td><td class="num"><span class="price">from $699</span></td><td class="num gov">$110</td></tr>
            <tr data-prefill="I need help with a humanitarian package (U-visa, T-visa, VAWA, or U4U)"><td><strong>U / T / VAWA / U4U</strong> humanitarian packages</td><td class="num quote">custom quote</td><td class="num gov">varies</td></tr>
          </tbody>
        </table>
        <p class="price-card-disclaimer">
          Document preparation only. We do not represent you before USCIS or EOIR. We do not give legal advice on whether you qualify, your defenses, or your strategy — for that you need an attorney. Imverica is not a law firm.
        </p>
      </div>

      <!-- ─────────────────────────────────────────────────────────────
           CATEGORY 4 — California court forms (sage)
           ───────────────────────────────────────────────────────────── -->
      <div class="price-card price-card--sage">
        <div class="price-card-stripe"></div>
        <div class="price-card-head">
          <div class="price-card-icon" aria-hidden="true">⚖️</div>
          <div>
            <div class="price-card-kicker">California state courts only</div>
            <h2>California court forms</h2>
            <p class="price-card-sub">Family law, small claims, civil, eviction defense, probate. Packages bundle the common combinations.</p>
          </div>
        </div>
        <table class="price-table">
          <thead>
            <tr><th>Service</th><th class="num">Imverica fee</th><th class="num">Court fee*</th></tr>
          </thead>
          <tbody>
            <tr class="price-row-popular" data-prefill="I need a simple FL-100 divorce package (no kids, no property)" data-formcode="FL-100">
              <td><strong>FL-100 Simple Divorce</strong> package<br><span class="price-row-meta">no kids, no property — FL-100/110/115 + service</span><span class="price-popular-pill">Most popular</span></td>
              <td class="num"><span class="price">from $349</span></td>
              <td class="num gov">$435</td>
            </tr>
            <tr data-prefill="I need a full FL-100 divorce package with kids and/or property (UCCJEA)" data-formcode="FL-100"><td><strong>FL-100 Full Divorce</strong> (kids + property, UCCJEA)</td><td class="num"><span class="price">from $799</span></td><td class="num gov">$435</td></tr>
            <tr data-prefill="I need an FL-300 Request for Order (custody/support/visitation)" data-formcode="FL-300"><td><strong>FL-300</strong> Request for Order (custody/support)</td><td class="num"><span class="price">$349</span></td><td class="num gov">$0</td></tr>
            <tr data-prefill="I need FL-150 / FL-160 financial disclosures prepared" data-formcode="FL-150"><td><strong>FL-150 / FL-160</strong> Financial disclosures</td><td class="num"><span class="price">$149 each</span></td><td class="num gov">$0</td></tr>
            <tr data-prefill="I need a post-judgment modification (family law)"><td><strong>Post-judgment modification</strong> (family law)</td><td class="num"><span class="price">from $499</span></td><td class="num gov">$0</td></tr>
            <tr class="price-row-popular" data-prefill="I need the SC-100 small-claims package (SC-100 + proof of service)" data-formcode="SC-100">
              <td><strong>SC-100 Small Claims</strong> package<br><span class="price-row-meta">SC-100 + proof of service (POS-010)</span></td>
              <td class="num"><span class="price">$249</span></td>
              <td class="num gov">$30–$75</td>
            </tr>
            <tr data-prefill="I need a demand letter prepared before filing in court"><td><strong>Demand letter</strong> (pre-litigation)</td><td class="num"><span class="price">$99</span></td><td class="num gov">$0</td></tr>
            <tr data-prefill="I need help collecting on a court judgment (WG-001 wage garnishment / EJ-001 abstract)"><td><strong>WG-001 / EJ-001</strong> Judgment collection</td><td class="num"><span class="price">$199</span></td><td class="num gov">$40</td></tr>
            <tr data-prefill="I need an unlawful-detainer (eviction) response prepared — I'm the tenant"><td><strong>UD response</strong> (tenant defense)</td><td class="num"><span class="price">$349</span></td><td class="num gov">$240</td></tr>
            <tr data-prefill="I need a restraining order document package (DV / CH / EA / GV / WV)"><td><strong>Restraining order</strong> document package</td><td class="num quote">custom quote</td><td class="num gov">$0</td></tr>
            <tr data-prefill="I need a small-estate affidavit (estate under $184,500)"><td><strong>Small estate affidavit</strong> (under $184,500)</td><td class="num"><span class="price">$199</span></td><td class="num gov">$0</td></tr>
            <tr data-prefill="I need a DE-111 probate petition" data-formcode="DE-111"><td><strong>DE-111 Probate</strong> petition</td><td class="num"><span class="price">from $799</span></td><td class="num gov">$435</td></tr>
            <tr data-prefill="I need the full California probate package (DE-111 / 121 / 160 / 221)" data-formcode="DE-111"><td><strong>Full Probate</strong> package (DE-111/121/160/221)</td><td class="num"><span class="price">from $1,599</span></td><td class="num gov">$435+</td></tr>
          </tbody>
        </table>
        <p class="price-card-disclaimer">
          Document preparation under your direction. We do not give legal advice, choose the form for you, or represent you in court. <em>Cal. Bus. & Prof. Code §§6400–6415.</em>
        </p>
      </div>

      <!-- ─────────────────────────────────────────────────────────────
           CATEGORY 5 — Business + add-ons (gold)
           ───────────────────────────────────────────────────────────── -->
      <div class="price-card price-card--gold">
        <div class="price-card-stripe"></div>
        <div class="price-card-head">
          <div class="price-card-icon" aria-hidden="true">🏢</div>
          <div>
            <div class="price-card-kicker">California business + service add-ons</div>
            <h2>Business filings · translation · notary</h2>
            <p class="price-card-sub">Launch your LLC or corporation, register a DBA, file for an EIN. Plus certified translation and mobile notary.</p>
          </div>
        </div>
        <table class="price-table">
          <thead>
            <tr><th>Service</th><th class="num">Imverica fee</th><th class="num">State fee*</th></tr>
          </thead>
          <tbody>
            <tr class="price-row-popular" data-prefill="I want the LLC Launch Package (LLC-1 + LLC-12 + EIN + operating agreement)" data-formcode="LLC-1">
              <td><strong>LLC Launch Package</strong><br><span class="price-row-meta">LLC-1 + LLC-12 + EIN + operating agreement</span><span class="price-popular-pill">Best value</span></td>
              <td class="num"><span class="price">$449</span></td>
              <td class="num gov">$90</td>
            </tr>
            <tr data-prefill="I want the Corporation Launch Package (ARTS-GS + SI-550 + EIN + bylaws)" data-formcode="ARTS-GS"><td><strong>Corporation Launch Package</strong><br><span class="price-row-meta">ARTS-GS + SI-550 + EIN + bylaws</span></td><td class="num"><span class="price">$549</span></td><td class="num gov">$125</td></tr>
            <tr data-prefill="I need to form an LLC (LLC-1 only)" data-formcode="LLC-1"><td><strong>LLC-1</strong> Form an LLC (standalone)</td><td class="num"><span class="price">$199</span></td><td class="num gov">$70</td></tr>
            <tr data-prefill="I need to file LLC-12 Statement of Information" data-formcode="LLC-12"><td><strong>LLC-12</strong> Statement of Information</td><td class="num"><span class="price">$99</span></td><td class="num gov">$20</td></tr>
            <tr data-prefill="I need help getting an EIN (SS-4)" data-formcode="SS-4"><td><strong>SS-4 EIN</strong> application</td><td class="num"><span class="price">$79</span></td><td class="num gov">$0</td></tr>
            <tr data-prefill="I need to file a DBA / Fictitious Business Name" data-formcode="FBN"><td><strong>DBA / FBN</strong> (Fictitious Business Name)</td><td class="num"><span class="price">$129</span></td><td class="num gov">varies (county)</td></tr>
            <tr data-prefill="I need to register a foreign LLC in California" data-formcode="LLC-1A"><td><strong>Foreign-LLC registration</strong></td><td class="num"><span class="price">$299</span></td><td class="num gov">$70</td></tr>
            <tr data-prefill="I need an operating agreement template customised for my LLC"><td><strong>Operating agreement</strong> (customised template)</td><td class="num"><span class="price">$149</span></td><td class="num gov">$0</td></tr>
            <tr><td colspan="3" class="price-table-divider">Translation & notary</td></tr>
            <tr data-prefill="I need a certified translation (Russian / Ukrainian / Spanish ↔ English)"><td><strong>Certified translation</strong> (RU / UA / ES ↔ EN)</td><td class="num"><span class="price">from $35/page</span></td><td class="num gov">—</td></tr>
            <tr data-prefill="I need a certified translation of a birth / marriage / divorce / death certificate"><td><strong>Standard certificate</strong> (birth/marriage/divorce)</td><td class="num"><span class="price">$45 each</span></td><td class="num gov">—</td></tr>
            <tr data-prefill="I need a certified translation of a diploma / academic transcript"><td><strong>Diploma / transcript</strong> translation</td><td class="num"><span class="price">$75 each</span></td><td class="num gov">—</td></tr>
            <tr data-prefill="I need apostille coordination through California Secretary of State"><td><strong>Apostille coordination</strong> (CA Secretary of State)</td><td class="num"><span class="price">$99</span></td><td class="num gov">$26+</td></tr>
            <tr data-prefill="I need a mobile notary in the Sacramento area"><td><strong>Mobile notary</strong> (Sacramento metro, up to 3 signatures)</td><td class="num"><span class="price">from $75</span></td><td class="num gov">—</td></tr>
          </tbody>
        </table>
        <p class="price-card-disclaimer">
          We do not give business or tax advice. We prepare and file the forms; consult a CPA or attorney for entity-choice questions. Imverica is not a law firm.
        </p>
      </div>

      <!-- ─────────────────────────────────────────────────────────────
           Discounts strip
           ───────────────────────────────────────────────────────────── -->
      <div class="discounts-strip">
        <div class="discounts-strip-head">
          <h2>Discounts &amp; family packages</h2>
          <p>Layer these on top of any package. Multiple discounts can stack.</p>
        </div>
        <div class="discounts-grid">
          <button type="button" class="discount-card" data-prefill="I'm a first-time Imverica client and would like the introductory discount applied.">
            <div class="discount-pct">−15%</div>
            <div class="discount-title">First-time client</div>
            <div class="discount-desc">First matter with Imverica gets an introductory discount, applied automatically.</div>
          </button>
          <button type="button" class="discount-card" data-prefill="I have two or more family members on the same I-130 / I-485 flow — please apply the family-bundle discount.">
            <div class="discount-pct">−10%</div>
            <div class="discount-title">Family bundle</div>
            <div class="discount-desc">Two or more family members on the same I-130 / I-485 flow — discount on the second relative onward.</div>
          </button>
          <button type="button" class="discount-card" data-prefill="I'd like a multi-form bundle (3+ forms from the same family) — please quote with the bundle discount.">
            <div class="discount-pct">−10%</div>
            <div class="discount-title">Multi-form bundle</div>
            <div class="discount-desc">Three or more forms from the same family (e.g. full I-485 package) — discount on the bundle total.</div>
          </button>
          <button type="button" class="discount-card" data-prefill="I was referred by an existing Imverica client — please apply the referral credit.">
            <div class="discount-pct">−10%</div>
            <div class="discount-title">Referral credit</div>
            <div class="discount-desc">You refer a new client to Imverica — both of you get a credit on the next invoice.</div>
          </button>
          <button type="button" class="discount-card" data-prefill="I qualify for the USCIS fee waiver (I-912) or California court fee waiver — please apply the fee-waiver discount.">
            <div class="discount-pct">−25%</div>
            <div class="discount-title">Fee-waiver verified</div>
            <div class="discount-desc">If your household qualifies for the USCIS fee waiver (I-912) or California court fee waiver — we reduce our fee too.</div>
          </button>
          <a class="discount-card discount-card--b2b" href="/for-attorneys">
            <div class="discount-pct">B2B</div>
            <div class="discount-title">Attorney retainer</div>
            <div class="discount-desc">Law firms with a monthly retainer (10+ hours/month) bill at our reduced paralegal rate. <span class="b2b-link">See attorney pricing →</span></div>
          </a>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────────────────────
           Positioning strip — software vs Imverica vs attorney
           ───────────────────────────────────────────────────────────── -->
      <div class="compare-strip">
        <h2>Where we sit in the market</h2>
        <p class="compare-intro">For a sense of value, here's how Imverica compares to two adjacent options — DIY software and a private attorney. We sit in the middle on price, with full multilingual human support, LDA registration, and supervising attorney oversight.</p>
        <div class="compare-grid">
          <div class="compare-col compare-col--software">
            <div class="compare-tier">DIY software</div>
            <div class="compare-name">CitizenPath, LegalZoom</div>
            <ul>
              <li>~$79–$279 per form</li>
              <li>No human review</li>
              <li>English only</li>
              <li>You handle everything</li>
              <li>No LDA / IC registration</li>
            </ul>
          </div>
          <div class="compare-col compare-col--imverica">
            <div class="compare-tier compare-tier--featured">Imverica</div>
            <div class="compare-name">California LDA + Immigration Consultant</div>
            <ul>
              <li>Flat-fee packages from $149</li>
              <li>Real humans, 4 languages</li>
              <li>Registered, bonded, supervised</li>
              <li>We prepare + assemble + send</li>
              <li>Document preparation only</li>
            </ul>
          </div>
          <div class="compare-col compare-col--attorney">
            <div class="compare-tier">Private attorney</div>
