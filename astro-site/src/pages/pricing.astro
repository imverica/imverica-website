            <tr><td><strong>I-589</strong> Asylum document preparation</td><td class="num"><span class="price">from $1,599</span></td><td class="num gov">$0</td></tr>
            <tr><td><strong>RFE Response</strong> package</td><td class="num"><span class="price">$399–$899</span></td><td class="num gov">$0</td></tr>
            <tr><td><strong>Country conditions</strong> evidence packet</td><td class="num"><span class="price">from $599</span></td><td class="num gov">$0</td></tr>
            <tr><td><strong>EOIR-29</strong> Notice of Appeal to BIA</td><td class="num"><span class="price">from $799</span></td><td class="num gov">$110</td></tr>
