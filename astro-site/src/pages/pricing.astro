---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import CTAStrip from '~/components/CTAStrip.astro';

const title = 'Pricing — Flat-Fee Document Preparation | Imverica Legal Solutions';
const description = 'Transparent flat-fee pricing for USCIS, EOIR, California family law, small claims, probate, and business document preparation. Simple forms from $49. USCIS packages from $199. Family law from $349. Complex cases by custom quote. No hidden fees, no hourly creep. Imverica is not a law firm.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Imverica Document Preparation Pricing',
  provider: { '@type': 'LegalService', name: 'Imverica Legal Solutions', legalName: 'Imverica LLC', url: 'https://imverica.com', telephone: '+1-916-399-3992' },
  description: 'Flat-fee document preparation for USCIS, EOIR, and California state-court forms. Imverica is a California-registered Legal Document Assistant and Immigration Consultant — not a law firm. Documents prepared at client direction. Government filing fees are separate.',
  areaServed: [
    { '@type': 'Country', name: 'United States' },
    { '@type': 'State', name: 'California' }
  ],
  offers: [
    { '@type': 'Offer', name: 'I-90 Green Card Renewal',       priceCurrency: 'USD', price: '199' },
    { '@type': 'Offer', name: 'I-765 Work Permit',             priceCurrency: 'USD', price: '199' },
    { '@type': 'Offer', name: 'I-130 Family Petition',         priceCurrency: 'USD', price: '499' },
    { '@type': 'Offer', name: 'I-485 Adjustment (single)',     priceCurrency: 'USD', price: '999' },
    { '@type': 'Offer', name: 'I-485 Marriage AOS Package',    priceCurrency: 'USD', price: '1799' },
    { '@type': 'Offer', name: 'N-400 Naturalization',          priceCurrency: 'USD', price: '599' },
    { '@type': 'Offer', name: 'SC-100 Small Claims Package',   priceCurrency: 'USD', price: '249' },
    { '@type': 'Offer', name: 'FL-100 Simple Divorce',         priceCurrency: 'USD', price: '349' },
    { '@type': 'Offer', name: 'LLC Launch Package',            priceCurrency: 'USD', price: '449' }
  ]
};
---
<BaseLayout title={title} description={description} canonical="https://imverica.com/pricing"
  slug="/pricing" availableLocales={['en', 'ru', 'uk', 'es']} jsonLd={[schema]}>
  <Hero
    eyebrow="Transparent flat-fee pricing · no hourly creep · no surprises"
    heading="What does it cost?"
    sub="Flat fees per document or matter. Government filing fees are paid separately to USCIS, the court, or the Secretary of State. Documents are prepared at your direction — Imverica is not a law firm and does not provide legal advice."
    ctaPrimary={{ href: '/#get-started', text: 'Start your case' }}
    ctaSecondary={{ href: 'tel:+19163993992', text: '📞 +1 (916) 399-3992' }}
  />

  <section class="pricing-section">
    <div class="pricing-inner">

      <!-- ─────────────────────────────────────────────────────────────
           CATEGORY 1 — Simple USCIS forms (navy)
           ───────────────────────────────────────────────────────────── -->
      <div class="price-card price-card--navy">
        <div class="price-card-stripe"></div>
        <div class="price-card-head">
          <div class="price-card-icon" aria-hidden="true">🛂</div>
          <div>
            <div class="price-card-kicker">Federal · all 50 states</div>
            <h2>Simple USCIS forms</h2>
            <p class="price-card-sub">One form, straightforward situation. Most prepared in 24–48 hours.</p>
