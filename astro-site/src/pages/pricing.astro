            <tr><td><strong>I-765</strong> Work Permit / EAD</td><td class="num"><span class="price">$199</span></td><td class="num gov">$520</td></tr>
            <tr><td><strong>I-131</strong> Travel Document / Re-entry Permit</td><td class="num"><span class="price">$179</span></td><td class="num gov">$630</td></tr>
            <tr><td><strong>I-864</strong> Affidavit of Support (standalone)</td><td class="num"><span class="price">$149</span></td><td class="num gov">$0</td></tr>
            <tr><td><strong>I-693</strong> Medical Exam package coordination</td><td class="num"><span class="price">$99</span></td><td class="num gov">—</td></tr>
            <tr><td><strong>G-639</strong> FOIA Request to USCIS</td><td class="num"><span class="price">$129</span></td><td class="num gov">$0</td></tr>
            <tr><td><strong>AR-11</strong> Change of Address</td><td class="num"><span class="price">$49</span></td><td class="num gov">$0</td></tr>
          </tbody>
        </table>
        <p class="price-card-disclaimer">
          Document preparation only — no legal advice, no form selection on your behalf, no outcome guarantees. Imverica is not a law firm.
