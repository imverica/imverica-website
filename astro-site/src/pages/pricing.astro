  <!-- Wire price-table rows and discount cards to the QuickIntakeModal.
       Each row/card carries data-prefill (and optionally data-formcode);
       on click we open the intake with that text pre-filled into the
       situation field so the visitor's first message to us is already
       written. Falls back gracefully if openIntakeModal isn't ready. -->
  <script is:inline>
    (function () {
      function openIntake(prefill, formCode) {
        if (typeof window.openIntakeModal !== 'function') {
          // Modal hasn't loaded — fall back to the generic homepage CTA.
          window.location.href = '/#get-started';
          return;
        }
        window.openIntakeModal(prefill || '', formCode ? { formCode: formCode } : undefined);
      }

      // Price-table rows
      document.querySelectorAll('.price-table tr[data-prefill]').forEach(function (row) {
        row.classList.add('price-row-clickable');
        row.setAttribute('role', 'button');
        row.setAttribute('tabindex', '0');
        row.addEventListener('click', function () {
          openIntake(row.getAttribute('data-prefill'), row.getAttribute('data-formcode'));
        });
        row.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            openIntake(row.getAttribute('data-prefill'), row.getAttribute('data-formcode'));
          }
        });
      });

      // Discount cards (the B2B card is a real <a href> link — skip)
      document.querySelectorAll('.discount-card[data-prefill]').forEach(function (card) {
        card.addEventListener('click', function () {
          openIntake(card.getAttribute('data-prefill'));
        });
      });
    })();
  </script>

