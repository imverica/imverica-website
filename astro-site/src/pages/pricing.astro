            <tr><td><strong>Foreign-LLC registration</strong></td><td class="num"><span class="price">$299</span></td><td class="num gov">$70</td></tr>
            <tr><td><strong>Operating agreement</strong> (customised template)</td><td class="num"><span class="price">$149</span></td><td class="num gov">$0</td></tr>
            <tr><td colspan="3" class="price-table-divider">Translation & notary</td></tr>
            <tr><td><strong>Certified translation</strong> (RU / UA / ES ↔ EN)</td><td class="num"><span class="price">from $35/page</span></td><td class="num gov">—</td></tr>
            <tr><td><strong>Standard certificate</strong> (birth/marriage/divorce)</td><td class="num"><span class="price">$45 each</span></td><td class="num gov">—</td></tr>
            <tr><td><strong>Diploma / transcript</strong> translation</td><td class="num"><span class="price">$75 each</span></td><td class="num gov">—</td></tr>
            <tr><td><strong>Apostille coordination</strong> (CA Secretary of State)</td><td class="num"><span class="price">$99</span></td><td class="num gov">$26+</td></tr>
            <tr><td><strong>Mobile notary</strong> (Sacramento metro, up to 3 signatures)</td><td class="num"><span class="price">from $75</span></td><td class="num gov">—</td></tr>
          </tbody>
        </table>
        <p class="price-card-disclaimer">
