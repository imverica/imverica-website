const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'California Unlawful Detainer Document Preparation',
  provider: {
    '@type': 'LegalService',
    name: 'Imverica Legal Solutions',
    url: 'https://imverica.com',
    telephone: '+1-916-399-3992',
    areaServed: { '@type': 'State', name: 'California' },
    disambiguatingDescription: "Imverica is not a law firm. Document preparation only, at the client's direction."
  },
  description: "Imverica prepares California unlawful detainer (eviction) documents at the client's direction. UD-100, SUM-130, pre-filing notices, UD-105 answer, UD-110 judgment, POS-010 proof of service."
