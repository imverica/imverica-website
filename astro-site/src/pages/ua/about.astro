---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import LandingBody from '~/components/LandingBody.astro';
import CategoryTiles from '~/components/CategoryTiles.astro';
import CTAStrip from '~/components/CTAStrip.astro';

const lang = 'uk' as const;
const title = 'Про компанію Imverica — California LDA та Immigration Consultant | Imverica Legal Solutions';
const description = "Imverica Legal Solutions — мультимовний (англійська, російська, українська, іспанська) Legal Document Assistant та Immigration Consultant із Сакраменто. Готуємо документи USCIS, EOIR та судів Каліфорнії по всій території США та штату — за доступними, прозорими тарифами. Ми не юридична фірма й не надаємо юридичних консультацій.";

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: 'Imverica Legal Solutions',
  legalName: 'Imverica LLC',
  alternateName: ['Imverica', 'Imverica LLC'],
  url: 'https://imverica.com/ua/about',
  telephone: '+1-916-399-3992',
  email: 'info@imverica.com',
  areaServed: [
    { '@type': 'Country', name: 'United States' },
    { '@type': 'State', name: 'California' }
  ],
  knowsLanguage: ['en', 'ru', 'uk', 'es'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Sacramento',
    addressRegion: 'CA',
    addressCountry: 'US'
  },
  sameAs: [
    'https://www.instagram.com/imverica',
    'https://www.facebook.com/imverica/',
    'https://t.me/imverica'
  ],
  description: 'Imverica Legal Solutions — торгова марка Imverica LLC, компанії з обмеженою відповідальністю штату Каліфорнія. Зареєстрований California Legal Document Assistant та Immigration Consultant. Мультимовна (EN/RU/UK/ES) підготовка документів для USCIS, EOIR та судів штату Каліфорнія за доступними тарифами.'
};
---
<BaseLayout title={title} description={description} canonical="https://imverica.com/ua/about"
  slug="/about" lang={lang} availableLocales={['en', 'ru', 'uk', 'es']} jsonLd={[schema]}>
  <Hero
    lang={lang}
    eyebrow="Про Imverica Legal Solutions"
    heading="Доступна підготовка документів чотирма мовами — під вашу ситуацію"
    sub="База в Сакраменто. Каліфорнійські суди по всьому штату, USCIS — по всіх США. Говоримо англійською, російською, українською та іспанською. Готуємо документи за вашим дорученням — ми не юридична фірма і не надаємо юридичних консультацій."
    ctaPrimary={{ href: '/ua/#get-started', text: 'Почати кейс' }}
    ctaSecondary={{ href: 'tel:+19163993992', text: '📞 +1 (916) 399-3992' }}
  />

  <LandingBody lang={lang} related={[
    { href: '/ua/lda', label: 'Хто такий California Legal Document Assistant?' },
    { href: '/ua/for-attorneys', label: 'Для адвокатів — paralegal-партнерство' },
    { href: '/ua/immigration', label: 'USCIS та EOIR документи, які ми готуємо' },
    { href: '/ua/fl', label: 'Сімейне право Каліфорнії' }
  ]}>
    <p class="lead">
      Imverica Legal Solutions народилася в <strong>Сакраменто, Каліфорнія</strong> —
      одному з найбільш етнічно й лінгвістично різноманітних міст США.
      Це не декорація — це причина, через яку ми існуємо. Кожен квартал
      цього міста — це чиясь перша адреса в Америці, чийсь маленький
      бізнес, чийсь сімейний кейс, чийсь конверт з I-485, який лежить
      нерозкритим тому що супровідний лист — чужою мовою. Ми будували
      Imverica як офіс, до якого сусіди можуть реально зайти —
      доступний, мультимовний, чесний, і побудований навколо того,
      що потрібно працюючій родині від LDA-професіонала.
    </p>

    <h2 id="story">Хто ми</h2>
    <p>
      <strong>Imverica Legal Solutions</strong> — це споживчий бренд
      компанії <strong>Imverica LLC</strong>, товариства з обмеженою
      відповідальністю штату Каліфорнія. Ми — команда зареєстрованих
      каліфорнійських <strong>Legal Document Assistants</strong>
      (Cal. Bus. & Prof. Code §§6400–6415) та <strong>Immigration Consultants</strong>
      (§§22440–22448) з багаторічним paralegal-досвідом у петиціях USCIS,
      справах в імміграційних судах EOIR, сімейному праві Каліфорнії,
      малих позовах, виселеннях, спадкових справах та реєстрації бізнесу.
      Наша робота виконується <strong>під наглядом ліцензованих адвокатів</strong> —
      і як незалежні paralegal-партнери каліфорнійських юридичних фірм,
      і для наших роздрібних клієнтів через панель консультантів-адвокатів,
      до яких ми звертаємось, коли кейс потребує юридичного судження,
      що виходить за межі повноважень LDA. Це партнерство тримає нас
      усередині дозволених рамок, захищає клієнта і тримає роботу в
      реальній юридичній площині замість галочкового введення даних.
    </p>
    <p>
      Ми побудовані на трьох обіцянках — і радше втратимо кейс, ніж порушимо їх:
    </p>
    <ul>
      <li><strong>Чесність про обсяг.</strong> Якщо ваш кейс потребує адвоката — ми кажемо це на першому дзвінку і направляємо вас до нього. Ми не беремо грошей за «консультацію», щоб з'ясувати, чи потрапили ви за адресою — це безкоштовно.</li>
      <li><strong>Чесність про ціну.</strong> Фіксовані тарифи публікуються до того, як ви погоджуєтесь. Без погодинної накрутки. Без сюрпризів у другому рахунку.</li>
      <li><strong>Чесність про результат.</strong> Ми готуємо документи за вашим дорученням. Ми не кажемо вам, чи підходите ви за вимогами, не передбачаємо, чи скаже USCIS або суддя «так», і ніколи не гарантуємо результат. Хто гарантує — або адвокат, або людина, якій не варто довіряти.</li>
    </ul>

    <h2 id="why-we-exist">Навіщо ми потрібні</h2>
    <p>
      Більшості людей, яким потрібні юридичні папери, адвокат не потрібен.
      Їм потрібна правильна форма, правильно заповнена, подана вчасно,
      їхньою мовою. Їм потрібен хтось, хто візьме слухавку, вислухає, і не
      візьме $400 за годину за введення даних. Це та ніша, яку програма
      California Legal Document Assistant створена закривати — і ми
      закриваємо її прозоро, доступно і мовою, якою клієнт реально говорить
      удома.
    </p>
    <p>
      Зміна статусу (adjustment of status), оновлення грін-карти,
      натуралізація, політичний притулок, розлучення, малі позови, захист
      від виселення, реєстрація бізнесу — більшість цих кейсів потребують
      акуратної пари рук і когось, хто пояснить що відбувається вашою
      мовою, а не судового літиганта. Коли кейс реально потребує адвоката —
      ми це кажемо і працюємо разом з ним через нашу панель наглядових
      адвокатів. Це і є межа, навколо якої побудовано каліфорнійську
      LDA-модель, і ми її тримаємо.
    </p>

    <h2 id="languages">Чотири мови, живі люди</h2>
    <p>
      Кожна заявка, кожен документ, кожен follow-up лист — ми працюємо
      нативно <strong>англійською, російською, українською та іспанською</strong>.
      Не Google Translate. Не chatbot зі скриптом. Живі люди, які виросли
      на цих мовах, які розуміють культурний контекст ваших питань, яким
      не доведеться пояснювати заново термін, який ви вже використали.
      Коли форма англійською — ми проводимо вас по кожному полю; коли
      ситуація розказана українською — ми слухаємо українською.
    </p>

    <h2 id="what-makes-us-different">Чим ми відрізняємось</h2>
    <ul>
      <li><strong>Прозорі ціни.</strong> Фіксовані тарифи за документ або кейс, опубліковані до підписання договору. Без плати за «консультацію», щоб дізнатись скільки що коштує. Ми кажемо ціну першими; ви вирішуєте, чи варто воно того.</li>
      <li><strong>UPL-дисципліна.</strong> Ми готуємо документи за вашим дорученням — ми не рекомендуємо, яку форму подавати, не передбачаємо результат, не кажемо чи підходите ви за вимогами. Це робота адвоката, і ми направляємо до адвоката, коли кейс реально цього вимагає. Це не маркетинг — так влаштована каліфорнійська LDA-програма, і це захищає вас.</li>
      <li><strong>Швидкість.</strong> Більшість квот — у той самий робочий день. Більшість документів готові протягом 48 годин з моменту заявки. Ми не змусимо вас два тижні чекати USCIS-форму, яку ви могли надіслати сьогодні.</li>
      <li><strong>Мультимовна підтримка end-to-end.</strong> Заявка, підготовка документів і пост-податкова комунікація — все вашою мовою. Адвокатів, які говорять українською, мало; нас — багато.</li>
      <li><strong>Remote-first, штат Каліфорнія — по всьому штату, федеральна імміграція — по всіх США.</strong> Не потрібно їхати в Сакраменто. Працюємо телефоном, email, Telegram і через захищений особистий кабінет — підписуємо документи електронно, де це дозволено, надсилаємо оригінали, де це потрібно.</li>
      <li><strong>Для клієнтів і для адвокатів.</strong> Ми працюємо безпосередньо з self-represented приватними особами ТА з ліцензованими адвокатами в ролі їхнього незалежного paralegal. <a href="/ua/for-attorneys">Див. варіанти партнерства для адвокатів</a>.</li>
    </ul>

    <h2 id="scope">Що ми робимо — і чого не робимо</h2>
    <p>
      <strong>Що ми готуємо:</strong>
    </p>
    <ul>
      <li>Будь-яку форму USCIS для будь-якого штату — федеральна імміграція федеральна, ваш штат проживання не має значення (I-485 adjustment, I-130 family petition, I-765 work permit, I-589 asylum, N-400 naturalization, I-90 green card renewal, I-131 travel document, I-864 affidavit of support, відповіді на RFE, повні пакети доказів).</li>
      <li>Справи в імміграційних судах EOIR по всіх США (EOIR-29, 42A, 42B, motions, країнові пакети, declarations свідків).</li>
      <li>Сімейне право Каліфорнії (FL-100/110/120 розлучення, FL-150/160 фінансові декларації, FL-300 RFO, опіка, аліменти, judgment-пакети).</li>
      <li>Малі позови та цивільні справи Каліфорнії (SC-100 — SC-140, demand letters, утримання із заробітної плати, abstract of judgment).</li>
      <li>Виселення в Каліфорнії (UD-100/105/110, three-day notices, default-пакети).</li>
      <li>Спадкові справи Каліфорнії (DE-111/121/160/221/295, small estate affidavits, inventory, final distribution, final discharge).</li>
      <li>California record-cleanup / petition-for-dismissal packets (CR-180/181), включно з DUI та іншими eligible cases за дорученням клієнта.</li>
      <li>Реєстрація бізнесу в Каліфорнії (LLC-1, LLC-12, ARTS-GS, FBN, EIN).</li>
      <li>Сертифікований переклад документів (російська, українська, іспанська ↔ англійська) та координація апостилювання.</li>
    </ul>
    <p>
      <strong>Чого ми не робимо — за дизайном і за законом:</strong> ми не
      надаємо юридичних консультацій, не представляємо вас у суді, не
      підписуємо процесуальні документи, не ведемо переговори з протилежною
      стороною, і не рекомендуємо, яку форму вам подавати. Якщо ваша
      ситуація реально потребує адвоката (судовий процес, стратегія,
      виступи в суді) — ми скажемо це на першому дзвінку і допоможемо
      знайти. Ми радше втратимо кейс і збережемо вашу довіру, ніж продамо
      більше, ніж LDA має право.
    </p>

    <h2 id="compliance">Реєстрація та захист споживачів</h2>
    <p>
      Imverica Legal Solutions зареєстрована в межах каліфорнійського
      статуту Legal Document Assistant (Cal. Bus. & Prof. Code §§6400–6415)
      та статуту Immigration Consultant (§§22440–22448). Каліфорнія
      вимагає від LDA реєстрації в офісі клерка округу, оформлення
      страхової гарантії $25,000, проходження навчання та щорічного
      продовження — це захист, який штат вбудував, щоб споживачі знали,
      хто готує їхні документи. Поточні реєстраційні номери та інформація
      про страхову гарантію вказані в кожному intake-договорі;
      рекомендаційні листи та підтвердження надаються на запит.
    </p>
    <p>
      Для федеральної імміграційної роботи (петиції USCIS, справи EOIR)
      застосовується каліфорнійський Immigration Consultant Act і
      федеральна регуляція 8 CFR §1.2 / §292.1 — paralegal-підготовка
      документів під керівництвом клієнта дозволена на всій території США
      за умови, що ми ніколи не надаємо юридичних консультацій, ніколи не
      виступаємо перед USCIS або EOIR як ваш представник, і на кожному
      кроці розкриваємо, що ми не адвокати і не акредитовані представники.
    </p>

    <h2 id="contact">Як з нами зв'язатися</h2>
    <p>
      Найпростіший перший контакт — телефон або контактна форма на цьому
      сайті. Відповідаємо в той самий робочий день, вашою мовою.
    </p>
    <ul class="contact-list">
      <li><strong>Телефон і SMS:</strong> <a href="tel:+19163993992">+1 (916) 399-3992</a></li>
      <li><strong>Email:</strong> <a href="mailto:info@imverica.com">info@imverica.com</a></li>
      <li><strong>Telegram:</strong> <a href="https://t.me/imverica" target="_blank" rel="noopener">t.me/imverica</a></li>
      <li><strong>Web-заявка:</strong> <a href="/ua/#get-started">Почати кейс тут</a> — п'ятихвилинна форма, можна прикріпити до п'яти документів.</li>
      <li><strong>Особистий кабінет:</strong> <a href="/account.html">imverica.com/account</a> — увійдіть, щоб відстежувати відкриті кейси, обмінюватись документами та листуватись із командою.</li>
    </ul>
    <p>
      База в Сакраменто, Каліфорнія. Обслуговуємо Каліфорнію за справами
      штату і всі США з федеральної імміграції.
    </p>

    <cite>
      <strong>Важливе повідомлення.</strong> Imverica Legal Solutions — це
      торгова марка <strong>Imverica LLC</strong>, товариства з обмеженою
      відповідальністю штату Каліфорнія. Зареєстрований California Legal
      Document Assistant та Immigration Consultant — не юридична фірма.
      Ми не надаємо юридичних консультацій, не встановлюємо відносин
      «адвокат-клієнт» і не представляємо клієнтів у суді або перед
      USCIS / EOIR як акредитовані представники. Вся робота виконується
      за дорученням self-represented сторони відповідно до Cal. Bus. &
      Prof. Code §§6400–6415 та §§22440–22448.
    </cite>
  </LandingBody>

  <CategoryTiles
    kicker="Куди далі"
    heading="Оберіть напрямок"
    intro="Якщо вже знаєте, що вам потрібно — переходьте прямо туди:"
    tiles={[
      { icon: '🛂', title: 'USCIS та EOIR',         desc: 'I-485, I-130, I-765, asylum, removal-defense — будь-який штат США.', href: '/ua/immigration', color: 'var(--navy)' },
      { icon: '👨‍👩‍👧', title: 'Сімейне право CA',    desc: 'Розлучення, опіка, аліменти, post-judgment modifications.', href: '/ua/fl', color: 'var(--terracotta)' },
      { icon: '📃', title: 'Малі позови та civil',  desc: 'SC-100, demand letters, стягнення за рішенням.', href: '/ua/sc', color: 'var(--sage)' },
      { icon: '🏠', title: 'Виселення',             desc: 'UD-100, three-day notices, default-пакети.', href: '/ua/california-unlawful-detainer', color: 'var(--gold)' },
      { icon: '🏛️', title: 'Спадкові справи',       desc: 'Серія DE-111, small estate affidavits, final distribution, DE-295 discharge.', href: '/ua/california-probate', color: 'var(--navy-light)' },
      { icon: '🧾', title: 'Record cleanup',        desc: 'CR-180/181 expungement / petition-for-dismissal packets, включно з DUI.', href: '/ua/california-expungement', color: 'var(--gold)' },
      { icon: '🏢', title: 'Реєстрація бізнесу',    desc: 'LLC-1, ARTS-GS, FBN/DBA, EIN, foreign-LLC.', href: '/ua/business', color: 'var(--terracotta-deep)' },
      { icon: '🤝', title: 'Для адвокатів',         desc: 'Незалежний paralegal — USCIS по всіх США, суди CA.', href: '/ua/for-attorneys', color: 'var(--terracotta)' },
      { icon: '📚', title: 'Що таке LDA?',          desc: 'Cal. Bus. & Prof. Code §§6400–6415 простими словами.', href: '/ua/lda', color: 'var(--navy)' }
    ]}
  />

  <CTAStrip
    heading="Готові — коли ви готові."
    sub="Відповідь у той самий день. Документи за 48 годин. Чотири мови. Доступні, прозорі тарифи."
    primaryHref="/ua/#get-started"
    primaryText="Почати кейс"
  />

