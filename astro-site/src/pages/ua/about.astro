    .contact-list {
      list-style: none;
      padding-left: 0;
      margin: 18px 0;
    }
    .contact-list li {
      padding: 10px 14px;
      margin-bottom: 8px;
      background: rgba(26,46,74,0.04);
      border-left: 3px solid var(--navy);
      border-radius: 0 6px 6px 0;
      font-size: 15px;
      line-height: 1.6;
