---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import CTAStrip from '~/components/CTAStrip.astro';

const lang = 'uk' as const;
const title = 'Імміграційні та судові документи у Сакраменто — українською | Imverica';
const description =
  'U4U, TPS, дозвіл на роботу I-765, грін-карта, документи судів Каліфорнії — підготовка у Сакраменто українською мовою. Registered LDA та Immigration Consultant. Фіксовані ціни.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: 'Imverica Legal Solutions',
  url: 'https://imverica.com/ua/sacramento',
  telephone: '+1-916-399-3992',
  areaServed: [
    { '@type': 'City', name: 'Sacramento' },
    { '@type': 'City', name: 'Rancho Cordova' },
    { '@type': 'City', name: 'Citrus Heights' },
    { '@type': 'City', name: 'Elk Grove' },
    { '@type': 'City', name: 'Roseville' }
  ],
  availableLanguage: ['Ukrainian', 'Russian', 'English', 'Spanish'],
  description:
    'Підготовка імміграційних і судових документів у Сакраменто українською: U4U, TPS, USCIS, EOIR, суди Каліфорнії. Registered Legal Document Assistant та Immigration Consultant.'
};
---
<BaseLayout title={title} description={description} canonical="https://imverica.com/ua/sacramento"
  slug="/ua/sacramento" lang={lang} jsonLd={[schema]}>
  <Hero
    lang={lang}
    eyebrow="Сакраменто · Українською · Registered LDA · Immigration Consultant"
    heading="Імміграційні та судові документи у Сакраменто — вашою мовою"
    sub="U4U, TPS, дозвіл на роботу, грін-карта, суди Каліфорнії: готуємо документи за вашим дорученням, пояснюємо кожен крок українською, фіксована ціна відома до початку роботи. Ми не юридична фірма і не надаємо юридичних порад — яку форму подавати, вирішуєте ви."
    ctaPrimary={{ href: '/#get-started', text: 'Почати заявку' }}
  />

  <section class="svc-section">
    <div class="svc-inner">
      <div class="svc-kicker">Для української громади</div>
      <h2>Сакраменто — одна з найбільших українських громад Америки</h2>
      <p>
        Після лютого 2022 року тисячі українських родин приїхали до Сакраменто
        за програмою Uniting for Ukraine — до родичів і друзів у Rancho
        Cordova, Citrus Heights, North Highlands, Antelope. І майже в кожної
        родини той самий список справ: продовжити пароль (re-parole), подати
        чи перереєструвати TPS, оновити дозвіл на роботу I-765, а далі —
        грін-карта, возз'єднання родини, навіть перший бізнес у Каліфорнії.
      </p>
      <p>
        Imverica Legal Solutions — зареєстрований у Каліфорнії Legal Document
        Assistant (Cal. Bus. &amp; Prof. Code §§6400–6415) та Immigration
        Consultant (§§22440–22448) у Сакраменто. Ми офіційно готуємо документи
        за вашим дорученням, маємо bond, працюємо за письмовим договором із
        фіксованою ціною — і чесно кажемо, коли вашій справі потрібен адвокат,
        а не підготовка документів.
      </p>

      <div class="svc-kicker" style="margin-top:34px;">Українські справи — наша щоденна робота</div>
      <h2>З чим найчастіше звертаються</h2>
      <p>
        <strong>U4U та гуманітарний захист:</strong> re-parole для українців
        (I-131, категорія 10.C), дозвіл на роботу I-765 категорії (c)(11),
        перша подача та перереєстрація TPS (I-821 + I-765 разом).
        <strong>Далі — стабільний статус:</strong> пакет на політичний
        притулок I-589 з декларацією, грін-карта через родину чи притулок
        (I-485, I-130, I-864), проїзні документи, натуралізація N-400.
        <strong>Життя в Каліфорнії:</strong> розлучення (FL-100) та відповідь
        на розлучення (FL-120), аліменти й опіка (FL-300), малі позови
        (SC-100), відповідь на виселення, зміна імені (NC-100), охоронні
        ордери. <strong>Свій бізнес:</strong> LLC-1, EIN, DBA — багато наших
        клієнтів відкривають перевезення, будівництво, салони й кафе.
      </p>
      <p>
        Кожен документ ви переглядаєте та схвалюєте в особистому кабінеті до
        фінальної версії — зі статусами справи, завантаженням документів і
        листуванням українською.
      </p>

      <div class="svc-kicker" style="margin-top:34px;">Як це працює</div>
      <h2>Фіксована ціна і зрозумілий процес</h2>
      <p>
        Розкажіть про ситуацію — українською, телефоном, у Telegram або прямо
        на сайті. Ми покажемо, які форми зазвичай використовують у таких
        випадках (загальна інформація, не юридична консультація). Ціна
        фіксована й відома до початку роботи; державні збори завжди окремо та
        сплачуються напряму до USCIS чи суду. Прості форми готові за 24–48
        годин.
      </p>
      <p>
        Прийом за записом; працюємо з усім округом Сакраменто та дистанційно по
        всій Каліфорнії і США (федеральні імміграційні форми — для клієнтів у
        будь-якому штаті). Телефонуйте або пишіть:
        <a href="tel:+19163993992">+1 (916) 399-3992</a> — розмовляємо
        українською, російською, англійською та іспанською.
      </p>
    </div>
  </section>

  <CTAStrip
    lang={lang}
    heading="Розкажіть, який документ вам потрібен"
    sub="Відповімо протягом одного робочого дня. Лише підготовка документів — не юридична консультація."
  />
</BaseLayout>
