---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import LandingBody from '~/components/LandingBody.astro';
import CategoryTiles from '~/components/CategoryTiles.astro';
import CTAStrip from '~/components/CTAStrip.astro';

const lang = 'uk' as const;
const title = 'Підготовка бізнес-документів Каліфорнії (LLC, DBA, EIN) | Imverica';
const description = 'California Licensed LDA готує бізнес-документи за вашим дорученням — LLC Articles of Organization (LLC-1), Statement of Information (LLC-12), fictitious business name (DBA), підтримка EIN. Фіксована ціна, без юридичних консультацій.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'California Business Filing Document Preparation',
  provider: { '@type': 'LegalService', name: 'Imverica Legal Solutions', url: 'https://imverica.com', telephone: '+1-916-399-3992', areaServed: { '@type': 'State', name: 'California' } },
  description: 'Підготовка бізнес-документів Каліфорнії — LLC, DBA, EIN та корпоративні записи за дорученням клієнта.'
};
---
<BaseLayout title={title} description={description} canonical="https://imverica.com/ua/business"
  slug="/business" lang={lang} availableLocales={['en', 'ru', 'uk', 'es']} jsonLd={[schema]}>
  <Hero
    lang={lang}
    eyebrow="Бізнес-документи Каліфорнії"
    heading="Підготовка бізнес-документів"
    sub="Створення LLC (LLC-1), Statement of Information (LLC-12), fictitious business name (DBA) і підтримка EIN — готуємо акуратно за вашим дорученням, фіксована ціна, без сюрпризів."
    ctaPrimary={{ href: '/#get-started?service=business', text: 'Почати бізнес-подачу' }}
  />

  <CategoryTiles
    kicker="Оберіть подання"
    heading="California Business"
    intro="LLC, корпорація, DBA, EIN — почніть потрібний пакет."
    tiles={[
      { icon: '🏢', title: 'LLC-1 — Створити LLC',         desc: 'Articles of Organization до Secretary of State.',  href: '/ua/llc-1-form-an-llc',   color: 'var(--navy)' },
      { icon: '📋', title: 'LLC-12 — Statement of Info',   desc: 'Початкова + раз на 2 роки Statement of Information.', href: '/ua/llc-12-statement-of-information', color: 'var(--terracotta)' },
      { icon: '🏛️', title: 'ARTS — Корпорація',           desc: 'General-stock або public-benefit Articles.',          href: '/ua/arts-gs-incorporation', color: 'var(--sage)' },
      { icon: '✍️', title: 'FBN / DBA',                    desc: 'Fictitious business name у county clerk.',             href: '/ua/fbn-dba',     color: 'var(--gold)' },
      { icon: '🔢', title: 'SS-4 — EIN',                   desc: 'Підтримка федерального EIN.',                          href: '/ua/ss-4-ein',    color: 'var(--navy-light)' },
      { icon: '📜', title: 'Operating agreement',          desc: 'Збірка LLC operating agreement.',                       href: '/ua/operating-agreement',      color: 'var(--terracotta-deep)' },
      { icon: '🔄', title: 'LLC-1A — З іншого штату',      desc: 'Реєстрація foreign LLC для роботи в Каліфорнії.',      href: '/ua/llc-1a-foreign-llc',  color: 'var(--navy)' },
      { icon: '📊', title: 'SI-550 — Corp Statement',      desc: 'Statement of Information корпорації.',                  href: '/ua/si-550-corporation-statement', color: 'var(--sage)' }
    ]}
  />

  <LandingBody related={[
    { href: '/ua/lda', label: 'Хто такий California Legal Document Assistant?' },
    { href: '/ua/sc', label: 'California малі позови (SC-100)' },
    { href: '/ua/immigration', label: 'USCIS | EOIR імміграційні документи' }
  ]}>
    <p class="lead">
      Відкриття або ведення бізнесу в Каліфорнії означає паперову роботу
      — реєстрація компанії, реєстрація назви, податкова ідентифікація
      і поточні подання, що тримають компанію в good standing. Як
      зареєстрований Legal Document Assistant, Imverica готує ці
      документи акуратно за вашим дорученням. Ми не є юридичною фірмою
      і не надаємо юридичних або податкових консультацій; ми готуємо
      ті документи, які ви вже вирішили подати.
    </p>

    <h2>Створення LLC у Каліфорнії</h2>
    <p>
      Каліфорнійське LLC створюється поданням форми
      <strong>Articles of Organization (Form LLC-1)</strong> до Secretary
      of State. Протягом 90 днів від створення — і кожні два роки після —
      LLC має подавати <strong>Statement of Information (Form LLC-12)</strong>.
      Каліфорнійські LLC також обкладаються щорічним $800 franchise tax
      від Franchise Tax Board. Ми готуємо документи для подання; ми не
      надаємо податкових консультацій і не обираємо за вас тип компанії.
    </p>

    <h2>Форми та документи, які ми готуємо</h2>
    <div class="form-list">
      <strong>Пакети бізнес-документів</strong>
      <ul>
        <li><strong>LLC-1</strong> — Articles of Organization (створення LLC)</li>
        <li><strong>LLC-12</strong> — Statement of Information (початкова і раз на 2 роки)</li>
        <li><strong>LLC-1A</strong> — Реєстрація LLC з іншого штату</li>
        <li><strong>ARTS-GS / ARTS-PB</strong> — Articles of Incorporation корпорації</li>
        <li><strong>SI-550</strong> — Statement of Information корпорації</li>
        <li><strong>FBN / DBA</strong> — Fictitious Business Name statement (округ)</li>
        <li><strong>SS-4 / EIN</strong> — Підтримка федерального Employer Identification Number</li>
        <li><strong>Operating agreement</strong> — Збірка LLC operating agreement</li>
      </ul>
    </div>

    <h2>Fictitious business name (DBA)</h2>
    <p>
      Індивідуальний підприємець або компанія, що працює під назвою,
      відмінною від юридичної, подає
      <strong>Fictitious Business Name statement</strong> у county clerk
      за місцем бізнесу, потім публікує його в схваленій округом газеті
      чотири тижні поспіль. Ми готуємо FBN statement і допомагаємо
      організувати крок публікації.
    </p>

    <h2>EIN — Employer Identification Number</h2>
    <p>
      Більшості бізнесів потрібен федеральний <strong>EIN</strong>
      (Form SS-4) від IRS для відкриття банківського рахунку, найму
      працівників або подання податків. Ми допомагаємо підготувати
      інформацію для SS-4, щоб ваша заявка була повна і точна.
    </p>

    <h2>Чого ми не робимо</h2>
    <p>
      Ми не надаємо юридичних чи податкових консультацій, не радимо
      який тип компанії створювати, не консультуємо щодо liability і не
      представляємо вас перед жодною інстанцією. Ці рішення за вами
      (або вашим адвокатом / CPA). У нас встановлені referral-відносини
      з ліцензованими каліфорнійськими спеціалістами для питань, що
      потребують юридичного чи податкового супроводу.
    </p>

    <cite>
      <strong>Джерело:</strong> California Corporations Code (LLC і
      корпоративні подання); California Business &amp; Professions Code
      §§17900-17930 (fictitious business names); California Business
      &amp; Professions Code §§6400-6415 (Legal Document Assistant Act).
      Лише підготовка документів — не юридичні чи податкові консультації.
    </cite>
  </LandingBody>

  <CTAStrip primaryHref="/#get-started" primaryText="Почати з Imverica" />
</BaseLayout>
