---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import HomeSearch from '~/components/HomeSearch.astro';
import StatsStrip from '~/components/StatsStrip.astro';
import { HERO } from '~/data/i18n';

const lang = 'uk' as const;
const title = 'Imverica Legal Solutions | USCIS · EOIR · Каліфорнійські форми';
const description =
  'Каліфорнійський ліцензований LDA та імміграційний консультант. Підготовка документів USCIS, EOIR, сімейного права, малих позовів та спадкових справ. Віддалений сервіс по всьому світу.';


const legalServiceSchema = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: 'Imverica Legal Solutions',
  url: 'https://imverica.com',
  telephone: '+1-916-399-3992',
  areaServed: [
    { '@type': 'State', name: 'California' },
    { '@type': 'Country', name: 'United States' }
  ],
  address: { '@type': 'PostalAddress', addressRegion: 'CA', addressCountry: 'US' },
  description: 'Каліфорнійський ліцензований помічник з юридичних документів та імміграційний консультант. Підготовка документів USCIS, EOIR, сімейного права, малих позовів, виселення та спадкових справ.',
  knowsLanguage: ['en', 'ru', 'uk', 'es'],
  serviceType: [
    'Підготовка імміграційних форм USCIS',
    'Підготовка документів EOIR',
    'Підготовка каліфорнійських форм сімейного права',
    'Підготовка документів малих позовів',
    'Підготовка документів unlawful detainer',
    'Підготовка документів зі спадкових справ'
  ],
  disambiguatingDescription: 'Imverica Legal Solutions не є юридичною фірмою і не надає юридичних консультацій. Документи готуються за дорученням клієнта.'
};
---
<BaseLayout
  title={title}
  description={description}
  canonical="https://imverica.com/ua/"
  jsonLd={[legalServiceSchema]}
  lang={lang}
  slug="/"
  availableLocales={['en', 'ru', 'uk', 'es']}
>
  <Hero
    lang={lang}
    eyebrow={HERO.uk.eyebrow}
    heading={HERO.uk.heading}
    sub={HERO.uk.sub}
    showActions={false}
  >
    <HomeSearch lang={lang} />
  </Hero>
  <StatsStrip lang={lang} />

  <section class="svc-section">
    <div class="svc-inner" style="text-align:center;">
      <div class="svc-kicker">Що ми робимо</div>
      <h2>USCIS, EOIR і каліфорнійські форми — готуємо під ключ</h2>
      <p style="margin:0 auto 1.4rem;max-width:780px;">
        Допомога з підготовкою документів українською, російською, англійською та іспанською. Не юридична фірма, юридичних порад не надаємо — готуємо форми акуратно за дорученням клієнта.
      </p>
      <div class="uk-form-grid">
        <a class="btn" href="/ua/i-485-help">I-485 — грін-карта (AOS)</a>
        <a class="btn btn-ghost" href="/ua/i-589-asylum-help">I-589 — притулок</a>
        <a class="btn btn-ghost" href="/ua/n-400-citizenship-help">N-400 — громадянство</a>
        <a class="btn btn-ghost" href="/immigration#immigration-consultant-california">I-130 — сімейна петиція</a>
        <a class="btn btn-ghost" href="/immigration#immigration-consultant-california">I-765 — дозвіл на роботу</a>
        <a class="btn btn-ghost" href="/immigration#immigration-consultant-california">I-131 — travel document</a>
        <a class="btn btn-ghost" href="/immigration#eoir-documents">EOIR-28 / 42A / 42B</a>
        <a class="btn btn-ghost" href="/ua/california-unlawful-detainer">Виселення (UD-100)</a>
      </div>
      <p style="margin:1.4rem auto 0;font-size:13px;color:var(--muted);">
        Повний перелік форм USCIS, EOIR і Каліфорнії — на сторінці
        <a href="/immigration">USCIS | EOIR</a>.
      </p>
    </div>
  </section>

  <style>
    .uk-form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 12px;
      max-width: 880px;
      margin: 0 auto;
    }
  </style>
</BaseLayout>
