---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import LandingBody from '~/components/LandingBody.astro';
import CategoryTiles from '~/components/CategoryTiles.astro';
import CTAStrip from '~/components/CTAStrip.astro';

const lang = 'uk' as const;
const title = 'Каліфорнійське сімейне право — підготовка документів | Imverica';
const description = 'California Registered LDA готує документи сімейного права за вашим дорученням — divorce, response, custody, support, financial disclosures, UCCJEA, fee waivers та пов’язані FL/FW форми.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'California Family Law Document Preparation',
  provider: { '@type': 'LegalService', name: 'Imverica Legal Solutions', url: 'https://imverica.com', telephone: '+1-916-399-3992', areaServed: { '@type': 'State', name: 'California' } },
  description: 'Підготовка документів сімейного права Каліфорнії за дорученням сторони. Розлучення, separation, parentage, custody, support.'
};
---
<BaseLayout title={title} description={description} canonical="https://imverica.com/ua/fl"
  slug="/fl" lang={lang} availableLocales={['en', 'ru', 'uk', 'es']} jsonLd={[schema]}>
  <Hero
    lang={lang}
    eyebrow="California Family Law · Family Code §2330 et seq."
    heading="Форми сімейного права Каліфорнії"
    sub="Підготовка документів для self-represented сторін у family law: розлучення та відповідь, custody і support requests, financial disclosures, property declarations, UCCJEA, fee waivers та пов’язані FL/FW court forms."
    ctaPrimary={{ href: '/#get-started?form=FL-100', text: 'Почати пакет сімейного права' }}
  />

  <CategoryTiles
    kicker="Оберіть напрям"
    heading="California Family Law"
    intro="Спочатку оберіть напрям сімейної справи. Пакети за конкретними формами — нижче."
    tiles={[
      { icon: '💍', title: 'FL-100 — Розлучення',         desc: 'Заява про розлучення (no-fault), summons, service.', href: '/ua/fl-100-divorce',  color: 'var(--navy)' },
      { icon: '👶', title: 'FL-300 — Опіка / Аліменти',   desc: 'Request for Order: тимчасові накази, зміна.',         href: '/ua/fl-300-request-for-order',  color: 'var(--terracotta)' },
      { icon: '💰', title: 'FL-150 — Доходи і витрати',   desc: 'Фінансові disclosures для support і judgment.',       href: '/ua/fl-150-income-expense-declaration',  color: 'var(--sage)' },
      { icon: '🏠', title: 'FL-160 — Майно',             desc: 'Декларація community / separate property.',           href: '/ua/fl-160-property-declaration',  color: 'var(--gold)' },
      { icon: '🛡️', title: 'DV-100 — Restraining order', desc: 'Domestic-violence TRO + RO After Hearing.',           href: '/ua/california-restraining-orders', color: 'var(--terracotta-deep)' },
      { icon: '📑', title: 'FL-105 / UCCJEA',              desc: 'Декларація про юрисдикцію опіки над дітьми.',         href: '/ua/fl-105-uccjea', color: 'var(--navy-light)' },
      { icon: '📝', title: 'FL-120 — Відповідь',          desc: 'Відповідь респондента протягом 30 днів від service.', href: '/ua/fl-120-divorce-response', color: 'var(--navy)' },
      { icon: '🧾', title: 'FW-001 — Fee waiver',         desc: 'Звільнення від судового мита за кваліфікації.',       href: '/ua/fw-001-fee-waiver', color: 'var(--sage)' }
    ]}
  />

  <LandingBody related={[
    { href: '/california-restraining-orders', label: 'California restraining orders (DV / CH)' },
    { href: '/ua/sc', label: 'California малі позови (SC-100)' },
    { href: '/ua/lda', label: 'Хто такий California Legal Document Assistant?' }
  ]}>
    <p class="lead">
      Сімейне право Каліфорнії охоплює розлучення та зареєстровані
      domestic partnerships, юридичне розділення (legal separation),
      анулювання (nullity), встановлення батьківства (parentage), опіку
      та порядок спілкування, аліменти на дітей і на чоловіка/дружину,
      а також restraining orders у межах сімейної справи. Наша роль —
      підготовка документів за вашим дорученням; ми не надаємо
      юридичних консультацій, але готуємо кожну стандартну форму FL-
      і FW- акуратно та вчасно.
    </p>

    <h2>Розлучення — стандартний шлях</h2>
    <ol>
      <li><strong>Petition (FL-100).</strong> Подає будь-хто з подружжя. Каліфорнія — no-fault штат: «irreconcilable differences» — стандартна причина.</li>
      <li><strong>Summons (FL-110)</strong> автоматично вводить тимчасові restraining orders, що забороняють великі перекази активів, вивезення дітей зі штату та зміну отримувачів страховок.</li>
      <li><strong>Service.</strong> Респондент отримує документи особисто (FL-115).</li>
      <li><strong>Response (FL-120).</strong> У респондента 30 днів на відповідь. Без відповіді суд може винести default після 6-місячного waiting period.</li>
      <li><strong>Financial disclosures (FL-140 + FL-142 або FL-160 + FL-150).</strong> Обидві сторони обмінюються preliminary disclosures протягом 60 днів від подачі та final disclosures до judgment.</li>
      <li><strong>Переговори / медіація / судовий розгляд.</strong> Більшість справ закінчуються угодою. Спірні йдуть на short cause або long cause trial.</li>
      <li><strong>Judgment (FL-180 + FL-190).</strong> Суд виносить рішення. Статус «single» набуває чинності через 6 місяців і 1 день після service.</li>
    </ol>

    <h2>Форми, які ми готуємо</h2>
    <div class="form-list">
      <strong>Пакети сімейного права</strong>
      <ul>
        <li><strong>FL-100</strong> — Petition (Marriage / Domestic Partnership)</li>
        <li><strong>FL-105 / UCCJEA</strong> — Declaration за Uniform Child Custody Jurisdiction Act (обов'язкова за наявності неповнолітніх дітей)</li>
        <li><strong>FL-110</strong> — Summons (Family Law)</li>
        <li><strong>FL-115</strong> — Proof of Service of Summons</li>
        <li><strong>FL-117</strong> — Notice and Acknowledgment of Receipt</li>
        <li><strong>FL-120</strong> — Response (Marriage / Domestic Partnership)</li>
        <li><strong>FL-140</strong> — Declaration of Disclosure</li>
        <li><strong>FL-141</strong> — Declaration Regarding Service of Declaration of Disclosure</li>
        <li><strong>FL-142</strong> — Schedule of Assets and Debts</li>
        <li><strong>FL-150</strong> — Income and Expense Declaration</li>
        <li><strong>FL-160</strong> — Property Declaration</li>
        <li><strong>FL-180 / FL-190</strong> — Judgment and Notice of Entry of Judgment</li>
        <li><strong>FL-300</strong> — Request for Order (тимчасові накази, зміна, contempt тощо)</li>
        <li><strong>FL-311</strong> — Child Custody and Visitation Attachment</li>
        <li><strong>FL-341</strong> — Child Custody and Visitation Order Attachment</li>
        <li><strong>FL-330</strong> — Proof of Personal Service</li>
        <li><strong>FW-001 / FW-003</strong> — Запит і наказ про fee waiver</li>
      </ul>
    </div>

    <h2>Чого ми не робимо</h2>
    <p>
      Ми не ведемо переговори від вашого імені, не складаємо
      індивідуальні marital settlement agreements, що потребують
      юридичного аналізу community-property, та не представляємо вас
      на слуханнях. Більшість сімейних справ закінчуються stipulation,
      яке ми можемо оформити у стандартній формі (FL-130, FL-180
      attachments). Спірні справи про опіку з високим рівнем конфлікту,
      складні community-property питання чи звинувачення у
      domestic-violence краще передати ліцензованому family-law
      адвокату — ми можемо надати referral.
    </p>

    <cite>
      <strong>Джерело:</strong> California Family Code §2330 (petition
      про розлучення); §§3010-3032 (custody jurisdiction); §§3040-3041
      (custody factors); §4055 (statewide uniform child support
      guideline); §4320 (spousal support factors); §§2104-2107
      (disclosure requirements); §§297-299.6 (registered domestic
      partnerships). California Rules of Court 5.50-5.435 (family law
      rules).
    </cite>
  </LandingBody>

  <CTAStrip primaryHref="/#get-started?form=FL-100" primaryText="Почати заявку з сімейного права" />
</BaseLayout>
