---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import LandingBody from '~/components/LandingBody.astro';
import CategoryTiles from '~/components/CategoryTiles.astro';
import CTAStrip from '~/components/CTAStrip.astro';

const lang = 'es' as const;
const title = 'FL-150 — Declaración de Ingresos y Gastos | Imverica';
const description = 'California Registered LDA prepara la FL-150 Income and Expense Declaration usada para manutención de hijos, manutención conyugal y sentencia en el derecho familiar de California. Bajo su dirección.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'California Income and Expense Declaration (FL-150) Document Preparation',
  provider: { '@type': 'LegalService', name: 'Imverica Legal Solutions', url: 'https://imverica.com', telephone: '+1-916-399-3992' },
  description: 'Preparación de documentos para la Income and Expense Declaration de California (Formulario FL-150), bajo la dirección del cliente.'
};
---
<BaseLayout title={title} description={description} canonical="https://imverica.com/mx/fl-150-income-expense-declaration"
  slug="/fl-150-income-expense-declaration" lang={lang} availableLocales={['en', 'ru', 'uk', 'es']} jsonLd={[schema]}>
  <Hero
    lang={lang}
    eyebrow="California Family Law · Fam. Code §§2104-2105"
    heading="FL-150 — Declaración de Ingresos y Gastos"
    sub="La FL-150 es el panorama financiero que la corte usa para fijar la manutención de hijos y conyugal. La preparamos con precisión a partir de sus cifras, bajo su dirección — precio fijo, entrevista multilingüe."
    ctaPrimary={{ href: '/#get-started?form=FL-150', text: 'Comenzar mi FL-150' }}
  />

  <CategoryTiles
    kicker="Dónde se usa la FL-150"
    heading="Qué respalda la FL-150"
    intro="La declaración de ingresos acompaña varias presentaciones. Toque un tile para ver para qué sirve cada uno."
    tiles={[
      { icon: '💍', title: 'FL-100 — Petición',          desc: 'Se presenta con la petición de divorcio como declaración preliminar.',              href: '/mx/fl-100-divorce',                   color: 'var(--terracotta-deep)' },
      { icon: '📄', title: 'FL-120 — Respuesta',          desc: 'La presenta el otro cónyuge junto con la respuesta.',                               href: '/mx/fl-120-divorce-response',          color: 'var(--navy)' },
      { icon: '👶', title: 'FL-300 — Request for Order',  desc: 'Se adjunta cuando solicita manutención o modificación.',                            href: '/mx/fl-300-request-for-order',         color: 'var(--sage)' },
      { icon: '🏠', title: 'FL-160 — Propiedad',          desc: 'La declaración complementaria de bienes y deudas.',                                 href: '/mx/fl-160-property-declaration',      color: 'var(--gold)' },
      { icon: '🧾', title: 'FW-001 — Exención de tarifas', desc: 'A menudo la presenta el mismo solicitante que califica por ingresos.',              href: '/mx/fw-001-fee-waiver',                color: 'var(--navy-light)' },
      { icon: '📑', title: 'FL-105 / UCCJEA',             desc: 'Declaración de jurisdicción de custodia cuando hay hijos.',                          href: '/mx/fl-105-uccjea',                    color: 'var(--terracotta)' }
    ]}
  />

  <LandingBody related={[
    { href: '/mx/fl-300-request-for-order', label: 'FL-300 — Request for Order (manutención)' },
    { href: '/mx/fl', label: 'Todos los formularios de derecho familiar de California' },
    { href: '/mx/lda', label: '¿Qué es un California Legal Document Assistant?' }
  ]}>
    <p class="lead">
      El Formulario FL-150, Income and Expense Declaration, da a la corte una
      foto bajo juramento de sus ingresos, deducciones, activos y gastos
      mensuales. Es la base que la corte usa para calcular la manutención de
      hijos y conyugal, así que la exactitud y los anexos completos importan.
    </p>

    <h2>Cuándo presenta la FL-150</h2>
    <ul>
      <li>Como declaración preliminar y final en un divorcio.</li>
      <li>Cada vez que solicita o responde a una orden de manutención (con FL-300).</li>
      <li>Cuando pide a la corte modificar una orden de manutención existente.</li>
    </ul>

    <h2>Qué preparamos</h2>
    <ul>
      <li><strong>FL-150</strong> completada con las cifras de ingresos, deducciones y gastos que usted proporciona.</li>
      <li>Organización de los anexos de <strong>talones de pago y declaraciones de impuestos</strong> que exige el formulario.</li>
      <li>Las <strong>FL-160 / FL-142</strong> complementarias cuando se necesiten.</li>
    </ul>

    <h2>Qué NO hacemos</h2>
    <p>
      Imverica es un California Legal Document Assistant registrado — no un
      bufete de abogados. Ingresamos las cifras que usted nos da, bajo su
      dirección. No calculamos un monto de manutención "recomendado", no damos
      asesoría legal o fiscal, ni lo representamos. Para asesoría mantenemos
      referencias a abogados con licencia.
    </p>

    <cite>
      <strong>Fuente:</strong> California Family Code §§2104-2105 (declaraciones)
      y la guía estatal de manutención de hijos, Fam. Code §4055; California
      Rules of Court, título 5. Solo preparación de documentos — no asesoría
      legal.
    </cite>
  </LandingBody>

  <CTAStrip primaryHref="/#get-started?form=FL-150" primaryText="Comenzar mi entrevista FL-150" />
</BaseLayout>
