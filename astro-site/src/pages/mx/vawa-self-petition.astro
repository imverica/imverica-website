---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import LandingBody from '~/components/LandingBody.astro';
import CategoryTiles from '~/components/CategoryTiles.astro';
import CTAStrip from '~/components/CTAStrip.astro';

const lang = 'es' as const;
const title = 'Auto-petición VAWA (I-360) — preparación de documentos | Imverica';
const description = 'California Registered LDA prepara paquetes confidenciales de auto-petición VAWA — Formulario I-360 para cónyuges, hijos y padres maltratados de ciudadanos de EE. UU. o LPR, con I-485 e I-765 cuando es elegible. Bajo su dirección.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'VAWA Self-Petition (Form I-360) Document Preparation',
  provider: { '@type': 'LegalService', name: 'Imverica Legal Solutions', url: 'https://imverica.com', telephone: '+1-916-399-3992' },
  description: 'Preparación confidencial de documentos para auto-peticiones VAWA para sobrevivientes de abuso, bajo la dirección del cliente.'
};
---
<BaseLayout title={title} description={description} canonical="https://imverica.com/mx/vawa-self-petition"
  slug="/vawa-self-petition" lang={lang} availableLocales={['en', 'ru', 'uk', 'es']} jsonLd={[schema]}>
  <Hero
    lang={lang}
    eyebrow="USCIS · VAWA · INA §204(a)(1)"
    heading="Auto-petición VAWA (I-360) — preparación de documentos"
    sub="La Ley contra la Violencia hacia las Mujeres (VAWA) permite que cónyuges, hijos y padres maltratados de ciudadanos de EE. UU. o residentes permanentes se auto-peticionen — de forma confidencial, sin el conocimiento ni la participación del agresor. Preparamos el paquete del Formulario I-360 bajo su dirección, con estricta confidencialidad."
    ctaPrimary={{ href: '/#get-started?form=I-360', text: 'Comenzar mi paquete VAWA' }}
  />

  <CategoryTiles
    kicker="Formularios del paquete VAWA"
    heading="Qué incluye una auto-petición VAWA"
    intro="Un caso VAWA suele combinar varias presentaciones. Todo se maneja con confidencialidad. Toque un tile para comenzar."
    tiles={[
      { icon: '🛡️', title: 'I-360 — Auto-petición',         desc: 'Petición del sobreviviente — la presentación VAWA central bajo INA §204(a)(1).',   href: '/#get-started?form=I-360', color: 'var(--terracotta-deep)' },
      { icon: '🟢', title: 'I-485 — Ajuste de estatus',      desc: 'Paquete de green card cuando hay visa disponible para el auto-peticionario aprobado.', href: '/mx/i-485-help',        color: 'var(--navy)' },
      { icon: '💼', title: 'I-765 — Permiso de trabajo',     desc: 'Autorización de empleo para auto-peticionarios VAWA elegibles.',                   href: '/mx/i-765-work-permit-help', color: 'var(--sage)' },
      { icon: '📑', title: 'Evidencia y declaraciones',      desc: 'Prueba organizada de la relación calificada, la convivencia y el abuso.',          href: '/#get-started?form=I-360', color: 'var(--gold)' },
      { icon: '🔒', title: 'Protección de confidencialidad', desc: 'Las presentaciones VAWA están protegidas contra divulgación bajo 8 U.S.C. §1367.',  href: '/#get-started?form=I-360', color: 'var(--navy-light)' },
      { icon: '⚖️', title: 'Referencia a abogado',           desc: 'Para asesoría, plan de seguridad o representación referimos a abogados con licencia.', href: '/mx/lda',              color: 'var(--terracotta)' }
    ]}
  />

  <LandingBody related={[
    { href: '/mx/i-485-help', label: 'I-485 — Ajuste de Estatus' },
    { href: '/mx/i-765-work-permit-help', label: 'I-765 — Permiso de Trabajo (EAD)' },
    { href: '/mx/lda', label: '¿Qué es un California Legal Document Assistant?' }
  ]}>
    <p class="lead">
      La Ley contra la Violencia hacia las Mujeres (VAWA) permite que ciertos
      sobrevivientes de abuso se peticionen a sí mismos — de forma independiente
      del familiar agresor — para que un ciudadano de EE. UU. o residente
      permanente abusivo ya no pueda usar el estatus migratorio como herramienta
      de control. A pesar del nombre, VAWA es neutral en cuanto al género:
      protege a hombres, mujeres y niños.
    </p>

    <h2>Quién puede auto-peticionarse</h2>
    <ul>
      <li>Un cónyuge maltratado de un ciudadano de EE. UU. o residente permanente legal (los hijos del cónyuge pueden incluirse).</li>
      <li>Un hijo maltratado (soltero, menor de 21) de un ciudadano de EE. UU. o residente permanente.</li>
      <li>Un padre o madre maltratado de un ciudadano de EE. UU. de 21 años o más.</li>
      <li>Vivió con el agresor, la relación fue real, tiene buen carácter moral y sufrió maltrato físico o crueldad extrema.</li>
    </ul>

    <h2>Qué preparamos</h2>
    <ul>
      <li><strong>Formulario I-360</strong> — la auto-petición, integrada con la evidencia de elegibilidad requerida.</li>
      <li><strong>Paquete de apoyo</strong> — su declaración personal, prueba de la relación calificada, evidencia de convivencia y documentación del abuso, todo organizado para presentar.</li>
      <li><strong>Formulario I-485 y Formulario I-765</strong> — ajuste de estatus y autorización de empleo cuando es elegible.</li>
      <li><strong>Traducciones certificadas</strong> de documentos en idioma extranjero.</li>
    </ul>

    <h2>Confidencialidad y qué NO hacemos</h2>
    <p>
      Las presentaciones VAWA tienen protecciones de confidencialidad
      especiales: la ley prohíbe que USCIS se base en información provista por
      el agresor y restringe la divulgación del caso. Tratamos cada caso VAWA
      como confidencial y nunca contactamos al agresor. VAWA es legalmente
      compleja y a menudo está ligada a preocupaciones de seguridad — Imverica
      es un Legal Document Assistant registrado, no un bufete de abogados.
      Preparamos documentos bajo su dirección y no damos asesoría legal, no
      diseñamos su estrategia, no hacemos planes de seguridad ni garantizamos
      ningún resultado. Recomendamos enfáticamente trabajar con un abogado de
      inmigración con licencia o una organización calificada de servicios para
      víctimas, y mantenemos referencias.
    </p>

    <cite>
      <strong>Fuente:</strong> Violence Against Women Act of 1994 y sus
      reautorizaciones; INA §204(a)(1)(A)(iii)-(iv) y (B)(ii)-(iii)
      (familiares auto-peticionarios de ciudadanos de EE. UU. y LPR); 8 C.F.R.
      §204.2(c)-(e); 8 U.S.C. §1367 (confidencialidad). Solo preparación de
      documentos — no asesoría legal.
    </cite>
  </LandingBody>

  <CTAStrip primaryHref="/#get-started?form=I-360" primaryText="Comenzar mi entrevista VAWA" />
</BaseLayout>
