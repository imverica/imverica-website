  .rd-visa-meta { font-family: var(--mono); font-size: 11px; color: #8FA0AE; letter-spacing: .04em; margin-bottom: 6px; }
  .rd-visa-title { font-family: var(--serif); font-size: 24px; color: #F1E9DA; font-weight: 500; margin-bottom: 18px; }
  .rd-visa-legend { display: flex; flex-direction: column; gap: 11px; }
