  .rd-visa-legrow strong { color: #EAE2D3; }
  .rd-visa-chip { width: 30px; height: 30px; border-radius: 7px; color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-weight: 600; font-size: 14px; flex-shrink: 0; }
  .rd-visa-chip--c { background: #3C9A6B; }
  .rd-visa-chip--u { background: #9A4242; }
  .rd-visa-foot { font-size: 12.5px; color: #8FA0AE; line-height: 1.5; margin: 18px 0 0; border-top: 1px solid rgba(255,255,255,.1); padding-top: 14px; }
  .rd-visa-foot strong { color: #C4CDD6; }

  /* REVIEWS */
  .rd-reviews { background: var(--paper-alt); border-top: 1px solid var(--border); padding: 78px 0; }
  .rd-reviews-head { text-align: center; margin-bottom: 42px; }
  .rd-reviews-intro { font-size: 16px; color: var(--text-3); max-width: 560px; margin: 14px auto 0; line-height: 1.6; text-wrap: pretty; }
  .rd-review { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 24px; display: flex; flex-direction: column; }
  .rd-review-stars { color: var(--gold-light); font-size: 14px; letter-spacing: 2px; margin-bottom: 14px; }
  .rd-review-text { font-size: 14.5px; line-height: 1.6; color: #3C4A55; margin: 0 0 18px; flex: 1; }
  .rd-review-foot { display: flex; align-items: center; gap: 12px; border-top: 1px solid #EFE8DB; padding-top: 14px; }
  .rd-review-avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--ink); color: var(--gold-light); display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 17px; font-weight: 600; flex-shrink: 0; }
  .rd-review-name { font-weight: 600; font-size: 14px; color: #16232F; }
  .rd-review-tag { font-family: var(--mono); font-size: 10.5px; color: #9AA3AD; letter-spacing: .03em; margin-top: 2px; }
  .rd-reviews-cta { text-align: center; margin-top: 34px; }
  .rd-ghost-btn { display: inline-flex; align-items: center; gap: 9px; color: #16232F; font-weight: 600; font-size: 14.5px; border: 1px solid #D8CDB8; border-radius: 10px; padding: 12px 22px; transition: border-color .18s ease; }
  .rd-ghost-btn:hover { border-color: var(--gold); }

  /* ABOUT */
  .rd-about { background: var(--paper); padding: 80px 0; }
  .rd-about-head { text-align: center; max-width: 720px; margin: 0 auto 46px; }
  .rd-about-intro { font-size: 16.5px; color: var(--text-2); margin: 0; line-height: 1.65; text-wrap: pretty; }
  .rd-aboutcard { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 28px; }
  .rd-aboutcard-icon { width: 42px; height: 42px; border-radius: 10px; background: var(--gold-tint); color: var(--gold-deep); display: flex; align-items: center; justify-content: center; font-size: 19px; margin-bottom: 18px; }
  .rd-aboutcard-title { font-family: var(--serif); font-weight: 500; font-size: 21px; letter-spacing: -.01em; margin: 0 0 10px; color: #15222E; }
  .rd-aboutcard-desc { font-size: 14px; line-height: 1.6; color: var(--text-3); margin: 0; }

  /* FOOTER */
  .rd-footer { background: var(--ink-deep); color: #B9C3CD; }
  .rd-footer .rd-container { padding-top: 56px; padding-bottom: 36px; }
  .rd-footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 40px; padding-bottom: 40px; border-bottom: 1px solid rgba(255,255,255,.1); }
  .rd-footer-brand { display: flex; align-items: center; gap: 11px; margin-bottom: 16px; }
  .rd-footer-mark { width: 34px; height: 34px; border-radius: 7px; background: #16232F; border: 1px solid rgba(255,255,255,.15); display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-weight: 600; font-size: 19px; color: var(--gold-light); }
  .rd-footer-brandname { font-family: var(--serif); font-size: 18px; font-weight: 600; color: #EAE2D3; }
  .rd-footer-tag { font-size: 13px; line-height: 1.6; color: #8B96A1; margin: 0 0 18px; max-width: 340px; }
  .rd-footer-contact { font-family: var(--mono); font-size: 12.5px; color: #C4CDD6; line-height: 1.9; }
  .rd-footer-coltitle { font-family: var(--mono); font-size: 10.5px; letter-spacing: .14em; text-transform: uppercase; color: #6E7B87; margin-bottom: 14px; }
  .rd-footer-links { display: flex; flex-direction: column; gap: 9px; font-size: 13.5px; }
  .rd-footer-links a { color: #B9C3CD; transition: color .18s ease; }
  .rd-footer-links a:hover { color: var(--gold-light); }
  .rd-footer-legal { padding-top: 24px; font-size: 11.5px; line-height: 1.7; color: #6E7B87; }
  .rd-footer-legal p { margin: 0 0 10px; }
  .rd-footer-legal p:last-child { margin: 0; }

  /* RESPONSIVE */
  @media (max-width: 1080px) {
    .rd-nav { display: none; }
    .rd-grid-3 { grid-template-columns: repeat(2, 1fr); }
    .rd-news-grid { grid-template-columns: 1fr; gap: 32px; }
    .rd-news-aside { position: static; }
    .rd-visa-panel { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 760px) {
    .rd-container, .rd-utility-inner, .rd-header-inner, .rd-stats-inner, .rd-hero-inner { padding-left: 20px; padding-right: 20px; }
    .rd-hero-h1 { font-size: 40px; }
    .rd-hero-sub { font-size: 16px; }
    .rd-h2, .rd-h2--onDark { font-size: 30px; }
    .rd-h2--news { font-size: 26px; }
    .rd-stats-inner { grid-template-columns: repeat(2, 1fr); gap: 28px 16px; }
    .rd-grid-3 { grid-template-columns: 1fr; }
    .rd-services-head { flex-direction: column; align-items: flex-start; }
    .rd-visa-panel { padding: 30px; }
    .rd-footer-grid { grid-template-columns: 1fr; gap: 28px; }
    .rd-utility-left { gap: 10px; flex-wrap: wrap; }
    .rd-utility { font-size: 11.5px; }
  }
  @media (max-width: 460px) {
    .rd-stats-inner { grid-template-columns: 1fr; }
    .rd-utility-left .rd-pipe { display: none; }
  }
</style>

<script>
  // Stats count-up — animates 0 → target when the band enters the viewport.
  // Mirrors the handoff interaction: 1400ms, ease-out cubic, runs once.
  (function () {
    const band = document.querySelector<HTMLElement>('[data-stats-band]');
    if (!band) return;
    const bandEl = band;
    let counted = false;

    function run() {
      if (counted) return;
      counted = true;
      const nums = Array.from(bandEl.querySelectorAll<HTMLElement>('[data-count]'));
      const dur = 1400;
      const start = performance.now();
      const targets = nums.map((el) => Number(el.getAttribute('data-count')) || 0);
      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - t, 3);
        nums.forEach((el, i) => { el.textContent = String(Math.round(targets[i] * eased)); });
        if (t < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    if ('IntersectionObserver' in window) {
      const obs = new IntersectionObserver((entries, observer) => {
        entries.forEach((e) => { if (e.isIntersecting) { run(); observer.disconnect(); } });
      }, { threshold: 0.35 });
      obs.observe(bandEl);
    } else {
      run();
    }
  })();

  // Hero search — quick chips fill the input; submit is a no-op in the
  // preview (production wires this to the intake / forms-search route).
  (function () {
    const input = document.getElementById('rdSearchInput') as HTMLInputElement | null;
    const form = document.getElementById('rdSearch') as HTMLFormElement | null;
    if (input) {
      const inputEl = input;
      document.querySelectorAll<HTMLElement>('[data-chip]').forEach((btn) => {
        btn.addEventListener('click', () => {
          inputEl.value = btn.getAttribute('data-chip') || '';
          inputEl.focus();
        });
      });
    }
    if (form) form.addEventListener('submit', (e) => { e.preventDefault(); });
  })();

  // Scroll-reveal — tiles fade + rise into view, staggered within each row.
  (function () {
    const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const root = document.querySelector<HTMLElement>('.rd');
    if (!root || reduce || !('IntersectionObserver' in window)) return;
    const els = Array.from(root.querySelectorAll<HTMLElement>('.rd-reveal'));
    if (!els.length) return;
    root.classList.add('rd-anim');

    // Stagger each tile by its position within its own parent container.
    const counts = new Map<Element, number>();
    els.forEach((el) => {
      const parent = el.parentElement;
      if (!parent) return;
      const i = counts.get(parent) || 0;
      counts.set(parent, i + 1);
      el.style.transitionDelay = Math.min(i, 6) * 70 + 'ms';
    });

    const obs = new IntersectionObserver((entries, observer) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('in'); observer.unobserve(e.target); }
      });
    }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });
    els.forEach((el) => obs.observe(el));
  })();

  // Language pills — visual active state only in the preview (production
  // wires these to the real EN/RU/UA/ES locale routing).
  (function () {
    const pills = document.querySelectorAll<HTMLElement>('.rd-lang');
    pills.forEach((btn) => {
      btn.addEventListener('click', () => {
        pills.forEach((b) => { b.classList.remove('is-active'); });
        btn.classList.add('is-active');
      });
    });
  })();
</script>
</body>
