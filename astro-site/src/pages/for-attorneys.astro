---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import LandingBody from '~/components/LandingBody.astro';
import CategoryTiles from '~/components/CategoryTiles.astro';
import CTAStrip from '~/components/CTAStrip.astro';

const title = 'For Attorneys — Affordable Paralegal Support, USCIS & EOIR Nationwide | Imverica';
const description = 'Imverica is your independent paralegal partner — preparing USCIS petitions and EOIR filings for attorneys nationwide, and California state court documents (family law, small claims, unlawful detainer, probate, business) for California attorneys. We are ready to partner with your firm. Pay-by-project, hourly, or retainer.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Independent Paralegal Services for Attorneys',
  areaServed: [
    { '@type': 'Country', name: 'United States' },
    { '@type': 'State', name: 'California' }
  ],
  provider: { '@type': 'LegalService', name: 'Imverica Legal Solutions', url: 'https://imverica.com', telephone: '+1-916-399-3992' },
  description: "Independent paralegal services for attorneys. USCIS petitions and EOIR immigration court filings handled for attorneys in any US state (federal forms — no state bar restriction). California state-court matters (family law, small claims, unlawful detainer, probate, business) for California attorneys. Document preparation under the attorney's direction."
};
---
<BaseLayout title={title} description={description} canonical="https://imverica.com/for-attorneys"
  slug="/for-attorneys" availableLocales={['en', 'ru', 'uk', 'es']} jsonLd={[schema]}>
  <div class="for-attorneys-hero">
    <Hero
      eyebrow="For attorneys · USCIS & EOIR nationwide · California state court"
      heading="Affordable paralegal support — under your direction"
      sub="Your full-service paralegal partner. We handle USCIS petitions and EOIR immigration court work for attorneys in any state, and California state-court matters (family law, small claims, unlawful detainer, probate, business) for California attorneys. You stay counsel of record. We prepare the paperwork — accurately, on time, on your firm's templates. We're ready to partner with you on a single matter or a steady book of work."
      ctaPrimary={{ href: '#fees', text: 'See fee structures' }}
    />
  </div>

  <CategoryTiles
    kicker="What we handle for your firm"
    heading="Practice areas we support"
    intro="USCIS and EOIR are federal — we work with attorneys in any US state. California-specific matters (family law, small claims, unlawful detainer, probate, record cleanup, business) we handle for California attorneys. Pick a category and we'll show you our fee structures and a clear path to engage us — these tiles route to our pricing and contact section, not to a client intake. You're the attorney; this is your B2B view."
    tiles={[
      { icon: '🛂', title: 'USCIS petitions · nationwide', desc: 'I-485, I-130, I-765, I-589, N-400, I-90, I-131, I-864 packages, RFE responses, evidence indexes. Federal forms — any state.', href: '#fees', color: 'var(--navy)' },
      { icon: '⚖️', title: 'EOIR filings · nationwide',    desc: 'EOIR-29 / 42A / 42B / 40, motions to reopen/reconsider, evidence packets, country-conditions exhibits, witness declarations. Federal immigration court — any state.', href: '#fees', color: 'var(--navy-dark)' },
      { icon: '👨‍👩‍👧', title: 'Family law · CA',           desc: 'FL-100/110/120/150/160/300, custody packets, UCCJEA, judgment papers, post-judgment modifications.', href: '#fees', color: 'var(--terracotta)' },
      { icon: '📃', title: 'Small claims & civil · CA',   desc: 'SC-100/120/104/133/140, demand letters, wage garnishment, abstract of judgment, civil cover sheets, POS.', href: '#fees', color: 'var(--sage)' },
      { icon: '🏠', title: 'Unlawful detainer · CA',       desc: 'UD-100/105/110, three-day notices, default packets, post-judgment writs.', href: '#fees', color: 'var(--gold)' },
      { icon: '🏛️', title: 'Probate · CA',                 desc: 'DE-111/121/160/221/295 series, small estate affidavits, probate notice, inventory, final distribution, discharge packets.', href: '#fees', color: 'var(--navy-light)' },
      { icon: '🧾', title: 'Record cleanup · CA',          desc: 'CR-180/181 petition-for-dismissal packets, DUI record-cleanup support, declarations, proof of service, fee waivers.', href: '#fees', color: 'var(--gold)' },
      { icon: '🏢', title: 'Business filings · CA',        desc: 'LLC-1 / LLC-12, ARTS-GS, SI-550, FBN/DBA, SS-4 EIN support, operating agreements, foreign-LLC registration.', href: '#fees', color: 'var(--terracotta-deep)' },
      { icon: '🌐', title: 'Translation & notary',         desc: 'Russian / Ukrainian / Spanish certified translations, apostille coordination, mobile notary referrals. Nationwide.', href: '#fees', color: 'var(--navy)' }
    ]}
  />

  <LandingBody related={[
    { href: '/lda', label: 'What is a California Legal Document Assistant?' },
    { href: '/immigration', label: 'USCIS & EOIR documents we prepare' },
    { href: '/fl', label: 'Family law forms (FL-)' },
    { href: '/sc', label: 'Small claims & civil (SC-)' },
    { href: '/business', label: 'Business filings (LLC-, ARTS-, FBN)' }
  ]}>
    <p class="lead">
      <strong>We're ready to partner with your firm.</strong> You're an
      attorney with a full calendar — we're the steady hand that prepares
      the paperwork accurately, on time, in your client's voice. Whether
      you're a solo immigration attorney in New York filing a single
      I-589, or a California firm with a steady book of family-law
      matters, we plug in as your independent paralegal: drafting forms,
      assembling exhibit binders, building evidence indexes, and turning
      your strategy notes into a court-ready package. You stay counsel
      of record. We stay invisible to the client unless you want us
      visible. <strong>One matter, ten matters, or full ongoing
      support — we'd love to work with you.</strong>
    </p>

    <h2 id="who-we-help">Who we work with</h2>
    <p>
      We partner with attorneys across the country on federal immigration
      matters, and with California-licensed attorneys on state-court work:
    </p>
    <ul>
      <li><strong>Immigration attorneys anywhere in the US</strong> — solo and small-firm practitioners handling adjustment, asylum, family-petition, removal-defense, naturalization, and humanitarian dockets. USCIS and EOIR are federal, so no state bar restriction applies to our paralegal work — we partner with attorneys from New York to Texas to Florida and everywhere in between.</li>
      <li><strong>California family law attorneys</strong> drowning in form-heavy filings (FL-150 income-and-expense, FL-160 property declarations, FL-300 RFOs, FL-105 UCCJEA, judgment packages, post-judgment modifications).</li>
      <li><strong>California litigation attorneys</strong> who need small-claims and civil packets prepared cleanly to free up associate time for actual lawyering.</li>
      <li><strong>California estate-planning attorneys</strong> with probate, small-estate, and post-decedent administrative work.</li>
      <li><strong>California business attorneys</strong> wanting entity formation, foreign-LLC registration, and post-formation compliance outsourced.</li>
      <li><strong>Multi-state firms</strong> who want one paralegal partner for their federal immigration practice and any California desk they operate.</li>
    </ul>

    <h2 id="how-we-work">How we work with your firm</h2>
    <p>
      <strong>Engagement is fast and informal — we want to make it easy
      to say yes.</strong> Send us the matter (intake notes, client info,
      strategy decisions you've already made). We confirm scope and
      timeline in writing the same business day. We prepare the documents
      in your firm's preferred template style — your letterhead, your
      formatting conventions, your exhibit numbering. You review and
      sign. We never hold your client file outside what's needed for the
      immediate task, and everything we touch is encrypted at rest and
      in transit. Conflict checks, confidentiality terms, and ABA Model
      Rule 5.3 supervision protocols — all handled to your satisfaction
      before the first matter starts.
    </p>
    <p>
      We don't give legal advice — that's your job. We don't sign anything
      that requires a member of the State Bar — that's also your job. We
      handle the form mastery, the data entry, the cross-referencing,
      the citations, and the proofreading. You handle the law and the
      client relationship. We've worked with attorneys for years and
      we know how to make ourselves useful without ever stepping outside
      our lane.
    </p>

    <h2 id="fees">Fee structures — pick what fits how you bill</h2>

    <div class="fee-grid">
      <div class="fee-card">
        <div class="fee-card-icon" aria-hidden="true">📐</div>
        <h3>Pay by project</h3>
        <p class="fee-card-lead">A fixed quote for each defined matter.</p>
        <p>
          Best when the scope is clear up front (I-485 adjustment package,
          FL-100 petition + summons + UCCJEA, SC-100 + service, etc.).
          We send a written quote after a short intake call — usually
          within the same business day. You approve, we deliver. No
          surprises and no hourly creep.
        </p>
      </div>

      <div class="fee-card">
        <div class="fee-card-icon" aria-hidden="true">⏱️</div>
        <h3>Pay as you go</h3>
        <p class="fee-card-lead">Hourly billing — no monthly commitment.</p>
        <p>
          For attorneys with unpredictable volume or quick one-off
          requests. Flat hourly rate, billed in tenth-of-an-hour
          increments, invoiced monthly. Great for firms that just want
          paralegal capacity on tap without signing up for retainer hours
          they may not use.
        </p>
      </div>

      <div class="fee-card fee-card-highlight">
        <div class="fee-card-icon" aria-hidden="true">⭐</div>
        <h3>Monthly retainer</h3>
        <p class="fee-card-lead">10+ hours/month at a discounted rate.</p>
        <p>
          For firms that consistently use 10 or more paralegal hours each
          month. Pay in advance, lock in a lower hourly rate, and reserve
          priority turnaround. Any hours beyond the committed minimum
          also bill at the discounted rate. Most attorney-clients pick
          this option once they've worked with us for a quarter.
        </p>
      </div>

      <div class="fee-card">
        <div class="fee-card-icon" aria-hidden="true">🤝</div>
        <h3>Discounts &amp; referrals</h3>
        <p class="fee-card-lead">New-client and referral pricing.</p>
        <p>
          New attorney clients get a discounted introductory rate on the
          first matter. Referring another attorney to Imverica earns both
          firms a credit on the next invoice. Long-term partners (12+
          months of continuous engagement) move to our top-tier rate
          automatically.
        </p>
      </div>
    </div>

    <p class="affordable-note">
      <strong>All rates are affordable and negotiable — we want your
      business and we'll price to earn it.</strong> Send us a sample
      matter or your current paralegal cost structure; we'll come back
      with a quote that's typically 30–50% below in-house associate
      time for equivalent work. First-time attorney clients always get
      an introductory rate on their first matter — try us with low risk.
    </p>

    <h2 id="what-we-do-not-do">What we do not do</h2>
    <p>
      We do not give legal advice. We do not appear in court. We do not
      sign pleadings. We do not negotiate with opposing counsel. We do
      not advise your client directly without your written authorization
      to communicate. All work product is yours, prepared under your
      direction, billed transparently, with confidentiality terms that
      match what you'd expect from in-house staff.
    </p>

    <h2 id="next-step">Let's start a conversation</h2>
    <p>
      The easiest first step: <strong>call or text +1 (916) 399-3992</strong>
      or send a sample matter through the contact form below. We'll respond
      the same business day with a fixed-fee quote, an hourly estimate, or
      a retainer proposal — whichever fits the matter. No commitment to
      start. If we're not the right fit, we'll say so on the first call;
      if we are, we can usually have a signed engagement and first
      deliverable turned around within 48 hours.
    </p>
    <p>
      <strong>We're genuinely excited to partner with attorneys</strong> —
      whether you're a solo immigration practitioner in another state
      looking for reliable USCIS support, or a California firm building
      a long-term paralegal relationship. Reach out and let's see how
      we can help.
    </p>

    <cite>
      <strong>Regulatory note.</strong> Imverica Legal Solutions is a
      California-registered Legal Document Assistant (Cal. Bus. &amp;
      Prof. Code §§6400–6415) and Immigration Consultant (§§22440–22448).
      <strong>For USCIS petitions and EOIR immigration court work,
      Imverica may be engaged by any attorney licensed in any US state</strong> —
      these are federal proceedings and no state-bar licensure boundary
      applies to paralegal support. All paralegal work performed for an
      attorney is by definition done under the attorney's supervision and
      direction, consistent with ABA Model Rule 5.3 and analogous state
      rules — so the LDA restrictions on giving legal advice do not apply
      to directed paralegal support for a licensed attorney. References
      available on request.
    </cite>
  </LandingBody>

  <CTAStrip
    heading="Outsource the paperwork. Keep the practice."
    sub="Federal immigration nationwide · California state court. Pay-by-project, hourly, or retainer — we work on your terms."
    primaryHref="/#get-started?topic=for-attorneys"
    primaryText="Send a sample matter"
  />

  <style is:global>
    /* Keep the hero headline on ONE LINE on desktop and tablet.
       Global .hero is max-width: 1040px and h1 is max-width: 820px,
       which wraps "Affordable paralegal support — under your direction"
       mid-sentence. Scoped to .for-attorneys-hero so it only affects
       this page's hero. We widen the container, clear the h1 max-width,
       and cap the font-size with clamp() so it fits cleanly at any
       common breakpoint. At ≥980px we force nowrap; on narrower screens
       text-wrap: balance distributes the line break gracefully. */
    .for-attorneys-hero .hero-wrap .hero {
      max-width: 1240px;
    }
    .for-attorneys-hero .hero-wrap .hero h1 {
      max-width: none;
      font-size: clamp(26px, 4.4vw, 50px);
      text-wrap: balance;
    }
    @media (min-width: 980px) {
      .for-attorneys-hero .hero-wrap .hero h1 {
        white-space: nowrap;
      }
    }
    /* The sub is a long B2B paragraph; the global 640px cap left it a narrow,
       ragged centered column under the wide one-line headline. Widen to a
       comfortable measure and balance the line lengths so it reads as a tidy
       block (no stray short last line) instead of "sticking out". */
    .for-attorneys-hero .hero-wrap .hero .hero-sub {
      max-width: 720px;
      text-align: left;
      text-wrap: pretty;
    }
  </style>

  <style>
    .fee-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      margin: 28px 0 8px;
    }
    @media (max-width: 760px) {
      .fee-grid { grid-template-columns: 1fr; }
    }
    .fee-card {
      background: #fff;
      border: 1px solid rgba(40,30,20,0.10);
      border-radius: 14px;
      padding: 22px 22px 18px;
      box-shadow: 0 6px 18px rgba(40,30,20,0.04);
    }
    .fee-card-highlight {
      border-color: var(--terracotta-deep);
      box-shadow: 0 10px 26px rgba(164,91,52,0.12);
      position: relative;
    }
    .fee-card-highlight::before {
      content: 'Most popular';
      position: absolute;
      top: -10px;
      right: 16px;
      background: var(--terracotta-deep);
      color: #fff;
      font-size: 10px;
      letter-spacing: 1.4px;
      text-transform: uppercase;
      font-weight: 700;
      padding: 5px 10px;
      border-radius: 999px;
    }
    .fee-card-icon { font-size: 26px; margin-bottom: 8px; }
    .fee-card h3 {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 700;
      color: var(--navy-dark);
      margin: 0 0 6px;
    }
    .fee-card-lead {
      color: var(--terracotta-deep);
      font-weight: 600;
      font-size: 13px;
      margin: 0 0 10px;
    }
    .fee-card p { margin: 0 0 8px; font-size: 14px; line-height: 1.65; color: #3a4a5e; }
    .affordable-note {
      background: #fffaf2;
      border-left: 4px solid var(--terracotta-deep);
      padding: 14px 18px;
      border-radius: 4px;
      font-size: 14px;
      line-height: 1.65;
      margin: 24px 0 8px;
    }
  </style>
</BaseLayout>
