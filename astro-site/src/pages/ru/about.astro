---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import LandingBody from '~/components/LandingBody.astro';
import CategoryTiles from '~/components/CategoryTiles.astro';
import CTAStrip from '~/components/CTAStrip.astro';

const lang = 'ru' as const;
const title = 'О компании Imverica — California LDA и Immigration Consultant | Imverica Legal Solutions';
const description = 'Imverica Legal Solutions — мультиязычный (английский, русский, украинский, испанский) Legal Document Assistant и Immigration Consultant из Сакраменто. Готовим документы USCIS, EOIR и судов Калифорнии по всему США и штату — по доступным, прозрачным тарифам. Мы не юридическая фирма и не даём юридических консультаций.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: 'Imverica Legal Solutions',
  legalName: 'Imverica LLC',
  alternateName: ['Imverica', 'Imverica LLC'],
  url: 'https://imverica.com/ru/about',
  telephone: '+1-916-399-3992',
  email: 'info@imverica.com',
  areaServed: [
    { '@type': 'Country', name: 'United States' },
    { '@type': 'State', name: 'California' }
  ],
  knowsLanguage: ['en', 'ru', 'uk', 'es'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Sacramento',
    addressRegion: 'CA',
    addressCountry: 'US'
  },
  sameAs: [
    'https://www.instagram.com/imverica',
    'https://www.facebook.com/imverica/',
    'https://t.me/imverica'
  ],
  description: 'Imverica Legal Solutions — торговая марка Imverica LLC, компании с ограниченной ответственностью в штате Калифорния. Зарегистрированный California Legal Document Assistant и Immigration Consultant. Мультиязычная (EN/RU/UK/ES) подготовка документов для USCIS, EOIR и судов штата Калифорния по доступным тарифам.'
};
---
<BaseLayout title={title} description={description} canonical="https://imverica.com/ru/about"
  slug="/about" lang={lang} availableLocales={['en', 'ru', 'uk', 'es']} jsonLd={[schema]}>
  <Hero
    lang={lang}
    eyebrow="О Imverica Legal Solutions"
    heading="Доступная подготовка документов на четырёх языках — под вашу ситуацию"
    sub="База в Сакраменто. Калифорнийские суды по всему штату, USCIS — по всем США. Говорим на английском, русском, украинском и испанском. Готовим документы по вашему поручению — мы не юридическая фирма и не даём юридических консультаций."
    ctaPrimary={{ href: '/#get-started', text: 'Начать кейс' }}
    ctaSecondary={{ href: 'tel:+19163993992', text: '📞 +1 (916) 399-3992' }}
  />

  <LandingBody lang={lang} related={[
    { href: '/ru/lda', label: 'Кто такой California Legal Document Assistant?' },
    { href: '/ru/for-attorneys', label: 'Для адвокатов — paralegal-партнёрство' },
    { href: '/ru/immigration', label: 'USCIS и EOIR документы которые мы готовим' },
    { href: '/ru/fl', label: 'Семейное право Калифорнии' }
  ]}>
    <p class="lead">
      Imverica Legal Solutions родилась в <strong>Сакраменто, Калифорния</strong> —
      одном из самых этнически и лингвистически разнообразных городов США.
      Это не декорация — это причина по которой мы существуем. Каждый квартал
      этого города — это чей-то первый адрес в Америке, чей-то маленький
      бизнес, чей-то семейный кейс, чей-то конверт с I-485 который лежит
      нераскрытым потому что сопроводительное письмо на чужом языке. Мы
      строили Imverica как офис в который соседи могут реально зайти —
      доступный, мультиязычный, честный, и построенный вокруг того что нужно
      работающей семье от LDA-профессионала.
    </p>

    <h2 id="story">Кто мы</h2>
    <p>
      <strong>Imverica Legal Solutions</strong> — это потребительский бренд
      компании <strong>Imverica LLC</strong>, общества с ограниченной
      ответственностью штата Калифорния. Мы — команда зарегистрированных
      калифорнийских <strong>Legal Document Assistants</strong>
      (Cal. Bus. & Prof. Code §§6400–6415) и <strong>Immigration Consultants</strong>
      (§§22440–22448) с многолетним paralegal-опытом по петициям USCIS,
      делам в иммиграционных судах EOIR, семейному праву Калифорнии,
      малым искам, выселениям, наследственным делам и регистрации бизнеса.
      Наша работа выполняется <strong>под надзором лицензированных адвокатов</strong> —
      и как независимые paralegal-партнёры калифорнийских юридических фирм,
      и для наших розничных клиентов через панель консультирующих адвокатов
      к которым мы обращаемся когда кейс требует юридического суждения
      выходящего за рамки полномочий LDA. Это партнёрство удерживает нас
      внутри допустимых границ, защищает клиента и держит работу в реальной
      юридической плоскости вместо галочковой записи данных.
    </p>
    <p>
      Мы построены на трёх обещаниях — и скорее потеряем кейс чем нарушим их:
    </p>
    <ul>
      <li><strong>Честность о масштабе.</strong> Если ваш кейс требует адвоката — мы говорим это на первом звонке и направляем вас к нему. Мы не берём денег за "консультацию" чтобы выяснить попали ли вы по адресу — это бесплатно.</li>
      <li><strong>Честность о цене.</strong> Фиксированные тарифы публикуются до того как вы соглашаетесь. Без почасовой накрутки. Без сюрпризов во втором счёте.</li>
      <li><strong>Честность об исходе.</strong> Мы готовим документы по вашему поручению. Мы не говорим вам подходите ли вы по требованиям, не предсказываем скажет ли USCIS или судья "да", и никогда не гарантируем результат. Кто гарантирует — либо адвокат, либо человек которому не стоит доверять.</li>
    </ul>

    <h2 id="why-we-exist">Зачем мы нужны</h2>
    <p>
      Большинству людей которым нужны юридические бумаги — адвокат не нужен.
      Им нужна правильная форма, правильно заполненная, поданная вовремя, на
      их собственном языке. Им нужен кто-то кто возьмёт трубку, выслушает,
      и не возьмёт $400 в час за ввод данных. Это та ниша которую программа
      California Legal Document Assistant создана закрывать — и мы закрываем
      её прозрачно, доступно и на языке которым клиент реально говорит дома.
    </p>
    <p>
      Изменение статуса (adjustment of status), обновление грин-карты,
      натурализация, политическое убежище, развод, малые иски, защита от
      выселения, регистрация бизнеса — большинство этих кейсов требуют
      аккуратной пары рук и кого-то кто объяснит что происходит на вашем
      языке, а не судебного литиганта. Когда кейс реально требует адвоката —
      мы это говорим, и работаем вместе с ним через нашу панель надзорных
      адвокатов. Это и есть граница вокруг которой построена калифорнийская
      LDA-модель, и мы её держим.
    </p>

    <h2 id="languages">Четыре языка, живые люди</h2>
    <p>
      Каждая заявка, каждый документ, каждое follow-up письмо — мы работаем
      нативно на <strong>английском, русском, украинском и испанском</strong>.
      Не Google Translate. Не chatbot со скриптом. Живые люди которые выросли
      на этих языках, которые понимают культурный контекст ваших вопросов,
      которым не придётся объяснять заново термин который вы уже использовали.
      Когда форма на английском — мы проводим вас по каждому полю; когда
      ситуация рассказана по-русски — мы слушаем по-русски.
    </p>

    <h2 id="what-makes-us-different">Чем мы отличаемся</h2>
    <ul>
      <li><strong>Прозрачные цены.</strong> Фиксированные тарифы за документ или кейс, опубликованы до подписания договора. Без платы за "консультацию" чтобы узнать сколько что стоит. Мы говорим цену первыми; вы решаете стоит ли оно того.</li>
      <li><strong>UPL-дисциплина.</strong> Мы готовим документы по вашему поручению — мы не рекомендуем какую форму подавать, не предсказываем результат, не говорим подходите ли вы по требованиям. Это работа адвоката, и мы направляем к адвокату когда кейс реально его требует. Это не маркетинг — это как устроена калифорнийская LDA-программа, и это защищает вас.</li>
      <li><strong>Скорость.</strong> Большинство квот в течение того же рабочего дня. Большинство документов готовы в течение 48 часов с момента заявки. Мы не заставим вас две недели ждать USCIS-форму которую вы могли отправить сегодня.</li>
      <li><strong>Мультиязычная поддержка end-to-end.</strong> Заявка, подготовка документов и после-податочная коммуникация — всё на вашем языке. Адвокатов говорящих по-русски мало; нас — много.</li>
      <li><strong>Remote-first, штат Калифорния — по всему штату, федеральная иммиграция — по всему США.</strong> Не нужно ехать в Сакраменто. Работаем по телефону, email, Telegram и через защищённый личный кабинет — подписываем документы электронно когда это разрешено, шлём оригиналы когда нужно.</li>
      <li><strong>Для клиентов и для адвокатов.</strong> Мы работаем напрямую с self-represented частными лицами И с лицензированными адвокатами в роли их независимого paralegal. <a href="/ru/for-attorneys">См. варианты партнёрства для адвокатов</a>.</li>
    </ul>

    <h2 id="scope">Что мы делаем — и чего не делаем</h2>
    <p>
      <strong>Что мы готовим:</strong>
    </p>
    <ul>
      <li>Любую форму USCIS для любого штата — федеральная иммиграция федеральна, ваш штат проживания не имеет значения (I-485 adjustment, I-130 family petition, I-765 work permit, I-589 asylum, N-400 naturalization, I-90 green card renewal, I-131 travel document, I-864 affidavit of support, ответы на RFE, полные пакеты доказательств).</li>
      <li>Дела в иммиграционных судах EOIR по всему США (EOIR-29, 42A, 42B, motions, страновые пакеты, declarations свидетелей).</li>
      <li>Семейное право Калифорнии (FL-100/110/120 развод, FL-150/160 финансовые декларации, FL-300 RFO, опека, алименты, judgment-пакеты).</li>
      <li>Малые иски и гражданские дела Калифорнии (SC-100 — SC-140, demand letters, удержание из заработной платы, abstract of judgment).</li>
      <li>Выселение в Калифорнии (UD-100/105/110, three-day notices, default-пакеты).</li>
      <li>Наследственные дела Калифорнии (DE-111/121/160/221/295, small estate affidavits, inventory, final distribution, final discharge).</li>
      <li>California record-cleanup / petition-for-dismissal packets (CR-180/181), включая DUI и другие eligible cases по поручению клиента.</li>
      <li>Регистрация бизнеса в Калифорнии (LLC-1, LLC-12, ARTS-GS, FBN, EIN).</li>
      <li>Сертифицированный перевод документов (русский, украинский, испанский ↔ английский) и координация апостилирования.</li>
    </ul>
    <p>
      <strong>Чего мы не делаем — по дизайну и по закону:</strong> мы не
      даём юридических консультаций, не представляем вас в суде, не
      подписываем процессуальные документы, не ведём переговоры с
      противоположной стороной, и не рекомендуем какую форму вам подавать.
      Если ваша ситуация реально требует адвоката (судебный процесс,
      стратегия, выступления в суде) — мы скажем это на первом звонке и
      поможем найти его. Мы скорее потеряем кейс и сохраним ваше доверие
      чем продадим больше чем LDA имеет право.
    </p>

    <h2 id="compliance">Регистрация и защита потребителей</h2>
    <p>
      Imverica Legal Solutions зарегистрирована в рамках калифорнийского
      статута Legal Document Assistant (Cal. Bus. & Prof. Code §§6400–6415)
      и статута Immigration Consultant (§§22440–22448). Калифорния требует
      от LDA регистрации в офисе клерка округа, оформления страховой
      гарантии $25,000, прохождения обучения и ежегодного продления — это
      защиты которые штат встроил чтобы потребители знали кто готовит их
      документы. Текущие регистрационные номера и информация о страховой
      гарантии указаны в каждом intake-договоре; рекомендательные письма
      и подтверждения предоставляются по запросу.
    </p>
    <p>
      Для федеральной иммиграционной работы (петиции USCIS, дела EOIR)
      применяется калифорнийский Immigration Consultant Act и федеральная
      регуляция 8 CFR §1.2 / §292.1 — paralegal-подготовка документов под
      руководством клиента разрешена на всей территории США при условии
      что мы никогда не даём юридических консультаций, никогда не
      выступаем перед USCIS или EOIR как ваш представитель, и на каждом
      шаге раскрываем что мы не адвокаты и не аккредитованные представители.
    </p>

    <h2 id="contact">Как с нами связаться</h2>
    <p>
      Самый простой первый контакт — телефон или контактная форма на этом
      сайте. Отвечаем в тот же рабочий день, на вашем языке.
    </p>
    <ul class="contact-list">
      <li><strong>Телефон и SMS:</strong> <a href="tel:+19163993992">+1 (916) 399-3992</a></li>
      <li><strong>Email:</strong> <a href="mailto:info@imverica.com">info@imverica.com</a></li>
      <li><strong>Telegram:</strong> <a href="https://t.me/imverica" target="_blank" rel="noopener">t.me/imverica</a></li>
      <li><strong>Web-заявка:</strong> <a href="/ru/#get-started">Начать кейс здесь</a> — пятиминутная форма, можно прикрепить до пяти документов.</li>
      <li><strong>Личный кабинет:</strong> <a href="/account.html">imverica.com/account</a> — войдите чтобы отслеживать открытые кейсы, обмениваться документами и переписываться с командой.</li>
    </ul>
    <p>
      База в Сакраменто, Калифорния. Обслуживаем Калифорнию по делам
      штата и все США по федеральной иммиграции.
    </p>

    <cite>
      <strong>Важное уведомление.</strong> Imverica Legal Solutions — это
      торговая марка <strong>Imverica LLC</strong>, общества с ограниченной
      ответственностью штата Калифорния. Зарегистрированный California
      Legal Document Assistant и Immigration Consultant — не юридическая
      фирма. Мы не даём юридических консультаций, не устанавливаем
      отношений «адвокат-клиент» и не представляем клиентов в суде или
      перед USCIS / EOIR как аккредитованные представители. Вся работа
      выполняется по поручению self-represented стороны в соответствии
      с Cal. Bus. & Prof. Code §§6400–6415 и §§22440–22448.
    </cite>
  </LandingBody>

  <CategoryTiles
    kicker="Куда дальше"
    heading="Выберите направление"
    intro="Если уже знаете что вам нужно — переходите прямо туда:"
    tiles={[
      { icon: '🛂', title: 'USCIS и EOIR',         desc: 'I-485, I-130, I-765, asylum, removal-defense — любой штат США.', href: '/ru/immigration', color: 'var(--navy)' },
      { icon: '👨‍👩‍👧', title: 'Семейное право CA',    desc: 'Развод, опека, алименты, post-judgment modifications.', href: '/ru/fl', color: 'var(--terracotta)' },
      { icon: '📃', title: 'Малые иски и civil',   desc: 'SC-100, demand letters, взыскание долга по решению.', href: '/ru/sc', color: 'var(--sage)' },
      { icon: '🏠', title: 'Выселение',            desc: 'UD-100, three-day notices, default-пакеты.', href: '/ru/california-unlawful-detainer', color: 'var(--gold)' },
      { icon: '🏛️', title: 'Наследственные дела',  desc: 'Серия DE-111, small estate affidavits, final distribution, DE-295 discharge.', href: '/ru/california-probate', color: 'var(--navy-light)' },
      { icon: '🧾', title: 'Record cleanup',       desc: 'CR-180/181 expungement / petition-for-dismissal packets, включая DUI.', href: '/ru/california-expungement', color: 'var(--gold)' },
      { icon: '🏢', title: 'Регистрация бизнеса',  desc: 'LLC-1, ARTS-GS, FBN/DBA, EIN, foreign-LLC.', href: '/ru/business', color: 'var(--terracotta-deep)' },
      { icon: '🤝', title: 'Для адвокатов',        desc: 'Независимый paralegal — USCIS по всему США, суды CA.', href: '/ru/for-attorneys', color: 'var(--terracotta)' },
      { icon: '📚', title: 'Что такое LDA?',       desc: 'Cal. Bus. & Prof. Code §§6400–6415 простыми словами.', href: '/ru/lda', color: 'var(--navy)' }
    ]}
  />

  <CTAStrip
    heading="Готовы — когда вы готовы."
    sub="Ответ в тот же день. Документы за 48 часов. Четыре языка. Доступные, прозрачные тарифы."
    primaryHref="/ru/#get-started"
    primaryText="Начать кейс"
  />

  <style>
    .contact-list {
      list-style: none;
      padding-left: 0;
      margin: 18px 0;
    }
    .contact-list li {
      padding: 10px 14px;
      margin-bottom: 8px;
      background: rgba(26,46,74,0.04);
      border-left: 3px solid var(--navy);
      border-radius: 0 6px 6px 0;
      font-size: 15px;
      line-height: 1.6;
    }
    .contact-list a {
      color: var(--navy);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }
    .contact-list a:hover {
      color: var(--terracotta-deep);
    }
  </style>
</BaseLayout>
