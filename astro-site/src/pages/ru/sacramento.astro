---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import CTAStrip from '~/components/CTAStrip.astro';

const lang = 'ru' as const;
const title = 'Иммиграционные и судебные документы в Сакраменто — на русском | Imverica';
const description =
  'Подготовка документов USCIS, иммиграционного суда EOIR и судов Калифорнии в Сакраменто — на русском языке. Registered LDA и Immigration Consultant. Фиксированные цены, без юридических консультаций.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: 'Imverica Legal Solutions',
  url: 'https://imverica.com/ru/sacramento',
  telephone: '+1-916-399-3992',
  areaServed: [
    { '@type': 'City', name: 'Sacramento' },
    { '@type': 'City', name: 'Rancho Cordova' },
    { '@type': 'City', name: 'Citrus Heights' },
    { '@type': 'City', name: 'Elk Grove' },
    { '@type': 'City', name: 'Roseville' }
  ],
  availableLanguage: ['Russian', 'Ukrainian', 'English', 'Spanish'],
  description:
    'Подготовка иммиграционных и судебных документов в Сакраменто на русском языке: USCIS, EOIR, суды Калифорнии. Registered Legal Document Assistant и Immigration Consultant.'
};
---
<BaseLayout title={title} description={description} canonical="https://imverica.com/ru/sacramento"
  slug="/ru/sacramento" lang={lang} jsonLd={[schema]}>
  <Hero
    lang={lang}
    eyebrow="Сакраменто · На русском · Registered LDA · Immigration Consultant"
    heading="Иммиграционные и судебные документы в Сакраменто — на вашем языке"
    sub="USCIS, иммиграционный суд EOIR и суды Калифорнии: готовим документы по вашему поручению, объясняем каждый шаг по-русски, называем фиксированную цену до начала работы. Мы не юридическая фирма и не даём юридических консультаций — какую форму подавать, решаете вы."
    ctaPrimary={{ href: '/#get-started', text: 'Начать заявку' }}
  />

  <section class="svc-section">
    <div class="svc-inner">
      <div class="svc-kicker">Почему Сакраменто</div>
      <h2>Мы работаем там же, где живут наши клиенты</h2>
      <p>
        В Сакраменто и пригородах — Rancho Cordova, Citrus Heights, Antelope,
        North Highlands, Elk Grove — живёт одна из крупнейших русскоязычных
        общин Калифорнии. Сюда приезжают по гуманитарному паролю U4U, по
        рабочим и семейным визам, сюда переезжают после многих лет в других
        штатах. И у каждой семьи рано или поздно появляется папка документов:
        продлить разрешение на работу, перерегистрировать TPS, подать на
        грин-карту, ответить на развод, открыть LLC.
      </p>
      <p>
        Imverica Legal Solutions — зарегистрированный в Калифорнии Legal
        Document Assistant (Cal. Bus. &amp; Prof. Code §§6400–6415) и
        Immigration Consultant (§§22440–22448) в Сакраменто. Это значит: мы
        официально готовим документы по вашему поручению, имеем bond, работаем
        по письменному договору с фиксированной ценой — и честно говорим,
        когда вашему делу нужен адвокат, а не подготовщик документов.
      </p>

      <div class="svc-kicker" style="margin-top:34px;">Что готовим чаще всего</div>
      <h2>Документы, с которыми приходят русскоязычные клиенты</h2>
      <p>
        <strong>Иммиграция (USCIS):</strong> разрешение на работу I-765 —
        включая категорию (c)(11) для паролистов U4U; перерегистрация TPS
        (I-821); грин-карта по браку и через убежище (I-485 с сопутствующими
        I-130, I-864); продление и замена грин-карты (I-90); проездные
        документы (I-131); натурализация (N-400); пакет по убежищу I-589 с
        декларацией. <strong>Иммиграционный суд (EOIR):</strong> motions,
        evidence packets, апелляции EOIR-29. <strong>Суды Калифорнии:</strong>
        развод (FL-100) и ответ на развод (FL-120), алименты и опека (FL-300),
        малые иски до $12,500 (SC-100), выселение и ответ арендатора, смена
        имени (NC-100), охранные ордера. <strong>Бизнес:</strong> LLC-1,
        Statement of Information, EIN, фиктивное имя (DBA).
      </p>
      <p>
        Каждый документ вы проверяете и одобряете в личном кабинете до
        финальной версии — на сайте работает портал со статусами дела,
        загрузкой документов и перепиской.
      </p>

      <div class="svc-kicker" style="margin-top:34px;">Как это устроено</div>
      <h2>Фиксированная цена и понятный процесс</h2>
      <p>
        Вы описываете ситуацию — по-русски, по телефону, в Telegram или прямо
        на сайте. Мы показываем, какие формы обычно используются в таких
        случаях (общая информация, не юридическая консультация), называете
        форму — мы называем фиксированную цену до начала работы.
        Государственные пошлины всегда отдельно и платятся напрямую в USCIS
        или суд. Простые формы готовы за 24–48 часов.
      </p>
      <p>
        Приём — по записи, работаем со всем округом Сакраменто и дистанционно
        по всей Калифорнии и США (федеральные иммиграционные формы — для
        клиентов в любом штате). Звоните или пишите:
        <a href="tel:+19163993992">+1 (916) 399-3992</a> — говорим по-русски,
        по-украински, по-английски и по-испански.
      </p>
    </div>
  </section>

  <CTAStrip
    lang={lang}
    heading="Расскажите, какой документ вам нужен"
    sub="Ответим в течение одного рабочего дня. Только подготовка документов — не юридическая консультация."
  />
</BaseLayout>
