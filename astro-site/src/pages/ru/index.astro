---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import HomeSearch from '~/components/HomeSearch.astro';
import StatsStrip from '~/components/StatsStrip.astro';
import { HERO } from '~/data/i18n';

const lang = 'ru' as const;
const title = 'Imverica Legal Solutions | USCIS · EOIR · Калифорнийские формы';
const description =
  'Калифорнийский лицензированный LDA и иммиграционный консультант. Подготовка документов USCIS, EOIR, семейного права, малых исков и наследственных дел. Удалённый сервис по всему миру.';


const legalServiceSchema = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: 'Imverica Legal Solutions',
  url: 'https://imverica.com',
  telephone: '+1-916-399-3992',
  areaServed: [
    { '@type': 'State', name: 'California' },
    { '@type': 'Country', name: 'United States' }
  ],
  address: { '@type': 'PostalAddress', addressRegion: 'CA', addressCountry: 'US' },
  description: 'Калифорнийский лицензированный помощник по юридическим документам и иммиграционный консультант. Подготовка документов USCIS, EOIR, семейного права, малых исков, выселения и наследственных дел.',
  knowsLanguage: ['en', 'ru', 'uk', 'es'],
  serviceType: [
    'Подготовка иммиграционных форм USCIS',
    'Подготовка документов EOIR',
    'Подготовка калифорнийских форм семейного права',
    'Подготовка документов малых исков',
    'Подготовка документов unlawful detainer',
    'Подготовка документов по наследственным делам'
  ],
  disambiguatingDescription: 'Imverica Legal Solutions не является юридической фирмой и не предоставляет юридических консультаций. Документы готовятся по поручению клиента.'
};
---
<BaseLayout
  title={title}
  description={description}
  canonical="https://imverica.com/ru/"
  jsonLd={[legalServiceSchema]}
  lang={lang}
  slug="/"
  availableLocales={['en', 'ru', 'uk', 'es']}
>
  <Hero
    lang={lang}
    eyebrow={HERO.ru.eyebrow}
    heading={HERO.ru.heading}
    sub={HERO.ru.sub}
    showActions={false}
  >
    <HomeSearch lang={lang} />
  </Hero>
  <StatsStrip lang={lang} />

  <section class="svc-section">
    <div class="svc-inner" style="text-align:center;">
      <div class="svc-kicker">Что мы делаем</div>
      <h2>USCIS, EOIR и калифорнийские формы — готовим под ключ</h2>
      <p style="margin:0 auto 1.4rem;max-width:780px;">
        Помощь с подготовкой документов на русском, английском, украинском и испанском.
        Не юридическая фирма, юридические консультации не даём — готовим формы аккуратно
        и по поручению клиента.
      </p>
      <div class="ru-form-grid">
        <a class="btn" href="/ru/i-485-help">I-485 — грин-карта (AOS)</a>
        <a class="btn btn-ghost" href="/ru/i-589-asylum-help">I-589 — убежище</a>
        <a class="btn btn-ghost" href="/ru/n-400-citizenship-help">N-400 — гражданство</a>
        <a class="btn btn-ghost" href="/immigration#immigration-consultant-california">I-130 — семейная петиция</a>
        <a class="btn btn-ghost" href="/immigration#immigration-consultant-california">I-765 — разрешение на работу</a>
        <a class="btn btn-ghost" href="/immigration#immigration-consultant-california">I-131 — travel document</a>
        <a class="btn btn-ghost" href="/immigration#eoir-documents">EOIR-28 / 42A / 42B</a>
        <a class="btn btn-ghost" href="/ru/california-unlawful-detainer">Выселение (UD-100)</a>
      </div>
      <p style="margin:1.4rem auto 0;font-size:13px;color:var(--muted);">
        Полный список USCIS, EOIR и калифорнийских форм — на странице
        <a href="/immigration">USCIS | EOIR</a>.
      </p>
    </div>
  </section>

  <style>
    .ru-form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 12px;
      max-width: 880px;
      margin: 0 auto;
    }
  </style>
</BaseLayout>
