---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ImmigrationCategories from '~/components/ImmigrationCategories.astro';
import ServiceSections from '~/components/ServiceSections.astro';

const title = 'USCIS & EOIR Immigration Document Preparation | Imverica Legal Solutions';
const description =
  'California Licensed LDA & Immigration Consultant. Document preparation for USCIS petitions (I-485, I-130, I-765, I-589, N-400, I-131, I-90) and EOIR immigration court filings — at the client\'s direction.';
---
<BaseLayout
  title={title}
  description={description}
  canonical="https://imverica.com/immigration"
  slug="/immigration"
>
  <ImmigrationCategories />
  <ServiceSections
    include={['immigration-consultant-california', 'eoir-documents', 'document-translation-california']}
    kicker="USCIS · EOIR · Immigration document preparation"
    heading="USCIS petitions and EOIR immigration-court documents"
    intro="Imverica Legal Solutions is a California-registered Immigration Consultant and Legal Document Assistant. We prepare USCIS petitions and EOIR (immigration court) document packages at the client's direction — accurately, organized, and on time. We are not a law firm and do not provide legal advice."
  />
</BaseLayout>
