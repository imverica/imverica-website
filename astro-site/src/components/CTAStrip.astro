---
import { CTA, type Locale } from '~/data/i18n';

interface Props {
  heading?: string;
  sub?: string;
  primaryHref?: string;
  primaryText?: string;
  secondaryHref?: string;
  secondaryText?: string;
  lang?: Locale;
}
const { lang = 'en' } = Astro.props;
const defaults = CTA[lang];
const {
  heading = defaults.heading,
  sub = defaults.sub,
  primaryHref = '/#get-started',
  primaryText = defaults.startBtn,
  secondaryHref = 'tel:+19163993992',
  secondaryText = '📞 +1 (916) 399-3992'
} = Astro.props;
---
<section style="background:linear-gradient(135deg,#fdf6ec 0%,#fff5e9 100%);padding:64px 1.5rem;border-top:1px solid rgba(40,30,20,0.08);">
  <div style="max-width:760px;margin:0 auto;text-align:center;">
    <h2 style="font-size:30px;margin:0 0 12px;">{heading}</h2>
    <p style="font-size:15px;color:#6b5a44;line-height:1.6;margin:0 auto 28px;max-width:560px;">{sub}</p>
    <div style="display:flex;justify-content:center;gap:12px;flex-wrap:wrap;">
      <a class="btn btn-accent" href={primaryHref}>{primaryText}</a>
      <a class="btn btn-ghost" href={secondaryHref}>{secondaryText}</a>
    </div>
  </div>
</section>
