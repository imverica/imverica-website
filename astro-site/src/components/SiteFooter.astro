---
import { FOOTER, localizedPathSafe, type Locale } from '~/data/i18n';

interface Props {
  lang?: Locale;
}
const { lang = 'en' } = Astro.props;
const f = FOOTER[lang];
const year = new Date().getFullYear();
const disclaimer = f.disclaimer.replace('{year}', String(year));
---
<footer class="site-footer">
  <div class="site-footer-inner">
    <div>
      <div class="site-brand-name" style="color:#fff;font-size:24px;">Imverica</div>
      <div class="site-footer-info" style="margin-top:0.5rem;">
        {f.brandLine}<br />
        +1 (916) 399-3992 · imverica.com
      </div>
    </div>
    <div>
      <strong>{f.servicesUscis}</strong>
      <div class="site-footer-info">
        <a href="/uscis-eoir">USCIS &amp; immigration court</a><br />
        <a href={localizedPathSafe(lang, '/n-400-citizenship-help')}>Naturalization</a><br />
        <a href={localizedPathSafe(lang, '/i-130-family-petition')}>Family petition</a><br />
        <a href={localizedPathSafe(lang, '/i-589-asylum-help')}>Asylum</a>
      </div>
    </div>
    <div>
      <strong>{f.servicesCivil}</strong>
      <div class="site-footer-info">
        <a href={localizedPathSafe(lang, '/california-family-law')}>Family law</a><br />
        <a href={localizedPathSafe(lang, '/california-small-claims')}>Small claims</a><br />
        <a href={localizedPathSafe(lang, '/california-unlawful-detainer')}>Unlawful detainer</a><br />
        <a href="/business">Business filings</a>
      </div>
    </div>
    <div>
      <strong>{f.about}</strong>
      <div class="site-footer-info">
        <a href={localizedPathSafe(lang, '/california-legal-document-assistant')}>What is an LDA?</a><br />
        <a href="/account.html">Client Portal</a>
      </div>
    </div>
  </div>
  <div class="site-footer-bottom">{disclaimer}</div>
</footer>
