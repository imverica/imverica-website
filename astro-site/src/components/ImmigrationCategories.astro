---
import { priceForTitle } from '~/data/prices';
/**
 * Quick-pick immigration categories — large icon tiles above the
 * detailed ServiceSections cards on /immigration.
 *
 * Each tile links to the most relevant landing page (form-specific
 * help page when one exists; in-page anchor on the ServiceSections
 * grid otherwise). Flags hint at the largest client communities.
 */
type Lang = 'en' | 'ru' | 'uk' | 'es';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props as Props;
const localePrefix: Record<Lang, string> = { en: '', ru: '/ru', uk: '/ua', es: '/mx' };
const lp = localePrefix[lang];

const STRINGS = {
  en: {
    kicker: 'Pick a category to get started',
    h2: 'USCIS & EOIR',
    intro: 'Most common immigration matters we handle. Tap any tile for the form-specific landing page with details, requirements, and a starter intake.',
    footPre: "Can't find your form? See the",
    footLink: 'full list of USCIS & EOIR documents we prepare',
    footMid: ', or',
    footTellLink: "tell us what you need",
    footPost: " and we'll point you to the matching forms (general information, not legal advice).",
  },
  ru: {
    kicker: 'Выберите категорию, чтобы начать',
    h2: 'USCIS и EOIR',
    intro: 'Самые частые иммиграционные вопросы, с которыми мы работаем. Нажмите любую плитку, чтобы перейти на страницу с описанием формы, требованиями и началом анкеты.',
    footPre: 'Не нашли свою форму? Посмотрите',
    footLink: 'полный список документов USCIS и EOIR, которые мы готовим',
    footMid: ', или',
    footTellLink: 'опишите, что вам нужно',
    footPost: ' — мы покажем подходящие формы (общая информация, не юридическая консультация).',
  },
  uk: {
    kicker: 'Оберіть категорію, щоб почати',
    h2: 'USCIS та EOIR',
    intro: 'Найчастіші імміграційні справи, з якими ми працюємо. Натисніть будь-яку плитку, щоб перейти на сторінку форми з деталями, вимогами та анкетою.',
    footPre: 'Не знайшли свою форму? Перегляньте',
    footLink: 'повний список документів USCIS та EOIR, які ми готуємо',
    footMid: ', або',
    footTellLink: 'опишіть, що вам потрібно',
    footPost: ' — ми покажемо відповідні форми (загальна інформація, не юридична консультація).',
  },
  es: {
    kicker: 'Elija una categoría para comenzar',
    h2: 'USCIS y EOIR',
    intro: 'Los asuntos de inmigración más comunes que manejamos. Toque cualquier tile para ver la página de la forma con detalles, requisitos y una entrevista inicial.',
    footPre: '¿No encuentra su formulario? Vea la',
    footLink: 'lista completa de documentos USCIS y EOIR que preparamos',
    footMid: ', o',
    footTellLink: 'cuéntenos lo que necesita',
    footPost: ' y le mostraremos los formularios relacionados (información general, no asesoría legal).',
  },
} as const;
const T = STRINGS[lang];

// Right-hand mono meta block in the hero.
const META: Record<Lang, { num: string; flows: string; fee: string; intake: string }> = {
  en: { num: '12', flows: 'priority flows', fee: 'Flat-fee · disclosed upfront', intake: 'EN · RU · UA · ES intake' },
  ru: { num: '12', flows: 'приоритетных форм', fee: 'Фикс. цена · заранее', intake: 'Приём на EN · RU · UA · ES' },
  uk: { num: '12', flows: 'пріоритетних форм', fee: 'Фікс. ціна · наперед', intake: 'Прийом на EN · RU · UA · ES' },
  es: { num: '12', flows: 'formas prioritarias', fee: 'Tarifa fija · informada', intake: 'Atención EN · RU · UA · ES' }
};
const M = META[lang];

const TITLES = {
  en: {
    u4u: { title: 'U4U — Uniting for Ukraine', desc: 'Humanitarian parole, I-765 work permit (c)(11) and TPS re-registration support for Ukrainian parolees.' },
    tps: { title: 'TPS — Temporary Protected Status', desc: 'Initial registration and re-registration for designated countries (UA, VE, HT, SY, NI and others).' },
    i485: { title: 'I-485 — Adjustment of Status', desc: 'Family-based and asylum-based green-card packages prepared at your direction.' },
    i589: { title: 'I-589 — Asylum & Withholding', desc: 'Affirmative asylum + withholding of removal applications and supporting packets.' },
    n400: { title: 'N-400 — Naturalization', desc: 'Citizenship application with civics + history support; multilingual intake.' },
    i130: { title: 'I-130 — Family Petition', desc: 'Spouse, parent, child, and sibling petitions (with I-130A for spouses).' },
    i765: { title: 'I-765 — Work Permit (EAD)', desc: 'All eligibility categories: (c)(8), (c)(9), TPS, DACA, parolee, and more.' },
    eoir: { title: 'EOIR — Immigration Court', desc: 'EOIR-28 / 42A / 42B, motions, evidence packets, declarations, country conditions.' },
    uvisa: { title: 'U visa — Crime victims', desc: 'I-918 + I-918A self-petition for survivors of qualifying crimes who help law enforcement.' },
    i539: { title: 'I-539 — Change / Extend Status', desc: 'Change to or extend a non-immigrant status (B, F, H4, L2, others) while in the US.' },
    i90: { title: 'I-90 — Green Card Renewal', desc: 'Renew, replace, or correct your Permanent Resident Card (10-year renewal, lost/stolen).' },
    vawa: { title: 'VAWA — I-360 self-petition', desc: 'Self-petition for spouses, children, and parents of abusive US citizens or LPRs.' },
  },
  ru: {
    u4u: { title: 'U4U — Uniting for Ukraine', desc: 'Гуманитарный parole, I-765 (c)(11) разрешение на работу и поддержка повторной регистрации TPS для украинских parolees.' },
    tps: { title: 'TPS — Временный защищённый статус', desc: 'Первичная и повторная регистрация для назначенных стран (UA, VE, HT, SY, NI и других).' },
    i485: { title: 'I-485 — Изменение статуса', desc: 'Семейные и убежищные пакеты на green card, готовим по вашему поручению.' },
    i589: { title: 'I-589 — Убежище и Withholding', desc: 'Affirmative asylum и withholding of removal — заявления и сопроводительные пакеты.' },
    n400: { title: 'N-400 — Натурализация', desc: 'Заявление на гражданство с поддержкой по civics и истории; многоязычная анкета.' },
    i130: { title: 'I-130 — Семейная петиция', desc: 'Петиции за супруга, родителя, ребёнка и брата/сестру (с I-130A для супругов).' },
    i765: { title: 'I-765 — Разрешение на работу (EAD)', desc: 'Все категории eligibility: (c)(8), (c)(9), TPS, DACA, parolee и др.' },
    eoir: { title: 'EOIR — Иммиграционный суд', desc: 'EOIR-28 / 42A / 42B, ходатайства, evidence packets, декларации, country conditions.' },
    uvisa: { title: 'U visa — жертвы преступлений', desc: 'I-918 + I-918A self-petition для пострадавших от квалифицирующих преступлений, помогающих правоохранителям.' },
    i539: { title: 'I-539 — смена/продление статуса', desc: 'Смена или продление неиммиграционного статуса (B, F, H4, L2 и др.) в США.' },
    i90: { title: 'I-90 — обновление green card', desc: 'Обновить, заменить или исправить вашу Permanent Resident Card (10-летнее обновление, утеря/кража).' },
    vawa: { title: 'VAWA — I-360 self-petition', desc: 'Self-petition для супругов, детей и родителей граждан США или LPR, совершавших насилие.' },
  },
  uk: {
    u4u: { title: 'U4U — Uniting for Ukraine', desc: 'Гуманітарний parole + I-765 (c)(11) дозвіл на роботу та підтримка повторної реєстрації TPS для українських parolees.' },
    tps: { title: 'TPS — Тимчасовий захищений статус', desc: 'Первинна та повторна реєстрація для призначених країн (UA, VE, HT, SY, NI та інших).' },
    i485: { title: 'I-485 — Зміна статусу', desc: 'Сімейні та притульні пакети на green card, готуємо за вашим дорученням.' },
    i589: { title: 'I-589 — Притулок і Withholding', desc: 'Affirmative asylum і withholding of removal — заяви та супровідні пакети.' },
    n400: { title: 'N-400 — Натуралізація', desc: 'Заява на громадянство з підтримкою з civics та історії; багатомовна анкета.' },
    i130: { title: 'I-130 — Сімейна петиція', desc: 'Петиції за дружину/чоловіка, батьків, дитину та брата/сестру (з I-130A для подружжя).' },
    i765: { title: 'I-765 — Дозвіл на роботу (EAD)', desc: 'Усі категорії eligibility: (c)(8), (c)(9), TPS, DACA, parolee та ін.' },
    eoir: { title: 'EOIR — Імміграційний суд', desc: 'EOIR-28 / 42A / 42B, клопотання, evidence packets, декларації, country conditions.' },
    uvisa: { title: 'U visa — Жертви злочинів', desc: 'I-918 + I-918A self-petition для постраждалих від кваліфікуючих злочинів, які допомагають правоохоронцям.' },
    i539: { title: 'I-539 — Зміна/продовження статусу', desc: 'Змінити або продовжити неімміграційний статус (B, F, H4, L2 та ін.) у США.' },
    i90: { title: 'I-90 — Поновлення green card', desc: 'Поновити, замінити або виправити вашу Permanent Resident Card (10-річне поновлення, втрата/крадіжка).' },
    vawa: { title: 'VAWA — I-360 self-petition', desc: 'Self-petition для подружжя, дітей та батьків кривдників-громадян США чи LPR.' },
  },
  es: {
    u4u: { title: 'U4U — Uniting for Ukraine', desc: 'Parole humanitario + I-765 (c)(11) permiso de trabajo y apoyo de re-registro TPS para parolees ucranianos.' },
    tps: { title: 'TPS — Estatus de Protección Temporal', desc: 'Registro inicial y re-registro para países designados (UA, VE, HT, SY, NI y otros).' },
    i485: { title: 'I-485 — Ajuste de Estatus', desc: 'Paquetes de green card por familia y por asilo preparados bajo su dirección.' },
    i589: { title: 'I-589 — Asilo y Withholding', desc: 'Affirmative asylum y withholding of removal — solicitudes y paquetes de respaldo.' },
    n400: { title: 'N-400 — Naturalización', desc: 'Solicitud de ciudadanía con apoyo de civics e historia; entrevista multilingüe.' },
    i130: { title: 'I-130 — Petición Familiar', desc: 'Peticiones por cónyuge, padre, hijo y hermano (con I-130A para cónyuges).' },
    i765: { title: 'I-765 — Permiso de Trabajo (EAD)', desc: 'Todas las categorías de eligibility: (c)(8), (c)(9), TPS, DACA, parolee y más.' },
    eoir: { title: 'EOIR — Corte de Inmigración', desc: 'EOIR-28 / 42A / 42B, mociones, evidence packets, declaraciones, country conditions.' },
    uvisa: { title: 'U visa — Víctimas de delito', desc: 'I-918 + I-918A self-petition para sobrevivientes de delitos calificados que ayuden a las autoridades.' },
    i539: { title: 'I-539 — Cambio/Extensión de Estatus', desc: 'Cambiar o extender un estatus no-inmigrante (B, F, H4, L2, otros) en EE. UU.' },
    i90: { title: 'I-90 — Renovación de Green Card', desc: 'Renovar, reemplazar o corregir su Permanent Resident Card (renovación de 10 años, perdida/robada).' },
    vawa: { title: 'VAWA — I-360 self-petition', desc: 'Self-petition para cónyuges, hijos y padres de ciudadanos o LPR abusivos de EE. UU.' },
  },
} as const;
const N = TITLES[lang];

const SOURCE_NOTE: Record<Lang, string> = {
  en: 'Form names, numbers, and requirements shown here are general information from official government sources (USCIS, EOIR, California Courts, CA Secretary of State, IRS), provided for informational purposes only — not legal advice. You choose the forms; Imverica prepares them at your direction.',
  ru: 'Названия, номера и требования форм здесь — общая информация из официальных источников (USCIS, EOIR, суды Калифорнии, Secretary of State Калифорнии, IRS), только для ознакомления, не юридическая консультация. Формы выбираете вы; Imverica готовит их по вашему поручению.',
  uk: 'Назви, номери та вимоги форм тут — загальна інформація з офіційних джерел (USCIS, EOIR, суди Каліфорнії, Secretary of State Каліфорнії, IRS), лише для ознайомлення, не юридична консультація. Форми обираєте ви; Imverica готує їх за вашим дорученням.',
  es: 'Los nombres, números y requisitos de los formularios aquí son información general de fuentes oficiales (USCIS, EOIR, Cortes de California, Secretario de Estado de California, IRS), solo con fines informativos — no asesoría legal. Usted elige los formularios; Imverica los prepara bajo su dirección.'
};

const cats = [
  // Row 1 — humanitarian + most-asked. U4U and TPS each have their own
  // explainer landing page that lists every form involved (parole, TPS,
  // EAD, advance parole, fee waiver). Going to a dedicated page beats
  // dropping the user into a single-form wizard.
  { ...N.u4u,  href: `${lp}/u4u`, flag: '🇺🇦', color: 'var(--terracotta-deep)' },
  { ...N.tps,  href: `${lp}/tps`, flag: '🛡️', color: 'var(--navy)' },
  { ...N.i485, href: `${lp}/i-485-help`,             flag: '🟢', color: 'var(--sage)' },
  { ...N.i589, href: `${lp}/i-589-asylum-help`,      flag: '🏛️', color: 'var(--navy-light)' },
  // Row 2 — common USCIS forms
  { ...N.n400, href: `${lp}/n-400-citizenship-help`, flag: '📜', color: 'var(--gold)' },
  { ...N.i130, href: `${lp}/i-130-family-petition`,  flag: '👨‍👩‍👧', color: 'var(--terracotta)' },
  { ...N.i765, href: `${lp}/i-765-work-permit-help`, flag: '💼', color: 'var(--navy)' },
  { ...N.eoir, href: `${lp}/eoir-immigration-court`, flag: '⚖️', color: 'var(--navy-dark)' },
  // Row 3 — humanitarian / specialty forms. Each now has its own dedicated
  // explainer page (like /u4u and /tps), so a tap opens a real page with
  // that category's forms, requirements, and a starter intake — never a
  // same-page anchor scroll.
  { ...N.uvisa, href: `${lp}/u-visa-help`,            flag: '🆘', color: 'var(--terracotta-deep)' },
  { ...N.i539,  href: `${lp}/i-539-change-of-status`, flag: '🔄', color: 'var(--navy)' },
  { ...N.i90,   href: `${lp}/i-90-green-card-renewal`, flag: '♻️', color: 'var(--sage)' },
  { ...N.vawa,  href: `${lp}/vawa-self-petition`,     flag: '🛡️', color: 'var(--terracotta)' }
];
---
<section class="imm-hero">
  <div class="imm-hero-inner">
    <div class="imm-hero-grid">
      <div class="imm-hero-copy">
        <div class="imm-hero-eyebrow">{T.kicker}</div>
        <h1 set:html={T.h2.replace('EOIR', '<em class="imm-hero-em">EOIR</em>')} />
        <p>{T.intro}</p>
      </div>
      <div class="imm-hero-meta">
        <div class="imm-hero-meta-row"><span class="imm-hero-meta-num">{M.num}</span> {M.flows}</div>
        <div class="imm-hero-meta-row">{M.fee}</div>
        <div class="imm-hero-meta-row">{M.intake}</div>
      </div>
    </div>

    <div class="imm-cats-grid">
      {cats.map((c) => {
        const [code, ...rest] = c.title.split(' — ');
        const name = rest.join(' — ') || c.title;
        const price = priceForTitle(c.title);
        return (
          <a class="imm-cat" href={c.href}>
            <div class="imm-cat-top">
              <span class="imm-cat-emoji" aria-hidden="true">{c.flag}</span>
              <span class="imm-cat-code">{code}</span>
            </div>
            <div class="imm-cat-title">{name}</div>
            <div class="imm-cat-desc">{c.desc}</div>
            <div class="imm-cat-foot">
              {price
                ? <span class="imm-cat-price">{price} · flat fee</span>
                : <span class="imm-cat-price imm-cat-price--ask">Flat fee · ask</span>}
              <span class="imm-cat-arrow" aria-hidden="true">→</span>
            </div>
          </a>
        );
      })}
    </div>

    <div class="imm-cats-footnote">
      <p>
        {T.footPre} <a href={`${lp}/immigration#services-detail`}>{T.footLink}</a>{T.footMid}
        <a href={`${lp}/#get-started`}>{T.footTellLink}</a>{T.footPost}
      </p>
    </div>
  </div>
</section>

<style>
  .imm-hero {
    background: var(--paper);
    position: relative;
    overflow: hidden;
    padding: 58px 1.5rem var(--space-section);
  }
  .imm-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(#dcd2bd 1px, transparent 1px);
    background-size: 26px 26px;
    opacity: 0.45;
    pointer-events: none;
  }
  .imm-hero-inner { position: relative; max-width: 1220px; margin: 0 auto; }
  .imm-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 680px) 1fr;
    gap: 40px;
    align-items: start;
    margin-bottom: 40px;
  }
  .imm-hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #8B7B5C;
    border: 1px solid #DDD3BF;
    background: rgba(255, 255, 255, 0.5);
    padding: 7px 15px;
    border-radius: 999px;
    margin-bottom: 18px;
  }
  .imm-hero-eyebrow::before { content: "\2605"; color: var(--gold); }
  .imm-hero-copy h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(34px, 2.2vw + 22px, 54px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: #13202E;
    margin: 0 0 16px;
  }
  .imm-hero-em { font-style: italic; color: var(--gold-deep); }
  .imm-hero-copy p { font-size: 17px; line-height: 1.6; color: var(--text-2); margin: 0; max-width: 640px; text-wrap: pretty; }
  .imm-hero-meta {
    justify-self: end;
    text-align: right;
    border-left: 1px solid var(--border);
    padding-left: 28px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--meta);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .imm-hero-meta-num { color: var(--gold-deep); font-weight: 600; }
  @media (max-width: 860px) {
    .imm-hero-grid { grid-template-columns: 1fr; gap: 22px; }
    .imm-hero-meta { justify-self: start; text-align: left; border-left: none; padding-left: 0; border-top: 1px solid var(--border); padding-top: 18px; flex-direction: row; flex-wrap: wrap; gap: 6px 18px; }
  }

  .imm-cats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  @media (max-width: 980px) { .imm-cats-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .imm-cats-grid { grid-template-columns: 1fr; } }
  .imm-cat {
    display: flex;
    flex-direction: column;
    min-height: 182px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .imm-cat:hover { transform: translateY(-3px); box-shadow: 0 22px 40px -26px rgba(20, 32, 46, 0.42); border-color: #D8C8A4; }
  .imm-cat-top { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 14px; }
  .imm-cat-emoji { font-size: 24px; line-height: 1; }
  .imm-cat-code { font-family: var(--font-mono); font-size: 12px; font-weight: 600; color: var(--gold-deep); }
  .imm-cat-title { font-family: var(--font-display); font-size: 19px; font-weight: 500; line-height: 1.14; letter-spacing: -0.01em; color: var(--navy-dark); margin-bottom: 8px; }
  .imm-cat-desc { font-size: 13px; line-height: 1.5; color: var(--text-3); flex: 1; }
  .imm-cat-foot { display: flex; align-items: center; justify-content: space-between; gap: 10px; border-top: 1px solid #EFE8DB; padding-top: 12px; margin-top: 14px; }
  .imm-cat-price { font-family: var(--font-mono); font-size: 11.5px; font-weight: 600; color: var(--gold-deep); }
  .imm-cat-price--ask { color: #9AA3AD; font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; font-size: 11px; }
  .imm-cat-arrow { color: var(--gold); font-size: 15px; }

  .imm-cats-footnote { margin-top: 28px; text-align: center; }
  .imm-cats-footnote p { margin: 0; font-size: 14px; line-height: 1.6; color: var(--text-2); }
  .imm-cats-footnote a { color: var(--gold-deep); font-weight: 600; text-decoration: underline; text-decoration-color: rgba(156, 116, 48, 0.4); text-underline-offset: 2px; }
  .imm-cats-footnote a:hover { text-decoration-color: var(--gold-deep); }
</style>
