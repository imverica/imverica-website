---
// High-level service overview for the landing page. Links to dedicated pages.
const services = [
  {
    num: '01 — USCIS | EOIR Immigration',
    title: 'Immigration Forms & Petitions',
    desc: 'Adjustment of status, work permits, green card, asylum, TPS, U visa, naturalization, travel documents, and removal-defense document preparation. Remote service worldwide.',
    href: '/immigration',
    color: 'var(--navy)'
  },
  {
    num: '02 — California Family Law',
    title: 'Divorce & Family Forms',
    desc: 'Dissolution of marriage, summary dissolution, legal separation, child custody, and child support forms. Per California Family Code §2320 et seq.',
    href: '/fl',
    note: 'California residents only.',
    color: 'var(--terracotta-deep)'
  },
  {
    num: '03 — Small Claims & Civil',
    title: 'California Court Forms',
    desc: 'Small claims document preparation (current CA limit: $12,500 for individuals per CCP §116.221) and Superior Court civil forms.',
    href: '/sc',
    note: 'California residents only.',
    color: 'var(--sage)'
  },
  {
    num: '04 — Unlawful Detainer',
    title: 'Landlord & Tenant Documents',
    desc: 'Eviction (unlawful detainer) document preparation for landlords and tenants — complaints, responses, and related California court forms. Per CCP §1161 et seq.',
    href: '/california-unlawful-detainer',
    note: 'California residents only.',
    color: 'var(--gold)'
  },
  {
    num: '05 — Restraining Orders',
    title: 'Protective Order Packets',
    desc: 'Domestic violence, civil harassment, elder-abuse, gun-violence, and workplace-violence restraining-order packages.',
    href: '/california-restraining-orders',
    note: 'California residents only.',
    color: 'var(--navy-light)'
  },
  {
    num: '06 — Probate & Expungement',
    title: 'Estates & Record-Cleanup Forms',
    desc: 'Probate opening and closing packets, final distribution/discharge documents, small-estate affidavits, and California expungement/dismissal packets for DUI and other eligible cases.',
    href: '/california-expungement',
    note: 'California residents only.',
    color: 'var(--terracotta)'
  },
  {
    num: '07 — About & LDA basics',
    title: 'What is a California LDA?',
    desc: 'How a registered Legal Document Assistant and Immigration Consultant can help you — and the legal limits we work within.',
    href: '/lda',
    color: 'var(--muted)'
  },
  {
    num: '08 — Name Change & Identity',
    title: 'Name Change Court Packets',
    desc: 'California legal name-change document preparation, NC-100 series court packets, gender-marker updates, and supporting identity-document paperwork.',
    href: '/#get-started?form=NC-100',
    note: 'California residents only.',
    color: 'var(--terracotta-deep)'
  },
  {
    num: '09 — Traffic, DMV & Collections',
    title: 'Ticket, Title & Judgment Forms',
    desc: 'Traffic ticket paperwork, DMV title and license forms, fee waivers, and post-judgment collection packets such as EJ-001 and WG-001.',
    href: '/#get-started?form=DMV',
    note: 'California residents only.',
    color: 'var(--sage)'
  }
];
---
<section class="ourserv-section" id="services">
  <div class="ourserv-inner">
    <div class="ourserv-kicker">What we do</div>
    <h2>Our Services</h2>
    <p class="ourserv-sub">We handle the paperwork — accurately, on time, and without surprises.</p>
    <div class="ourserv-grid">
      {services.map((s) => (
        <a class="ourserv-card" href={s.href}>
          <div class="ourserv-num" style={`color:${s.color}`}>{s.num}</div>
          <div class="ourserv-title">{s.title}</div>
          <div class="ourserv-desc">{s.desc}</div>
          {s.note && <div class="ourserv-note">{s.note}</div>}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ourserv-section { padding: var(--space-section) 1.5rem; background: var(--paper); border-top: 1px solid var(--border); }
  .ourserv-inner { max-width: 1220px; margin: 0 auto; }
  .ourserv-kicker, .ourserv-section h2, .ourserv-sub { text-align: center; }
  .ourserv-sub { margin-left: auto; margin-right: auto; }
  .ourserv-kicker { font-family: var(--font-mono); font-size: 11.5px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold-deep); margin-bottom: 12px; }
  .ourserv-section h2 { font-size: var(--fs-h2); margin-bottom: 10px; font-weight: 500; }
  .ourserv-sub { color: var(--text-2); font-size: 16px; margin-bottom: 32px; }
  .ourserv-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 820px) { .ourserv-grid { grid-template-columns: 1fr; } }
  .ourserv-card { display: flex; flex-direction: column; min-height: 200px; background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 24px; text-decoration: none; transition: transform 0.18s ease, box-shadow 0.18s ease; }
  .ourserv-card:hover { transform: translateY(-3px); box-shadow: 0 22px 40px -26px rgba(20, 32, 46, 0.4); }
  .ourserv-num { font-family: var(--font-mono); font-size: 12px; font-weight: 500; letter-spacing: 0.04em; text-transform: none; color: var(--gold) !important; margin-bottom: 14px; }
  .ourserv-title { font-family: var(--font-display); font-size: 21px; font-weight: 500; letter-spacing: -0.01em; color: var(--navy-dark); margin-bottom: 10px; }
  .ourserv-desc { font-size: 14px; line-height: 1.55; color: var(--text-2); flex: 1; }
  .ourserv-note { font-size: 11.5px; font-weight: 600; color: var(--ca-only); margin-top: 14px; font-style: normal; border-top: 1px solid #EFE8DB; padding-top: 12px; }
</style>
