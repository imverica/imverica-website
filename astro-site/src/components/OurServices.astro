---
// High-level service overview for the landing page. Links to dedicated pages.
const services = [
  {
    num: '01 — USCIS | EOIR Immigration',
    title: 'Immigration Forms & Petitions',
    desc: 'Adjustment of status, work permits, green card, asylum, TPS, U visa, naturalization, travel documents, and removal-defense document preparation. Remote service worldwide.',
    href: '/immigration',
    color: 'var(--navy)'
  },
  {
    num: '02 — California Family Law',
    title: 'Divorce & Family Forms',
    desc: 'Dissolution of marriage, summary dissolution, legal separation, child custody, and child support forms. Per California Family Code §2320 et seq.',
    href: '/fl',
    note: 'California residents only.',
    color: 'var(--terracotta-deep)'
  },
  {
    num: '03 — Small Claims & Civil',
    title: 'California Court Forms',
    desc: 'Small claims document preparation (current CA limit: $12,500 for individuals per CCP §116.221) and Superior Court civil forms.',
    href: '/sc',
    note: 'California residents only.',
    color: 'var(--sage)'
  },
  {
    num: '04 — Unlawful Detainer',
    title: 'Landlord & Tenant Documents',
    desc: 'Eviction (unlawful detainer) document preparation for landlords and tenants — complaints, responses, and related California court forms. Per CCP §1161 et seq.',
    href: '/california-unlawful-detainer',
    note: 'California residents only.',
    color: 'var(--gold)'
  },
  {
    num: '05 — Restraining Orders & Probate',
    title: 'Protective Orders & Estates',
    desc: 'Domestic violence, civil harassment, and elder-abuse restraining-order packages; probate and small-estate document preparation.',
    href: '/california-restraining-orders',
    note: 'California residents only.',
    color: 'var(--navy-light)'
  },
  {
    num: '06 — About & LDA basics',
    title: 'What is a California LDA?',
    desc: 'How a registered Legal Document Assistant and Immigration Consultant can help you — and the legal limits we work within.',
    href: '/lda',
    color: 'var(--muted)'
  }
];
---
<section class="ourserv-section" id="services">
  <div class="ourserv-inner">
    <div class="ourserv-kicker">What we do</div>
    <h2>Our Services</h2>
    <p class="ourserv-sub">We handle the paperwork — accurately, on time, and without surprises.</p>
    <div class="ourserv-grid">
      {services.map((s) => (
        <a class="ourserv-card" href={s.href}>
          <div class="ourserv-num" style={`color:${s.color}`}>{s.num}</div>
          <div class="ourserv-title">{s.title}</div>
          <div class="ourserv-desc">{s.desc}</div>
          {s.note && <div class="ourserv-note">{s.note}</div>}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ourserv-section { padding: 76px 1.5rem; background: #fff; border-top: 1px solid rgba(40,30,20,0.08); }
  .ourserv-inner { max-width: 1200px; margin: 0 auto; }
  .ourserv-kicker { font-size: 11px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; color: var(--terracotta-deep); margin-bottom: 10px; }
  .ourserv-section h2 { font-size: 36px; margin-bottom: 10px; font-weight: 700; }
  .ourserv-sub { color: var(--muted); font-size: 15px; margin-bottom: 28px; }
  .ourserv-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  @media (max-width: 820px) { .ourserv-grid { grid-template-columns: 1fr; } }
  .ourserv-card { display: block; background: #fff; padding: 26px 24px; text-decoration: none; transition: background 0.18s ease; }
  .ourserv-card:hover { background: #fffaf2; }
  .ourserv-num { font-size: 12px; font-weight: 700; letter-spacing: 0.6px; text-transform: uppercase; margin-bottom: 8px; }
  .ourserv-title { font-family: var(--font-display); font-size: 19px; color: var(--navy-dark); margin-bottom: 8px; }
  .ourserv-desc { font-size: 13.5px; line-height: 1.6; color: #3a4a5e; }
  .ourserv-note { font-size: 12px; color: var(--muted); margin-top: 8px; font-style: italic; }
</style>
