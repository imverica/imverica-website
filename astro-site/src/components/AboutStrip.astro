---
// Compact "Who we are" block for the homepage bottom. Links to the full
// About / What-is-an-LDA page. UPL-safe: no legal-advice claims.
const points = [
  {
    title: 'California Licensed LDA',
    body: 'Registered and bonded Legal Document Assistant under Cal. Bus. & Prof. Code §§6400-6415 — authorized to prepare court and agency documents at your direction.'
  },
  {
    title: 'Immigration Consultant',
    body: 'Registered Immigration Consultant for USCIS and EOIR document preparation under Cal. Bus. & Prof. Code §§22440-22448. Remote service worldwide.'
  },
  {
    title: 'Flat fee, no surprises',
    body: 'A written §6410 contract and a flat fee disclosed before we start. We are not a law firm and do not give legal advice — we prepare the documents you decide to file.'
  }
];
---
<section class="about-strip" id="about">
  <div class="about-inner">
    <div class="about-head">
      <div class="about-kicker">Who we are</div>
      <h2>A California Licensed LDA &amp; Immigration Consultant</h2>
      <p>
        Imverica Legal Solutions prepares immigration and California court
        documents accurately, on time, and at your direction — multilingual
        intake in English, Russian, Ukrainian, and Spanish.
      </p>
    </div>
    <div class="about-grid">
      {points.map((p) => (
        <div class="about-card">
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </div>
      ))}
    </div>
    <div class="about-actions">
      <a class="btn btn-accent" href="/california-legal-document-assistant">What is a California LDA?</a>
      <a class="btn btn-ghost" href="/#get-started">Start with Imverica</a>
    </div>
  </div>
</section>

<style>
  .about-strip { padding: 76px 1.5rem; background: var(--cream); border-top: 1px solid var(--border); }
  .about-inner { max-width: 1200px; margin: 0 auto; }
  .about-head { max-width: 760px; }
  .about-kicker { font-size: 11px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; color: var(--terracotta-deep); margin-bottom: 10px; }
  .about-strip h2 { font-size: 30px; margin-bottom: 12px; }
  .about-head > p { color: #3a4a5e; font-size: 15px; line-height: 1.7; margin: 0; }
  .about-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 32px 0; }
  @media (max-width: 820px) { .about-grid { grid-template-columns: 1fr; } }
  .about-card { background: #fff; border: 1px solid rgba(40,30,20,0.08); border-radius: 12px; padding: 24px; box-shadow: 0 6px 20px rgba(40,30,20,0.04); }
  .about-card h3 { font-family: 'Playfair Display', serif; font-size: 19px; color: var(--navy-dark); margin: 0 0 8px; }
  .about-card p { font-size: 13.5px; line-height: 1.65; color: #3a4a5e; margin: 0; }
  .about-actions { display: flex; flex-wrap: wrap; gap: 12px; }
</style>
