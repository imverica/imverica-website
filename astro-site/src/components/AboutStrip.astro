---
// Compact "Who we are" block for the homepage bottom. Links to the full
// About / What-is-an-LDA page. UPL-safe: no legal-advice claims.
const points = [
  {
    icon: '§',
    title: 'California Registered LDA',
    body: 'Registered and bonded Legal Document Assistant under Cal. Bus. & Prof. Code §§6400-6415 — authorized to prepare court and agency documents at your direction.'
  },
  {
    icon: '✦',
    title: 'Immigration Consultant',
    body: 'Registered Immigration Consultant for USCIS and EOIR document preparation under Cal. Bus. & Prof. Code §§22440-22448. Remote service worldwide.'
  },
  {
    icon: '✓',
    title: 'Flat fee, no surprises',
    body: 'A written §6410 contract and a flat fee disclosed before we start. We are not a law firm and do not give legal advice — we prepare the documents you decide to file.'
  }
];
---
<section class="about-strip" id="about">
  <div class="about-inner">
    <div class="about-head">
      <div class="about-kicker">Who we are</div>
      <h2 class="about-h2">A California Registered LDA &amp; Immigration&nbsp;Consultant</h2>
      <p class="about-lead">
        Imverica Legal Solutions prepares immigration and California court documents accurately, on time, and at your direction — multilingual intake in English, Russian, Ukrainian, and Spanish.
      </p>
    </div>
    <div class="about-grid">
      {points.map((p) => (
        <div class="about-card">
          <div class="about-icon" aria-hidden="true">{p.icon}</div>
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </div>
      ))}
    </div>
    {/* CTA buttons were removed: the homepage hero, every landing page
        and the footer already have "What is an LDA" / "Start with
        Imverica" calls — repeating them right under the three info
        cards reads as filler. */}
  </div>
</section>

<style>
  .about-strip { padding: 80px 1.5rem; background: var(--paper); border-top: 1px solid var(--border); }
  .about-inner { max-width: 1220px; margin: 0 auto; }
  .about-icon { width: 42px; height: 42px; border-radius: 10px; background: var(--gold-tint); color: var(--gold-deep); display: flex; align-items: center; justify-content: center; font-size: 19px; margin-bottom: 18px; }
  /* The intro spans the full 3-column row (1200 max) instead of being
     boxed to 760 — gives the lead more horizontal breathing room and
     avoids the awkward orphan "Consultant" wrap that came from a
     narrower constraint. */
  .about-head { max-width: 720px; margin: 0 auto 46px; text-align: center; }
  .about-kicker { font-family: var(--font-mono); font-size: 11.5px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold-deep); margin-bottom: 12px; }
  /* text-wrap: balance gives every line about the same character count,
     so awkward orphans like "they speak" or "Consultant" alone on the
     second line are auto-redistributed across all lines. Supported by
     Chrome/Safari/Firefox; older browsers just fall back to natural wrap. */
  .about-strip h2,
  .about-strip .about-h2 { font-size: var(--fs-h2); margin-bottom: 16px; font-weight: 500; text-wrap: balance; }
  .about-head > p,
  .about-head .about-lead { color: var(--text-2); font-size: 16.5px; line-height: 1.65; margin: 0; text-wrap: pretty; }
  .about-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 32px 0; }
  @media (max-width: 820px) { .about-grid { grid-template-columns: 1fr; } }
  .about-card { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 28px; }
  .about-card h3 { font-family: var(--font-display); font-size: 21px; font-weight: 500; letter-spacing: -0.01em; color: var(--navy-dark); margin: 0 0 10px; }
  .about-card p { font-size: 14px; line-height: 1.6; color: var(--text-2); margin: 0; }
  .about-actions { display: flex; flex-wrap: wrap; gap: 12px; }
</style>
