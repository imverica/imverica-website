<!-- Floating AI chat widget — ported verbatim from legacy index.html. Talks to /api/chat (chat.js function). -->
<style is:global>
#iw-launcher{position:fixed;bottom:24px;right:24px;width:60px;height:60px;border-radius:50%;background:#1a2e4a;color:#fff;border:none;cursor:pointer;z-index:9998;box-shadow:0 4px 16px rgba(0,0,0,0.25);display:flex;align-items:center;justify-content:center;font-size:28px;transition:transform 0.2s;}
#iw-launcher:hover{transform:scale(1.08);}
#iw-window{position:fixed;bottom:96px;right:24px;width:360px;max-width:calc(100vw - 48px);height:520px;background:#fff;border-radius:12px;box-shadow:0 8px 40px rgba(0,0,0,0.25);z-index:9997;display:none;flex-direction:column;overflow:hidden;font-family:var(--font-system);}
#iw-window.open{display:flex;}
#iw-content{display:flex;flex-direction:column;flex:1;min-height:0;overflow:hidden;}
.iw-header{background:#1a2e4a;color:#fff;padding:16px;display:flex;justify-content:space-between;align-items:center;}
.iw-header-title{font-weight:500;font-size:15px;}
.iw-close{background:none;border:none;color:#fff;font-size:22px;cursor:pointer;line-height:1;padding:0;}
.iw-langs{display:flex;gap:6px;padding:10px 14px;border-bottom:1px solid #eee;background:#f8f8f6;}
.iw-lang{flex:1;padding:6px;border:1px solid #ddd;background:#fff;border-radius:4px;cursor:pointer;font-size:12px;color:#444;font-family:inherit;}
.iw-lang.active{background:#1a2e4a;color:#fff;border-color:#1a2e4a;}
.iw-menu{padding:14px;display:flex;flex-direction:column;gap:8px;flex:1;overflow-y:auto;}
.iw-menu-btn{display:flex;align-items:center;gap:12px;padding:14px;border:1px solid #ddd;background:#fff;border-radius:8px;cursor:pointer;font-size:14px;color:#333;text-decoration:none;font-family:inherit;text-align:left;transition:background 0.15s;}
.iw-menu-btn:hover{background:#f4f3f0;}
.iw-menu-icon{font-size:22px;}
.iw-menu-text{flex:1;}
.iw-menu-title{font-weight:500;color:#1a2e4a;}
.iw-menu-sub{font-size:12px;color:#888;margin-top:2px;}
.iw-back{background:none;border:none;color:#1a2e4a;font-size:13px;cursor:pointer;padding:8px 14px;font-family:inherit;text-align:left;border-bottom:1px solid #eee;}
.iw-chat-body{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:8px;}
.iw-msg{padding:10px 14px;border-radius:12px;max-width:85%;font-size:14px;line-height:1.4;}
.iw-msg-bot{background:#f0f4f8;color:#333;align-self:flex-start;}
.iw-msg-user{background:#1a2e4a;color:#fff;align-self:flex-end;}
.iw-typing{font-style:italic;color:#888;font-size:13px;padding:8px 14px;}
.iw-input-row{display:flex;border-top:1px solid #eee;padding:10px;gap:8px;}
.iw-input{flex:1;border:1px solid #ddd;border-radius:6px;padding:10px;font-size:14px;font-family:inherit;outline:none;}
.iw-input:focus{border-color:#1a2e4a;}
.iw-send{background:#1a2e4a;color:#fff;border:none;border-radius:6px;padding:0 16px;cursor:pointer;font-size:16px;}
.iw-form{padding:14px;display:flex;flex-direction:column;gap:10px;}
.iw-form input,.iw-form textarea{border:1px solid #ddd;border-radius:6px;padding:10px;font-size:14px;font-family:inherit;outline:none;}
.iw-form textarea{resize:vertical;min-height:80px;}
.iw-form button{background:#1a2e4a;color:#fff;border:none;border-radius:6px;padding:12px;cursor:pointer;font-size:14px;font-family:inherit;}
.iw-success{padding:14px;color:#1a5a3a;font-size:14px;text-align:center;}
.iw-presets{display:flex;flex-wrap:wrap;gap:6px;padding:4px 0 8px;}
.iw-preset{background:#f0f4f8;border:1px solid #c5d0de;color:#1a2e4a;border-radius:16px;padding:5px 12px;font-size:12px;cursor:pointer;font-family:inherit;transition:background 0.15s;}
.iw-preset:hover{background:#1a2e4a;color:#fff;border-color:#1a2e4a;}
.iw-disclaimer-wrap{padding:10px 14px 14px;border-top:1px solid #eee;margin-top:4px;}
.iw-disclaimer-label{display:flex;gap:10px;align-items:flex-start;cursor:pointer;font-size:11px;color:#555;line-height:1.5;}
.iw-disclaimer-label input[type=checkbox]{margin-top:2px;flex-shrink:0;width:15px;height:15px;cursor:pointer;accent-color:#1a2e4a;}
@media (max-width: 720px){
  /* Align the chat button to the same right gutter as page content and the
     hero arrow, and keep it a touch smaller so it doesn't cover text. */
  #iw-launcher{bottom:18px;right:16px;width:54px;height:54px;font-size:25px;}
  #iw-window{bottom:84px;right:16px;}
}
</style>

<button id="iw-launcher" aria-label="Open chat">💬</button>

<div id="iw-window">
  <div class="iw-header">
    <div class="iw-header-title">Imverica Legal Solutions</div>
    <button class="iw-close" id="iw-close">×</button>
  </div>
  <div class="iw-langs">
    <button class="iw-lang active" data-lang="en">EN</button>
    <button class="iw-lang" data-lang="ru">RU</button>
    <button class="iw-lang" data-lang="uk">UA</button>
    <button class="iw-lang" data-lang="es">ES</button>
  </div>
  <div id="iw-content"></div>
</div>


<script is:inline>
(function(){
  const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbw1-Im71BEZQMEL8elsKTQekokZCqqV0Mj7D6d44G1ueAIDIiqV6QXvR0p6Btqs7WaFnA/exec';
  
  const T = {
    en: {
      menuTitle: 'How can we help you?',
      ai: 'Chat with our assistant', aiSub: 'Get instant answers',
      msg: 'Send us a message', msgSub: 'We reply within 1 business day',
      tg: 'Telegram', tgSub: 'Chat on Telegram',
      call: 'Call us', callSub: '+1 (916) 399-3992',
      back: '← Back',
      formName: 'Your name', formPhone: 'Phone', formEmail: 'Email (optional)', formMsg: 'Message',
      send: 'Send', sending: 'Sending...',
      success: '✓ Message received! We will contact you within 1 business day.',
      chatPlaceholder: 'Type your message...',
      chatGreeting: 'Hello! Ask me about USCIS forms, family law, civil court, or our services.',
      chatError: 'Sorry, please try again or call us at +1 (916) 399-3992.',
      tosText: 'I understand that Imverica Legal Solutions provides document-preparation services through registered Legal Document Assistants (LDAs) and immigration consultant document-preparation personnel, as applicable, but is not a law firm and its personnel are not acting as attorneys. Imverica prepares documents only at the client\'s direction, does not provide legal advice, does not choose forms or legal strategy for me, and does not guarantee any result. For legal advice, I should consult a licensed attorney. I agree to the <a href="/terms.html" target="_blank" style="color:#1a2e4a;text-decoration:underline;">Terms of Service</a>.',
      presets: ['Green Card', 'Asylum', 'U Visa', 'Divorce', 'Small Claims', 'DMV']
    },
    ru: {
      menuTitle: 'Как мы можем помочь?',
      ai: 'Чат с ассистентом', aiSub: 'Мгновенные ответы',
      msg: 'Отправить сообщение', msgSub: 'Ответим в течение 1 рабочего дня',
      tg: 'Telegram', tgSub: 'Чат в Telegram',
      call: 'Позвонить', callSub: '+1 (916) 399-3992',
      back: '← Назад',
      formName: 'Ваше имя', formPhone: 'Телефон', formEmail: 'Email (необязательно)', formMsg: 'Сообщение',
      send: 'Отправить', sending: 'Отправка...',
      success: '✓ Сообщение получено! Мы свяжемся с вами в течение 1 рабочего дня.',
      chatPlaceholder: 'Напишите ваше сообщение...',
      chatGreeting: 'Здравствуйте! Спросите меня о формах USCIS, семейном праве, гражданских делах или наших услугах.',
      chatError: 'Извините, попробуйте еще раз или позвоните нам +1 (916) 399-3992.',
      tosText: 'Я понимаю, что Imverica Legal Solutions предоставляет услуги подготовки документов через зарегистрированных помощников по юридическим документам (LDA) и иммиграционных консультантов по подготовке документов, где применимо, но не является юридической фирмой, а ее сотрудники не действуют как адвокаты. Imverica готовит документы только по указанию клиента, не предоставляет юридические консультации, не выбирает за меня формы или правовую стратегию и не гарантирует результат. Для юридической консультации мне следует обратиться к лицензированному адвокату. Я соглашаюсь с <a href="/terms.html" target="_blank" style="color:#1a2e4a;text-decoration:underline;">Условиями использования</a>.',
      presets: ['Грин карта', 'Убежище', 'Виза U', 'Развод', 'Малые иски', 'DMV']
    },
    uk: {
      menuTitle: 'Як ми можемо допомогти?',
      ai: 'Чат з асистентом', aiSub: 'Миттєві відповіді',
      msg: 'Надіслати повідомлення', msgSub: 'Відповімо протягом 1 робочого дня',
      tg: 'Telegram', tgSub: 'Чат у Telegram',
      call: 'Зателефонувати', callSub: '+1 (916) 399-3992',
      back: '← Назад',
      formName: 'Ваше ім\'я', formPhone: 'Телефон', formEmail: 'Email (за бажанням)', formMsg: 'Повідомлення',
      send: 'Надіслати', sending: 'Надсилання...',
      success: '✓ Повідомлення отримано! Ми зв\'яжемось з вами протягом 1 робочого дня.',
      chatPlaceholder: 'Напишіть ваше повідомлення...',
      chatGreeting: 'Вітаю! Запитайте мене про форми USCIS, сімейне право, цивільні справи або наші послуги.',
      chatError: 'Вибачте, спробуйте ще раз або зателефонуйте нам +1 (916) 399-3992.',
      tosText: 'Я розумію, що Imverica Legal Solutions надає послуги з підготовки документів через зареєстрованих помічників з юридичних документів (LDA) та імміграційних консультантів з підготовки документів, де це застосовується, але не є юридичною фірмою, а її працівники не діють як адвокати. Imverica готує документи лише за вказівкою клієнта, не надає юридичних консультацій, не обирає за мене форми або правову стратегію і не гарантує результат. Для юридичної консультації мені слід звернутися до ліцензованого адвоката. Я погоджуюся з <a href="/terms.html" target="_blank" style="color:#1a2e4a;text-decoration:underline;">Умовами використання</a>.',
      presets: ['Грін карта', 'Притулок', 'Віза U', 'Розлучення', 'Малі позови', 'DMV']
    },
    es: {
      menuTitle: '¿Cómo podemos ayudarle?',
      ai: 'Chat con asistente', aiSub: 'Respuestas instantáneas',
      msg: 'Enviar mensaje', msgSub: 'Respondemos en 1 día hábil',
      tg: 'Telegram', tgSub: 'Chat en Telegram',
      call: 'Llamar', callSub: '+1 (916) 399-3992',
      back: '← Atrás',
      formName: 'Su nombre', formPhone: 'Teléfono', formEmail: 'Email (opcional)', formMsg: 'Mensaje',
      send: 'Enviar', sending: 'Enviando...',
      success: '✓ ¡Mensaje recibido! Le contactaremos en 1 día hábil.',
      chatPlaceholder: 'Escriba su mensaje...',
      chatGreeting: '¡Hola! Pregúnteme sobre formularios USCIS, derecho familiar, tribunales civiles o nuestros servicios.',
      chatError: 'Lo siento, inténtelo de nuevo o llámenos al +1 (916) 399-3992.',
      tosText: 'Entiendo que Imverica Legal Solutions brinda servicios de preparación de documentos a través de Asistentes de Documentos Legales (LDA) registrados y consultores de inmigración para preparación de documentos, según corresponda, pero no es un bufete de abogados y su personal no actúa como abogado. Imverica solo prepara documentos bajo la dirección del cliente, no brinda asesoramiento legal, no elige formularios ni estrategia legal por mí, y no garantiza ningún resultado. Para asesoramiento legal, debo consultar a un abogado con licencia. Acepto los <a href="/terms.html" target="_blank" style="color:#1a2e4a;text-decoration:underline;">Términos de Servicio</a>.',
      presets: ['Tarjeta Verde', 'Asilo', 'Visa U', 'Divorcio', 'Demanda Civil', 'DMV']
    }
  };
  
  let currentLang = 'en';
  let conversationHistory = [];
  
  const launcher = document.getElementById('iw-launcher');
  const win = document.getElementById('iw-window');
  const closeBtn = document.getElementById('iw-close');
  const content = document.getElementById('iw-content');
  
  launcher.addEventListener('click', function(){
    win.classList.toggle('open');
    if (win.classList.contains('open')) renderMenu();
  });
  closeBtn.addEventListener('click', function(){
    win.classList.remove('open');
  });
  
  document.querySelectorAll('.iw-lang').forEach(btn => {
    btn.addEventListener('click', function(){
      document.querySelectorAll('.iw-lang').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      currentLang = this.dataset.lang;
      renderMenu();
    });
  });
  
  function renderMenu() {
    const t = T[currentLang];
    content.innerHTML = `
      <div class="iw-menu">
        <button class="iw-menu-btn" id="iw-go-ai">
          <span class="iw-menu-icon">🤖</span>
          <span class="iw-menu-text">
            <div class="iw-menu-title">${t.ai}</div>
            <div class="iw-menu-sub">${t.aiSub}</div>
          </span>
        </button>
        <button class="iw-menu-btn" id="iw-go-msg">
          <span class="iw-menu-icon">✉️</span>
          <span class="iw-menu-text">
            <div class="iw-menu-title">${t.msg}</div>
            <div class="iw-menu-sub">${t.msgSub}</div>
          </span>
        </button>
        <a class="iw-menu-btn" id="iw-go-tg" href="https://t.me/imverica" target="_blank">
          <span class="iw-menu-icon">📱</span>
          <span class="iw-menu-text">
            <div class="iw-menu-title">${t.tg}</div>
            <div class="iw-menu-sub">${t.tgSub}</div>
          </span>
        </a>
        <a class="iw-menu-btn" href="tel:+19163993992">
          <span class="iw-menu-icon">📞</span>
          <span class="iw-menu-text">
            <div class="iw-menu-title">${t.call}</div>
            <div class="iw-menu-sub">${t.callSub}</div>
          </span>
        </a>
        <div class="iw-disclaimer-wrap">
          <label class="iw-disclaimer-label">
            <input type="checkbox" id="iw-tos-check">
            <span>${t.tosText}</span>
          </label>
        </div>
      </div>
    `;

    const check = document.getElementById('iw-tos-check');
    const btnAi = document.getElementById('iw-go-ai');
    const btnMsg = document.getElementById('iw-go-msg');
    const btnTg = document.getElementById('iw-go-tg');

    function setBlocked(blocked) {
      [btnAi, btnMsg, btnTg].forEach(btn => {
        btn.style.opacity = blocked ? '0.4' : '1';
        btn.style.pointerEvents = blocked ? 'none' : 'auto';
        btn.style.cursor = blocked ? 'not-allowed' : 'pointer';
      });
    }

    setBlocked(true);
    check.addEventListener('change', function() { setBlocked(!this.checked); });
    btnAi.onclick = function() { if (check.checked) renderChat(); };
    btnMsg.onclick = function() { if (check.checked) renderForm(); };
  }
  
  function renderForm() {
    const t = T[currentLang];
    content.innerHTML = `
      <button class="iw-back" id="iw-back-btn">${t.back}</button>
      <form class="iw-form" id="iw-msg-form">
        <input type="text" name="name" placeholder="${t.formName}" required>
        <input type="tel" name="phone" placeholder="${t.formPhone}" required>
        <input type="email" name="email" placeholder="${t.formEmail}">
        <textarea name="message" placeholder="${t.formMsg}" required></textarea>
        <button type="submit">${t.send}</button>
      </form>
    `;
    document.getElementById('iw-back-btn').onclick = renderMenu;
    document.getElementById('iw-msg-form').onsubmit = async function(e){
      e.preventDefault();
      const btn = e.target.querySelector('button[type=submit]');
      btn.disabled = true;
      btn.textContent = t.sending;
      const fd = new FormData(e.target);
      const payload = {
        name: fd.get('name'), phone: fd.get('phone'),
        email: fd.get('email'), service: 'Chat widget',
        message: fd.get('message')
      };
      try {
        await fetch(APPS_SCRIPT_URL, {
          method: 'POST', mode: 'no-cors',
          headers: {'Content-Type':'application/json'},
          body: JSON.stringify(payload)
        });
        content.innerHTML = `<div class="iw-success">${t.success}</div><button class="iw-back" onclick="document.getElementById('iw-launcher').click();document.getElementById('iw-launcher').click();">${t.back}</button>`;
      } catch(err) {
        btn.disabled = false;
        btn.textContent = t.send;
        alert('Error. Call +1 (916) 399-3992');
      }
    };
  }
  
  function renderChat() {
    const t = T[currentLang];
    conversationHistory = [];
    const presetBtns = (t.presets || []).map(p =>
      `<button class="iw-preset" data-text="${p}">${p}</button>`
    ).join('');
    content.innerHTML = `
      <button class="iw-back" id="iw-back-btn">${t.back}</button>
      <div class="iw-chat-body" id="iw-chat-body" style="flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:8px;">
        <div class="iw-msg iw-msg-bot">${t.chatGreeting}</div>
        <div class="iw-presets" id="iw-presets">${presetBtns}</div>
      </div>
      <div class="iw-input-row" style="flex-shrink:0;display:flex;border-top:1px solid #eee;padding:10px;gap:8px;">
        <input class="iw-input" id="iw-chat-input" type="text" placeholder="${t.chatPlaceholder}" style="flex:1;border:1px solid #ddd;border-radius:6px;padding:10px;font-size:14px;font-family:inherit;outline:none;">
        <button class="iw-send" id="iw-chat-send" style="flex-shrink:0;background:#1a2e4a;color:#fff;border:none;border-radius:6px;padding:0 16px;cursor:pointer;font-size:16px;">→</button>
      </div>
    `;
    document.getElementById('iw-back-btn').onclick = renderMenu;
    const input = document.getElementById('iw-chat-input');
    const sendBtn = document.getElementById('iw-chat-send');
    const body = document.getElementById('iw-chat-body');
    let sending = false;

    // preset buttons
    document.querySelectorAll('.iw-preset').forEach(btn => {
      btn.addEventListener('click', function() {
        input.value = this.dataset.text;
        const presets = document.getElementById('iw-presets');
        if (presets) presets.remove();
        send();
      });
    });
    
    function addMsg(text, who) {
      const div = document.createElement('div');
      div.className = 'iw-msg iw-msg-' + who;
      div.innerHTML = text
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
        .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
        .replace(/\n/g,'<br>');
      body.appendChild(div);
      body.scrollTop = body.scrollHeight;
    }
    
    async function send() {
      if (sending) return;
      const txt = input.value.trim();
      if (!txt) return;
      sending = true;
      sendBtn.style.opacity = '0.5';
      addMsg(txt, 'user');
      conversationHistory.push({role:'user', content: txt});
      input.value = '';
      
      const typing = document.createElement('div');
      typing.className = 'iw-typing';
      typing.textContent = '...';
      body.appendChild(typing);
      body.scrollTop = body.scrollHeight;
      
      try {
        const useLiveChatApi = window.location.protocol === 'file:' ||
          window.location.hostname === '127.0.0.1' ||
          window.location.hostname === 'localhost';
        const chatUrl = useLiveChatApi
          ? 'https://imverica.com/.netlify/functions/chat'
          : '/.netlify/functions/chat';
        const res = await fetch(chatUrl, {
          method: 'POST',
          headers: {'Content-Type':'application/json'},
          body: JSON.stringify({messages: conversationHistory})
        });
        typing.remove();
        if (res.status === 429) {
          addMsg(currentLang === 'ru' ? 'Слишком много сообщений. Позвоните нам: +1 (916) 399-3992.' :
                 currentLang === 'uk' ? 'Забагато повідомлень. Зателефонуйте нам: +1 (916) 399-3992.' :
                 currentLang === 'es' ? 'Demasiados mensajes. Llámenos: +1 (916) 399-3992.' :
                 'Too many messages. Please call us: +1 (916) 399-3992.', 'bot');
          sendBtn.disabled = true;
          input.disabled = true;
          input.placeholder = '...';
        } else if (!res.ok) {
          addMsg(t.chatError, 'bot');
        } else {
          const data = await res.json();
          const reply = data.reply || t.chatError;
          conversationHistory.push({role:'assistant', content: reply});
          addMsg(reply, 'bot');
        }
      } catch(err) {
        typing.remove();
        addMsg(t.chatError, 'bot');
      } finally {
        sending = false;
        sendBtn.style.opacity = '1';
      }
    }
    
    sendBtn.onclick = send;
    input.addEventListener('keydown', e => { if (e.key === 'Enter') send(); });
    input.focus();
  }
})();
</script>
