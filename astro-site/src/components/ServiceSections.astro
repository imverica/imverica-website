---
import { localizedPathSafe, type Locale } from '~/data/i18n';

const services = [
  {
    id: 'immigration-consultant-california',
    title: 'USCIS immigration document preparation',
    text: 'Full USCIS form package preparation for adjustment of status, work authorization, family petitions, naturalization, asylum, travel documents, green card replacement, and supporting affidavits.',
    items: [
      'I-485 — Adjustment of Status',
      'I-130 / I-130A — Petition for Alien Relative',
      'I-765 — Employment Authorization',
      'I-589 — Asylum & Withholding of Removal',
      'N-400 — Naturalization',
      'I-131 / I-131A — Travel Document / Re-entry Permit',
      'I-90 — Green Card Renewal / Replacement',
      'I-864 / I-864A — Affidavit of Support',
      'I-693 — Medical Examination submittal',
      'I-751 — Removal of Conditions on Residence',
      'I-539 — Change / Extend Non-immigrant Status',
      'I-824 — Action on Approved Application'
    ],
    cite: 'Documents are prepared at the client’s direction. We do not select forms or provide legal advice.'
  },
  {
    id: 'eoir-documents',
    title: 'EOIR immigration court documents',
    text: 'Document preparation for proceedings before the Executive Office for Immigration Review (EOIR) — motions, evidence packets, indexes, declarations, and applications for relief.',
    items: [
      'EOIR-28 — Notice of Entry of Appearance',
      'EOIR-29 — Notice of Appeal (BIA)',
      'EOIR-42A — Cancellation of Removal (LPR)',
      'EOIR-42B — Cancellation of Removal (Non-LPR)',
      'EOIR-40 — Suspension of Deportation',
      'Motion to reopen / reconsider packets',
      'Evidence packets, indexes, tabs',
      'Country-conditions evidence assembly',
      'Witness declarations & translation prep'
    ],
    cite: 'Court representation requires a licensed attorney or accredited representative.'
  },
  {
    id: 'family-law-documents-california',
    title: 'California family law document preparation',
    text: 'Petition, response, and supporting documents for California dissolution, legal separation, parentage, custody, support, and fee waiver matters.',
    items: ['FL-100, FL-110, FL-120, FL-150', 'FL-300 — Request for Order', 'FL-105 / UCCJEA', 'FW-001 — Request to Waive Court Fees'],
    cite: 'California Family Code and Judicial Council forms.'
  },
  {
    id: 'unlawful-detainer-document-preparation-california',
    title: 'Unlawful detainer document preparation',
    text: 'Landlord and tenant document preparation for California unlawful detainer matters, notices, answers, proof of service, and court packets.',
    items: ['UD-100, UD-105, UD-110', 'SUM-130', 'Proof of service forms', 'Notice and response packets'],
    cite: 'California Code of Civil Procedure unlawful detainer provisions.'
  },
  {
    id: 'small-claims-document-preparation-california',
    title: 'Small claims, demand letters, and civil court forms',
    text: 'Preparation support for pre-suit demand letters, small claims, civil complaint packets, proof of service, fee waivers, and related California court documents.',
    items: ['Demand letter (pre-suit)', 'SC-100, SC-104, SC-120', 'CIV-100 and civil pleading forms', 'POS forms', 'FW-001 fee waiver'],
    cite: 'California small claims and civil procedure forms.'
  },
  {
    id: 'restraining-orders-california',
    title: 'Restraining order document preparation',
    text: 'Document preparation for California civil harassment, domestic violence, elder abuse, gun violence, and workplace violence restraining order packets.',
    items: ['CH-100', 'DV-100', 'EA-100', 'GV-100', 'WV-100'],
    cite: 'Court forms are prepared only at the client’s direction.'
  },
  {
    id: 'probate-document-preparation-california',
    title: 'Probate, small estate, and closing documents',
    text: 'California probate document preparation for estate petitions, notices, inventories, small estate affidavits, final distribution, final discharge, and related court packets.',
    items: ['DE-111, DE-121, DE-160, DE-221', 'DE-295 — Final discharge where applicable', 'Small estate affidavit', 'Final accounting / distribution packets'],
    cite: 'California Probate Code forms and procedures.'
  },
  {
    id: 'expungement-record-clearance-california',
    title: 'California expungement and record-cleanup packets',
    text: 'Document preparation for California dismissal / record-cleanup packets, including DUI and other eligible misdemeanor or felony cases, prepared from the client’s court records and instructions.',
    items: ['CR-180 — Petition for Dismissal', 'CR-181 — Order for Dismissal', 'MC-025 / MC-031 attachments', 'POS-030 / POS-040 proof of service', 'FW-001 fee waiver when applicable'],
    cite: 'California Courts describe record-cleanup options as complicated; eligibility and immigration consequences should be reviewed with an attorney when needed.'
  },
  {
    id: 'business-filings',
    title: 'Business filings and records',
    text: 'Document preparation for California business filings and supporting paperwork, including LLC, fictitious business name, and EIN-related paperwork.',
    items: ['LLC filing support', 'Fictitious business name forms', 'EIN application support', 'Business record preparation'],
    cite: 'Business documents prepared at client direction.'
  },
  {
    id: 'document-translation-california',
    title: 'Translations, notary, and document support',
    text: 'Multilingual document support for immigration and court packets, including certified translations (Russian, Ukrainian, Spanish, English), apostille coordination, mobile notary, and full filing-package assembly.',
    items: [
      'Russian / Ukrainian / Spanish ↔ English certified translation',
      'Birth, marriage, divorce, death certificates',
      'Diplomas, academic transcripts, professional licenses',
      'Court decisions, foreign judgments, affidavits',
      'Apostille coordination through CA Secretary of State',
      'Mobile notary — Sacramento metro and surrounding counties',
      'Notarization for USCIS / EOIR / California court packets',
      'Filing-package assembly, indexing, and final review',
      'Document organization for marriage-based and asylum evidence',
      'Same-day turnaround on most translations'
    ],
    cite: 'Translation support does not include legal advice.'
  }
];

interface ServiceItem {
  id: string;
  title: string;
  text: string;
  items: string[];
  cite: string;
}
interface Props {
  /** Filter to a specific subset of service IDs (e.g. only USCIS + EOIR). */
  include?: string[];
  /** Override the section heading and kicker. */
  kicker?: string;
  heading?: string;
  intro?: string;
  /** Override the per-service cards entirely (e.g. for localized pages). */
  servicesOverride?: ServiceItem[];
  /** Locale — used to localize internal page links (chips + plain items). */
  lang?: Locale;
}
const { include, kicker, heading, intro, servicesOverride, lang = 'en' } = Astro.props;

const SOURCE_NOTE: Record<string, string> = {
  en: 'Form names, numbers, and requirements shown here are general information from official government sources (USCIS, EOIR, California Courts, CA Secretary of State, IRS), provided for informational purposes only — not legal advice. You choose the forms; Imverica prepares them at your direction.',
  ru: 'Названия, номера и требования форм здесь — общая информация из официальных источников (USCIS, EOIR, суды Калифорнии, Secretary of State Калифорнии, IRS), только для ознакомления, не юридическая консультация. Формы выбираете вы; Imverica готовит их по вашему поручению.',
  uk: 'Назви, номери та вимоги форм тут — загальна інформація з офіційних джерел (USCIS, EOIR, суди Каліфорнії, Secretary of State Каліфорнії, IRS), лише для ознайомлення, не юридична консультація. Форми обираєте ви; Imverica готує їх за вашим дорученням.',
  es: 'Los nombres, números y requisitos de los formularios aquí son información general de fuentes oficiales (USCIS, EOIR, Cortes de California, Secretario de Estado de California, IRS), solo con fines informativos — no asesoría legal. Usted elige los formularios; Imverica los prepara bajo su dirección.'
};
const sourceNote = SOURCE_NOTE[lang] || SOURCE_NOTE.en;
const source = servicesOverride && servicesOverride.length ? servicesOverride : services;
const visible = include ? source.filter((s) => include.includes(s.id)) : source;
const finalKicker = kicker || 'California document preparation services';
const finalHeading = heading || 'USCIS, immigration court, and California civil document preparation';
const finalIntro = intro || 'Imverica Legal Solutions provides document preparation through California registered Legal Document Assistant and Immigration Consultant services. We prepare documents at the client’s direction across the categories below. We are not a law firm and do not provide legal advice.';

// Short mono kicker shown above each catalog card's title (design system).
const KICKERS: Record<string, string> = {
  'immigration-consultant-california': 'USCIS petitions',
  'eoir-documents': 'EOIR · immigration court',
  'document-translation-california': 'Translations · notary · support',
  'family-law-documents-california': 'Family law',
  'unlawful-detainer-document-preparation-california': 'Landlord · tenant',
  'small-claims-document-preparation-california': 'Small claims · civil',
  'restraining-orders-california': 'Protective orders',
  'probate-document-preparation-california': 'Probate · estates',
  'expungement-record-clearance-california': 'Record clearing',
  'business-filings': 'Business filings'
};

// Each bullet inside a service card becomes a clickable link to that
// form's prep page (or, when no dedicated page exists yet, the intake
// wizard preset to that form code). The splitItem helper understands:
//   "I-485 — Adjustment of Status"   → codes=['I-485'], rest='Adjustment of Status'
//   "FL-100, FL-110, FL-120, FL-150" → codes=[FL-100..150], rest=''
//   "Russian, Ukrainian, Spanish"    → no recognizable codes → plain text
// Each form code maps to a *content* destination — either the form's
// dedicated explainer page or the relevant section anchor. We never
// route directly to the intake wizard from these chips: the previous
// behaviour confused visitors who clicked an EOIR code expecting an
// explanation and were dropped into the I-918 / I-131 / EOIR-42 wizard
// for a form the schema may not even have. Use the wizard only when
// the user clicks "Start" on a dedicated page.
const FORM_LINKS: Record<string, string> = {
  // USCIS petitions with dedicated explainer pages
  'I-485': '/i-485-help',
  'I-130': '/i-130-family-petition',
  'I-130A': '/i-130-family-petition',
  'I-765': '/i-765-work-permit-help',
  'I-589': '/i-589-asylum-help',
  'N-400': '/n-400-citizenship-help',
  // USCIS forms with their own dedicated explainer page.
  'I-90': '/i-90-green-card-renewal',
  'I-539': '/i-539-change-of-status',
  // USCIS forms — each now has a dedicated explainer page (matching the
  // /i-485-help, /i-130-family-petition pattern). Clicking a chip goes
  // to the page with the form's purpose, requirements, package contents,
  // and a Start button — never directly into the intake wizard.
  'I-131': '/i-131-travel-document',
  'I-131A': '/i-131a-returning-resident',
  'I-864': '/i-864-affidavit-of-support',
  'I-864A': '/i-864a-household-member',
  'I-693': '/i-693-medical-examination',
  'I-751': '/i-751-remove-conditions',
  'I-824': '/i-824-action-on-approved-application',
  // EOIR series — each major form has its own dedicated page. EOIR-28
  // (notice of appearance) is generic and routes to the EOIR overview.
  'EOIR-28': '/eoir-immigration-court',
  'EOIR-29': '/eoir-29-notice-of-appeal',
  'EOIR-42A': '/eoir-42a-cancellation-lpr',
  'EOIR-42B': '/eoir-42b-cancellation-non-lpr',
  'EOIR-40': '/eoir-40-suspension-of-deportation',
  // California court / family / civil — dedicated pages
  'FL-100': '/fl',
  'FL-110': '/fl',
  'FL-120': '/fl',
  'FL-150': '/fl',
  'FL-300': '/fl',
  'FL-105': '/fl',
  'UCCJEA': '/fl',
  'FW-001': '/fw-001-fee-waiver',
  'SC-100': '/sc',
  'SC-104': '/sc',
  'SC-120': '/sc',
  'UD-100': '/california-unlawful-detainer',
  'UD-105': '/california-unlawful-detainer',
  'UD-110': '/california-unlawful-detainer',
  'SUM-130': '/california-unlawful-detainer',
  'CH-100': '/california-restraining-orders',
  'DV-100': '/california-restraining-orders',
  'EA-100': '/california-restraining-orders',
  'GV-100': '/california-restraining-orders',
  'WV-100': '/california-restraining-orders',
  'CR-180': '/california-expungement',
  'CR-181': '/california-expungement',
  'MC-025': '/california-expungement',
  'MC-031': '/california-expungement',
  'POS-030': '/california-expungement',
  'POS-040': '/california-expungement',
  'DE-111': '/california-probate',
  'DE-121': '/california-probate',
  'DE-160': '/california-probate',
  'DE-221': '/california-probate',
  'DE-295': '/california-probate'
};

function splitItem(raw: string): { codes: string[]; rest: string } {
  // "I-485 — Adjustment of Status" → codes=['I-485'], rest='Adjustment...'
  // "FL-100, FL-110, FL-120, FL-150" → multiple codes, no rest
  // "Russian, Ukrainian, Spanish, English support" → no codes
  const trimmed = String(raw || '').trim();
  const m = trimmed.match(/^([A-Z][\w-]*(?:\s*[,/]\s*[A-Z][\w-]*)*)\s*(?:[—–-]\s*)?(.*)$/);
  if (!m) return { codes: [], rest: trimmed };
  const codeText = m[1] || '';
  const rest = (m[2] || '').trim();
  const codes = codeText.split(/[,/]/).map((c) => c.trim()).filter((c) => /^[A-Z][\w-]*$/.test(c) && FORM_LINKS[c.toUpperCase()]);
  return { codes, rest };
}

// Plain bullet items (no form code) link to the most relevant page for
// that service. Wizard / same-page anchor links (starting with '/#') are
// left as-is; real page slugs are localized to the current locale so a
// Russian visitor lands on the Russian page, etc.
const SERVICE_HREF: Record<string, string> = {
  'immigration-consultant-california': '/#get-started',
  'eoir-documents': '/eoir-immigration-court',
  'document-translation-california': '/#get-started',
  'family-law-documents-california': '/fl',
  'unlawful-detainer-document-preparation-california': '/california-unlawful-detainer',
  'small-claims-document-preparation-california': '/sc',
  'restraining-orders-california': '/california-restraining-orders',
  'probate-document-preparation-california': '/california-probate',
  'expungement-record-clearance-california': '/california-expungement',
  'business-filings': '/business'
};
function pageHref(dest: string): string {
  if (!dest) return '/#get-started';
  if (dest.startsWith('/#') || dest.startsWith('http')) return dest;
  return localizedPathSafe(lang, dest);
}
---

<section class="svc-band" id="services-detail">
  <div class="svc-band-inner">
    <div class="svc-band-kicker">{finalKicker}</div>
    <div class="svc-band-cols">
      <h2>{finalHeading}</h2>
      <p>{finalIntro}</p>
    </div>
  </div>
</section>

<section class="svc-catalog">
  <div class="svc-inner">
    <div class="svc-grid">
      {visible.map((service) => (
        <article class="svc-card" id={service.id}>
          <div class="svc-card-kicker">{KICKERS[service.id] || finalKicker}</div>
          <h3>{service.title}</h3>
          <p>{service.text}</p>
          <ul class="svc-card-forms">
            {service.items.map((item) => {
              const { codes } = splitItem(item);
              const dest = (codes.length && FORM_LINKS[codes[0]]) || SERVICE_HREF[service.id] || '/#get-started';
              const label = item.replace(/\s+[—–]\s+/, ' ');
              return (
                <li>
                  <a href={pageHref(dest)}>{label}</a>
                </li>
              );
            })}
          </ul>
          <cite>{service.cite}</cite>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .svc-source-note {
    margin: 26px auto 0;
    max-width: 1200px;
    font-size: 12px;
    line-height: 1.6;
    color: #6b7a90;
  }
</style>
