---
const services = [
  {
    id: 'immigration-consultant-california',
    title: 'USCIS immigration document preparation',
    text: 'Full USCIS form package preparation for adjustment of status, work authorization, family petitions, naturalization, asylum, travel documents, green card replacement, and supporting affidavits.',
    items: [
      'I-485 — Adjustment of Status',
      'I-130 / I-130A — Petition for Alien Relative',
      'I-765 — Employment Authorization',
      'I-589 — Asylum & Withholding of Removal',
      'N-400 — Naturalization',
      'I-131 / I-131A — Travel Document / Re-entry Permit',
      'I-90 — Green Card Renewal / Replacement',
      'I-864 / I-864A — Affidavit of Support',
      'I-693 — Medical Examination submittal',
      'I-751 — Removal of Conditions on Residence',
      'I-539 — Change / Extend Non-immigrant Status',
      'I-824 — Action on Approved Application'
    ],
    cite: 'Documents are prepared at the client’s direction. We do not select forms or provide legal advice.'
  },
  {
    id: 'eoir-documents',
    title: 'EOIR immigration court documents',
    text: 'Document preparation for proceedings before the Executive Office for Immigration Review (EOIR) — motions, evidence packets, indexes, declarations, and applications for relief.',
    items: [
      'EOIR-28 — Notice of Entry of Appearance',
      'EOIR-29 — Notice of Appeal (BIA)',
      'EOIR-42A — Cancellation of Removal (LPR)',
      'EOIR-42B — Cancellation of Removal (Non-LPR)',
      'EOIR-40 — Suspension of Deportation',
      'Motion to reopen / reconsider packets',
      'Evidence packets, indexes, tabs',
      'Country-conditions evidence assembly',
      'Witness declarations & translation prep'
    ],
    cite: 'Court representation requires a licensed attorney or accredited representative.'
  },
  {
    id: 'family-law-documents-california',
    title: 'California family law document preparation',
    text: 'Petition, response, and supporting documents for California dissolution, legal separation, parentage, custody, support, and fee waiver matters.',
    items: ['FL-100, FL-110, FL-120, FL-150', 'FL-300 — Request for Order', 'FL-105 / UCCJEA', 'FW-001 — Request to Waive Court Fees'],
    cite: 'California Family Code and Judicial Council forms.'
  },
  {
    id: 'unlawful-detainer-document-preparation-california',
    title: 'Unlawful detainer document preparation',
    text: 'Landlord and tenant document preparation for California unlawful detainer matters, notices, answers, proof of service, and court packets.',
    items: ['UD-100, UD-105, UD-110', 'SUM-130', 'Proof of service forms', 'Notice and response packets'],
    cite: 'California Code of Civil Procedure unlawful detainer provisions.'
  },
  {
    id: 'small-claims-document-preparation-california',
    title: 'Small claims and civil court forms',
    text: 'Preparation support for small claims, civil complaint packets, proof of service, fee waivers, and related California court documents.',
    items: ['SC-100, SC-104, SC-120', 'CIV-100 and civil pleading forms', 'POS forms', 'FW-001 fee waiver'],
    cite: 'California small claims and civil procedure forms.'
  },
  {
    id: 'restraining-orders-california',
    title: 'Restraining order document preparation',
    text: 'Document preparation for California civil harassment, domestic violence, elder abuse, gun violence, and workplace violence restraining order packets.',
    items: ['CH-100', 'DV-100', 'EA-100', 'GV-100', 'WV-100'],
    cite: 'Court forms are prepared only at the client’s direction.'
  },
  {
    id: 'probate-document-preparation-california',
    title: 'Probate and small estate documents',
    text: 'California probate document preparation for estate petitions, notices, inventories, small estate affidavits, and related court packets.',
    items: ['DE-111, DE-121, DE-160, DE-221', 'Small estate affidavit', 'Probate hearing and notice packets'],
    cite: 'California Probate Code forms and procedures.'
  },
  {
    id: 'business-filings',
    title: 'Business filings and records',
    text: 'Document preparation for California business filings and supporting paperwork, including LLC, fictitious business name, and EIN-related paperwork.',
    items: ['LLC filing support', 'Fictitious business name forms', 'EIN application support', 'Business record preparation'],
    cite: 'Business documents prepared at client direction.'
  },
  {
    id: 'document-translation-california',
    title: 'Translations, notary, and document support',
    text: 'Multilingual document support for immigration and court packets, including translations, apostille coordination, notary support, and filing package organization.',
    items: ['Russian, Ukrainian, Spanish, English support', 'Certified translation coordination', 'Document organization', 'Filing package review'],
    cite: 'Translation support does not include legal advice.'
  }
];

interface ServiceItem {
  id: string;
  title: string;
  text: string;
  items: string[];
  cite: string;
}
interface Props {
  /** Filter to a specific subset of service IDs (e.g. only USCIS + EOIR). */
  include?: string[];
  /** Override the section heading and kicker. */
  kicker?: string;
  heading?: string;
  intro?: string;
  /** Override the per-service cards entirely (e.g. for localized pages). */
  servicesOverride?: ServiceItem[];
}
const { include, kicker, heading, intro, servicesOverride } = Astro.props;
const source = servicesOverride && servicesOverride.length ? servicesOverride : services;
const visible = include ? source.filter((s) => include.includes(s.id)) : source;
const finalKicker = kicker || 'California document preparation services';
const finalHeading = heading || 'USCIS, immigration court, and California civil document preparation';
const finalIntro = intro || 'Imverica Legal Solutions provides document preparation through California registered Legal Document Assistant and Immigration Consultant services. We prepare documents at the client’s direction across the categories below. We are not a law firm and do not provide legal advice.';

// Each bullet inside a service card becomes a clickable link to that
// form's prep page (or, when no dedicated page exists yet, the intake
// wizard preset to that form code). The splitItem helper understands:
//   "I-485 — Adjustment of Status"   → codes=['I-485'], rest='Adjustment of Status'
//   "FL-100, FL-110, FL-120, FL-150" → codes=[FL-100..150], rest=''
//   "Russian, Ukrainian, Spanish"    → no recognizable codes → plain text
// Each form code maps to a *content* destination — either the form's
// dedicated explainer page or the relevant section anchor. We never
// route directly to the intake wizard from these chips: the previous
// behaviour confused visitors who clicked an EOIR code expecting an
// explanation and were dropped into the I-918 / I-131 / EOIR-42 wizard
// for a form the schema may not even have. Use the wizard only when
// the user clicks "Start" on a dedicated page.
const FORM_LINKS: Record<string, string> = {
  // USCIS petitions with dedicated explainer pages
  'I-485': '/i-485-help',
  'I-130': '/i-130-family-petition',
  'I-130A': '/i-130-family-petition',
  'I-765': '/i-765-work-permit-help',
  'I-589': '/i-589-asylum-help',
  'N-400': '/n-400-citizenship-help',
  // USCIS forms without a dedicated page yet — link to the USCIS
  // service card so the visitor sees its scope in context.
  'I-131': '/immigration#immigration-consultant-california',
  'I-131A': '/immigration#immigration-consultant-california',
  'I-90': '/immigration#immigration-consultant-california',
  'I-864': '/immigration#immigration-consultant-california',
  'I-864A': '/immigration#immigration-consultant-california',
  'I-693': '/immigration#immigration-consultant-california',
  'I-751': '/immigration#immigration-consultant-california',
  'I-539': '/immigration#immigration-consultant-california',
  'I-824': '/immigration#immigration-consultant-california',
  // EOIR series — all route to the EOIR card on the immigration page,
  // not the wizard (the wizard has no EOIR-* flow).
  'EOIR-28': '/immigration#eoir-documents',
  'EOIR-29': '/immigration#eoir-documents',
  'EOIR-42A': '/immigration#eoir-documents',
  'EOIR-42B': '/immigration#eoir-documents',
  'EOIR-40': '/immigration#eoir-documents',
  // California court / family / civil — dedicated pages
  'FL-100': '/fl',
  'FL-110': '/fl',
  'FL-120': '/fl',
  'FL-150': '/fl',
  'FL-300': '/fl',
  'FL-105': '/fl',
  'UCCJEA': '/fl',
  'FW-001': '/fl',
  'SC-100': '/sc',
  'SC-104': '/sc',
  'SC-120': '/sc',
  'UD-100': '/california-unlawful-detainer',
  'UD-105': '/california-unlawful-detainer',
  'UD-110': '/california-unlawful-detainer',
  'SUM-130': '/california-unlawful-detainer',
  'CH-100': '/california-restraining-orders',
  'DV-100': '/california-restraining-orders',
  'EA-100': '/california-restraining-orders',
  'GV-100': '/california-restraining-orders',
  'WV-100': '/california-restraining-orders',
  'DE-111': '/california-probate',
  'DE-121': '/california-probate',
  'DE-160': '/california-probate',
  'DE-221': '/california-probate'
};

function splitItem(raw: string): { codes: string[]; rest: string } {
  // "I-485 — Adjustment of Status" → codes=['I-485'], rest='Adjustment...'
  // "FL-100, FL-110, FL-120, FL-150" → multiple codes, no rest
  // "Russian, Ukrainian, Spanish, English support" → no codes
  const trimmed = String(raw || '').trim();
  const m = trimmed.match(/^([A-Z][\w-]*(?:\s*[,/]\s*[A-Z][\w-]*)*)\s*(?:[—–-]\s*)?(.*)$/);
  if (!m) return { codes: [], rest: trimmed };
  const codeText = m[1] || '';
  const rest = (m[2] || '').trim();
  const codes = codeText.split(/[,/]/).map((c) => c.trim()).filter((c) => /^[A-Z][\w-]*$/.test(c) && FORM_LINKS[c.toUpperCase()]);
  return { codes, rest };
}
---

<section class="svc-section" id="services-detail">
  <div class="svc-inner">
    <div class="svc-kicker">{finalKicker}</div>
    <h2>{finalHeading}</h2>
    <p>{finalIntro}</p>
    <div class="svc-grid">
      {visible.map((service) => (
        <article class="svc-card" id={service.id}>
          <h3>{service.title}</h3>
          <p>{service.text}</p>
          <ul class="svc-card-forms">
            {service.items.map((item) => {
              const { codes, rest } = splitItem(item);
              if (!codes.length) {
                return <li class="svc-card-plain">{item}</li>;
              }
              if (codes.length === 1) {
                const code = codes[0];
                return (
                  <li>
                    <a href={FORM_LINKS[code]}>
                      <span class="svc-card-code">{code}</span>
                      {rest && <span class="svc-card-rest">{rest}</span>}
                    </a>
                  </li>
                );
              }
              return (
                <li class="svc-card-multi">
                  <span class="svc-card-multi-chips">
                    {codes.map((c) => (
                      <a href={FORM_LINKS[c]} class="svc-card-pill">
                        <span class="svc-card-code">{c}</span>
                      </a>
                    ))}
                  </span>
                  {rest && <span class="svc-card-rest">{rest}</span>}
                </li>
              );
            })}
          </ul>
          <cite>{service.cite}</cite>
        </article>
      ))}
    </div>
  </div>
</section>
