---

<section class="svc-section" id="services-detail">
  <div class="svc-inner">
    <div class="svc-kicker">California document preparation services</div>
    <h2>USCIS, immigration court, and California civil document preparation</h2>
    <p>
      Imverica Legal Solutions provides document preparation through California registered Legal Document Assistant and Immigration Consultant services. We prepare documents at the client’s direction across the categories below. We are not a law firm and do not provide legal advice.
    </p>
    <div class="svc-grid">
      {services.map((service) => (
        <article class="svc-card" id={service.id}>
          <h3>{service.title}</h3>
          <p>{service.text}</p>
          <ul>
            {service.items.map((item) => <li>{item}</li>)}
          </ul>
          <cite>{service.cite}</cite>
        </article>
      ))}
    </div>
  </div>
</section>
