    'FW-001': { en: 'Court Fee Waiver', ru: 'Освобождение от пошлины', uk: 'Звільнення від мита', es: 'Exención de Cuota Judicial' },
    'LLC-1': { en: 'Form a California LLC', ru: 'Открыть LLC в Калифорнии', uk: 'Відкрити LLC у Каліфорнії', es: 'Formar LLC en California' },
