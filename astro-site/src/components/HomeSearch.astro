    'FL-100': { en: 'Divorce / Dissolution', ru: 'Расторжение брака', uk: 'Розлучення', es: 'Divorcio / Disolución' },
    'FL-120': { en: 'Response to Divorce', ru: 'Ответ на иск о разводе', uk: 'Відповідь на позов про розлучення', es: 'Respuesta al Divorcio' },
    'FL-150': { en: 'Income & Expense Declaration', ru: 'Декларация доходов и расходов', uk: 'Декларація доходів і витрат', es: 'Declaración de Ingresos y Gastos' },
    'FL-160': { en: 'Property Declaration', ru: 'Раздел имущества', uk: 'Поділ майна', es: 'Declaración de Bienes' },
    'FL-300': { en: 'Request for Order (custody / support)', ru: 'Запрос суда (опека / алименты)', uk: 'Запит до суду (опіка / аліменти)', es: 'Solicitud al Tribunal (custodia / pensión)' },
    'FL-105': { en: 'UCCJEA (child custody jurisdiction)', ru: 'UCCJEA — юрисдикция по опеке', uk: 'UCCJEA — юрисдикція з опіки', es: 'UCCJEA' },
    'SC-100': { en: 'Small Claims Plaintiff', ru: 'Малые иски (истец)', uk: 'Малі позови (позивач)', es: 'Reclamos Menores (Demandante)' },
    'SC-120': { en: 'Small Claims — Defendant', ru: 'Малые иски — встречный иск', uk: 'Малі позови — зустрічний позов', es: 'Reclamos Menores — Demandado' },
