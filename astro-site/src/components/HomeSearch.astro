    'TRANSLATION': { en: 'Certified Document Translation', ru: 'Заверенный перевод документа', uk: 'Засвідчений переклад документа', es: 'Traducción Certificada' },
    'NOTARY': { en: 'Notary Service', ru: 'Нотариальное заверение', uk: 'Нотаріальне засвідчення', es: 'Servicio Notarial' },
    'G-639': { en: 'FOIA — USCIS Records Request', ru: 'FOIA — запрос иммиграционных записей', uk: 'FOIA — запит імміграційних записів', es: 'FOIA — Solicitud de Archivo USCIS' },
    'NC-100': { en: 'Legal Name Change (California)', ru: 'Юридическая смена имени (Калифорния)', uk: 'Юридична зміна імені (Каліфорнія)', es: 'Cambio Legal de Nombre' },
    'DMV': { en: 'California DMV forms (license / title)', ru: 'Документы DMV Калифорнии (права / тайтл)', uk: 'Документи DMV Каліфорнії (права / тайтл)', es: 'Formularios DMV de California' },
    'DS-11': { en: 'U.S. Passport (new)', ru: 'Паспорт США (новый)', uk: 'Паспорт США (новий)', es: 'Pasaporte de EE. UU. (nuevo)' },
    'DS-82': { en: 'U.S. Passport (renewal)', ru: 'Паспорт США (продление)', uk: 'Паспорт США (поновлення)', es: 'Pasaporte de EE. UU. (renovación)' },
    'EOIR-29': { en: 'Notice of Appeal to BIA', ru: 'Апелляция в BIA', uk: 'Апеляція до BIA', es: 'Apelación al BIA' },
    'EOIR-42A': { en: 'Cancellation of Removal (LPR)', ru: 'Cancellation of Removal для LPR', uk: 'Cancellation of Removal для LPR', es: 'Cancelación de Remoción (LPR)' },
    'EOIR-42B': { en: 'Cancellation of Removal (non-LPR)', ru: 'Cancellation of Removal для non-LPR', uk: 'Cancellation of Removal для non-LPR', es: 'Cancelación de Remoción (no-LPR)' }
  };

  // Per-language sentence templates so the answer feels native, not
  // machine-translated. Plain text — no HTML — the page renders them.
  // Informational framing only — an LDA/Immigration Consultant may NOT tell a
  // client which form they "need" (that is choosing the form for them = UPL).
  // Present forms as commonly-associated options; the client decides; always
  // carry the not-legal-advice line.
  const ANSWER_TEMPLATE: Record<string, string> = {
    en: 'Documents commonly used for situations like this include <strong>{form}</strong> — {name}. You decide which form to file; Imverica prepares it at your direction. General information, not legal advice.',
    ru: 'Для подобных ситуаций часто используют форму <strong>{form}</strong> — {name}. Какую форму подавать — решаете вы; Imverica готовит её по вашему поручению. Общая информация, не юридическая консультация.',
    uk: 'Для подібних ситуацій часто використовують форму <strong>{form}</strong> — {name}. Яку форму подавати — вирішуєте ви; Imverica готує її за вашим дорученням. Загальна інформація, не юридична консультація.',
    es: 'Para situaciones como esta se suele usar el formulario <strong>{form}</strong> — {name}. Usted decide qué formulario presentar; Imverica lo prepara bajo su dirección. Información general, no asesoría legal.'
  };
  const LOW_CONFIDENCE_TEMPLATE: Record<string, string> = {
    en: 'Based on what you wrote, a related form may be <strong>{form}</strong> ({name}). You decide what to file — tap Continue to refine, or contact us. General information, not legal advice.',
    ru: 'Судя по описанию, к теме может относиться форма <strong>{form}</strong> ({name}). Что подавать — решаете вы. Жмите «Продолжить» или свяжитесь с нами. Общая информация, не юридическая консультация.',
    uk: 'Судячи з опису, до теми може стосуватися форма <strong>{form}</strong> ({name}). Що подавати — вирішуєте ви. Натисніть «Продовжити» або зв’яжіться з нами. Загальна інформація, не юридична консультація.',
    es: 'Según lo que escribió, un formulario relacionado puede ser <strong>{form}</strong> ({name}). Usted decide qué presentar — pulse Continuar o contáctenos. Información general, no asesoría legal.'
  };

  function setResult(html: string, open = true) {
    if (!result) return;
    result.innerHTML = html;
    result.classList.toggle('open', open);
  }

  function escapeHtml(value: unknown) {
    return String(value ?? '').replace(/[&<>"']/g, (character) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[character] || character));
  }

  function renderCountyPrompt(query: string, routeData: any, lang: keyof typeof labels) {
    const t = labels[lang] || labels.en;
    const counties = Array.isArray(routeData?.counties) ? routeData.counties : [];
    const mismatch = routeData?.countyMismatch ? `<p class="ai-county-warning">${t.countyMismatch}</p>` : '';
    const options = counties.map((county: any) =>
      `<option value="${escapeHtml(county.slug)}">${escapeHtml(county.name)} County</option>`
    ).join('');
    setResult(`
      ${mismatch}
      <div class="ai-county-step">
        <label for="aiCountySelect">${t.countyQuestion}</label>
        <p>${t.countyHelp}</p>
        <div class="ai-county-controls">
          <select id="aiCountySelect" data-ai-county>
            <option value="">${t.countyPlaceholder}</option>
            ${options}
          </select>
          <button type="button" class="dark" data-ai-county-continue disabled>${t.countyContinue}</button>
        </div>
      </div>
    `);
    const select = result?.querySelector('[data-ai-county]') as HTMLSelectElement | null;
    const button = result?.querySelector('[data-ai-county-continue]') as HTMLButtonElement | null;
    select?.addEventListener('change', () => { if (button) button.disabled = !select.value; });
    button?.addEventListener('click', () => { if (select?.value) submitQuery(query, select.value); });
  }

  // Fire-and-forget analytics beacon — never blocks or breaks the UX.
  function logSearchEvent(type: 'search' | 'start', query: string, formCode: string, confidence: number) {
    try {
      const payload = JSON.stringify({ type, query: query.slice(0, 200), lang: detectLang(query), formCode, confidence });
      if (navigator.sendBeacon) navigator.sendBeacon('/api/analytics', new Blob([payload], { type: 'application/json' }));
      else fetch('/api/analytics', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
    } catch { /* analytics must never break search */ }
  }

  function continueToWizard(query: string, formCode = '') {
    logSearchEvent('start', query, '', 0);
    const opener = (window as Window & { openIntakeModal?: (prefill?: string, options?: { formCode?: string }) => void }).openIntakeModal;
    if (typeof opener === 'function') {
      opener(query, formCode ? { formCode } : undefined);
      return;
    }
    window.location.hash = 'get-started';
  }

  async function submitQuery(query: string, county = '') {
    const lang = detectLang(query);
    const t = labels[lang] || labels.en;
    setResult(`<p>${t.checking}</p>`);

    // Primary: our deterministic catalog router (/api/route). 35 multilang
    // rules cover all major USCIS / EOIR / family / civil / business /
    // probate forms — runs in <100ms, no AI cost, never times out. We
    // ALSO kick off the chat call in parallel so we can append an AI
    // explanation paragraph when it succeeds, but if chat 502s the user
    // still gets a working answer.
    const routePromise = fetch(routeEndpoint(query, county), {
      headers: { 'Accept': 'application/json' }
    }).then((r) => (r.ok ? r.json() : null)).catch(() => null);

    const routeData = await routePromise;
    if (routeData?.needsCounty) {
      renderCountyPrompt(query, routeData, lang);
      return;
    }
    const countyName = String(routeData?.county?.name || routeData?.route?.county || '').trim();
    const countySlug = String(routeData?.county?.slug || routeData?.route?.countySlug || '').trim();
    if (countySlug) {
      try {
        localStorage.setItem('imverica_court_county', countySlug);
        localStorage.setItem('imverica_court_route', JSON.stringify({
          county: countyName,
          countySlug,
          formCode: routeData?.route?.formCode || '',
          localFormId: routeData?.route?.localFormId || ''
        }));
      } catch { /* Storage may be unavailable in privacy-restricted browsers. */ }
    }
    const enrichedQuery = countyName ? `${query}\nFiling county: ${countyName} County, California.` : query;
    const chatPromise = fetch(chatEndpoint(), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: [{ role: 'user', content: enrichedQuery }] })
    }).then((r) => (r.ok ? r.json() : null)).catch(() => null);
    const formCode = String(routeData?.route?.formCode || '').toUpperCase();
    const confidence = Number(routeData?.route?.confidence || 0);
    logSearchEvent('search', query, formCode, confidence);
    const matched = FORM_NAMES[formCode];
    const routedTitle = String(routeData?.route?.formTitle || '').trim();

    if (formCode && (matched || routedTitle)) {
      const tmpl = confidence >= 0.7 ? ANSWER_TEMPLATE[lang] : LOW_CONFIDENCE_TEMPLATE[lang];
      const name = matched
        ? (matched[lang as 'en' | 'ru' | 'uk' | 'es'] || matched.en)
        : routedTitle;
      const headline = (tmpl || ANSWER_TEMPLATE.en)
        .replace('{form}', formCode)
        .replace('{name}', name);

      // Render the catalog answer immediately, then asynchronously append
      // the AI elaboration once chat finishes (if it ever does).
      const countyLine = countyName ? `<p class="ai-result-county">${t.filingCourt}: <strong>${escapeHtml(countyName)} County Superior Court</strong></p>` : '';
      setResult(`
        <p>${headline}</p>
        ${countyLine}
        <p id="aiExtra" class="ai-result-extra"></p>
        <div class="ai-result-actions">
          <button type="button" class="dark" data-ai-continue>${t.continue}</button>
          <a href="https://t.me/imverica" target="_blank" rel="noopener">${t.telegram}</a>
          <a href="tel:+19163993992">${t.call}</a>
        </div>
      `);
      result?.querySelector('[data-ai-continue]')?.addEventListener('click', () => continueToWizard(enrichedQuery, formCode));

      const chatData = await chatPromise;
      const reply = String(chatData?.reply || '').trim();
      const extra = document.getElementById('aiExtra');
      if (reply && extra) extra.innerHTML = reply.replace(/\n/g, '<br>');
      return;
    }

    // Catalog router couldn't identify the form — fall back to chat-only.
    const chatData = await chatPromise;
    const answer = String(chatData?.reply || chatData?.answer || '').trim();
    if (answer) {
      setResult(`
        <p>${answer.replace(/\n/g, '<br>')}</p>
        <div class="ai-result-actions">
          <button type="button" class="dark" data-ai-continue>${t.continue}</button>
          <a href="https://t.me/imverica" target="_blank" rel="noopener">${t.telegram}</a>
          <a href="tel:+19163993992">${t.call}</a>
        </div>
      `);
      result?.querySelector('[data-ai-continue]')?.addEventListener('click', () => continueToWizard(enrichedQuery));
      return;
    }

    // Both router and chat returned nothing usable — last-resort error.
    setResult(`<p>${t.error}</p>`);
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const query = input?.value?.trim();
    if (!query) return;
    submitQuery(query);
  });

  input?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter' && !event.shiftKey) {
      event.preventDefault();
      form?.requestSubmit();
    }
  });

  document.querySelectorAll('[data-ai-example]').forEach((button) => {
    button.addEventListener('click', () => {
      const value = button.getAttribute('data-ai-example') || '';
      if (input) input.value = value;
      submitQuery(value);
    });
  });
</script>
