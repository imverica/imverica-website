      continue: 'Continuar',
      telegram: 'Telegram',
      call: 'Llamar +1 (916) 399-3992'
    }
  };

  function detectLang(value: string) {
    const text = String(value || '').toLowerCase();
    if (/[іїєґ]/i.test(text)) return 'uk';
    if (/[а-яё]/i.test(text)) return 'ru';
    if (/[ñáéíóúü¿¡]/i.test(text)) return 'es';
    return 'en';
  }

  function chatEndpoint() {
    const isLocal = ['localhost', '127.0.0.1', ''].includes(window.location.hostname) || window.location.protocol === 'file:';
    return isLocal ? 'https://imverica.com/.netlify/functions/chat' : '/.netlify/functions/chat';
  }

  function routeEndpoint(query: string, county = '') {
    const isLocal = ['localhost', '127.0.0.1', ''].includes(window.location.hostname) || window.location.protocol === 'file:';
    const base = isLocal ? 'https://imverica.com' : '';
    return base + '/.netlify/functions/route?q=' + encodeURIComponent(query) + (county ? '&county=' + encodeURIComponent(county) : '');
  }

  // Human-friendly form name lookup for the answer card. Keeps the wizard
  // independent of the network — when the AI chat is slow / down / over
  // quota, we still tell the user which form we'll prepare.
