---
import { STATS, type Locale } from '~/data/i18n';

interface Props {
  lang?: Locale;
}
const { lang = 'en' } = Astro.props;
const labels = STATS[lang];

/*
  Auto-growing targets:
  - "Forms supported"   — base 734, +2 every 7 days (1 week)
  - "Priority forms"    — base 18,  +1 every 60 days (~2 months)
  Baseline = 2026-05-25 (when the user set this rule). At build time we
  bump the value forward by the elapsed weeks/2-month windows so the
  numbers grow on their own without manual edits.
*/
const BASE_DATE = Date.UTC(2026, 4, 25); // May = month 4 (0-indexed)
const now = Date.now();
const days = Math.max(0, Math.floor((now - BASE_DATE) / (24 * 60 * 60 * 1000)));
// Auto-growth: forms supported now ticks up by +1 every ~2.5 days
// (5 forms every 12 days keeps the integer arithmetic clean), and the
// priority-flows counter still gains +1 every two months.
const formsTarget = 734 + Math.floor(days * 2 / 5);
const priorityTarget = 18 + Math.floor(days / 60);

const items = [
  { target: formsTarget, suffix: '+', label: labels[0] },
  { target: priorityTarget, suffix: '+', label: labels[1] },
  { target: 4, suffix: '', label: labels[2] },
  { target: 10, suffix: '+', label: labels[3] }
];
---
<section class="stats-strip">
  <div class="stats-inner">
    {items.map((s) => (
      <div class="stat-item">
        <div class="stat-number">
          <span data-stat-target={s.target}>{s.target}</span>
          {s.suffix && <span style="font-size:0.55em;color:#a45b34;">{s.suffix}</span>}
        </div>
        <div class="stat-label">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<script>
  function runStatCounters() {
    const nums = document.querySelectorAll<HTMLElement>('[data-stat-target]');
    if (!nums.length) return;

    const animate = (el: HTMLElement) => {
      const target = Number(el.getAttribute('data-stat-target') || '0');
      // Start the count-up from 0 only when the number is animated.
      el.textContent = '0';
      const duration = 1200;
      const start = performance.now();
      const step = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        // easeOutQuad
        const eased = 1 - (1 - progress) * (1 - progress);
        el.textContent = String(Math.round(eased * target));
        if (progress < 1) requestAnimationFrame(step);
        else el.textContent = String(target);
      };
      requestAnimationFrame(step);
    };

    if (!('IntersectionObserver' in window)) {
      nums.forEach(animate);
      return;
    }

    // Animate on first paint for any stat already in view (no scroll needed).
    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          animate(entry.target as HTMLElement);
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -5% 0px' });

    nums.forEach((el) => observer.observe(el));
  }

  runStatCounters();
  document.addEventListener('astro:after-swap', runStatCounters);
</script>
