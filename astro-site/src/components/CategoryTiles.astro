---
import { priceForTitle } from '~/data/prices';
/**
 * Generic category-tile grid (same shell as ImmigrationCategories), used on
 * Family Law / Small Claims / Business / About pages so each section has a
 * consistent visual entry-point. Tiles fade in on scroll because the .cat-tile
 * class is wired into the global reveal observer in BaseLayout.
 *
 * Props: kicker, heading, intro (already-translated by the parent page),
 * tiles[] with { icon (emoji), title, desc, href, color (CSS var or hex) }.
 */
interface Tile {
  icon: string;
  title: string;
  desc: string;
  href: string;
  color?: string;
  /** Explicit price-chip text (e.g. "from $449"). Falls back to priceForTitle(title). */
  price?: string;
}
interface Props {
  kicker?: string;
  heading?: string;
  intro?: string;
  tiles: Tile[];
}
const { kicker, heading, intro, tiles } = Astro.props as Props;

---
<section class="cat-tiles-section">
  <div class="cat-tiles-inner">
    {kicker && <div class="cat-tiles-kicker">{kicker}</div>}
    {heading && <h2 class="cat-tiles-h2">{heading}</h2>}
    {intro && <p class="cat-tiles-intro">{intro}</p>}
    <div class="cat-tiles-grid">
      {tiles.map((t) => {
        const di = t.title.indexOf(' — ');
        const code = di >= 0 ? t.title.slice(0, di) : '';
        const name = di >= 0 ? t.title.slice(di + 3) : t.title;
        const price = t.price || priceForTitle(t.title);
        return (
          <a class="cat-tile" href={t.href}>
            <div class="cat-tile-top">
              <span class="cat-tile-emoji" aria-hidden="true">{t.icon}</span>
              {code && <span class="cat-tile-code">{code}</span>}
            </div>
            <div class="cat-tile-title">{name}</div>
            <div class="cat-tile-desc">{t.desc}</div>
            <div class="cat-tile-foot">
              {price
                ? <span class="cat-tile-price">{price} · flat fee</span>
                : <span class="cat-tile-price cat-tile-price--ask">Flat fee · ask</span>}
              <span class="cat-tile-arrow" aria-hidden="true">→</span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .cat-tiles-section { padding: 40px 1.5rem var(--space-section); background: var(--paper); }
  .cat-tiles-inner { max-width: 1220px; margin: 0 auto; }
  .cat-tiles-kicker {
    font-family: var(--font-mono); font-size: 11.5px; font-weight: 500; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold-deep); margin-bottom: 18px; text-align: center;
  }
  .cat-tiles-h2 { font-size: var(--fs-h2); font-weight: 500; margin-bottom: 12px; text-align: center; }
  .cat-tiles-intro {
    color: var(--text-2); font-size: 16px; line-height: 1.6; margin: 0 auto 28px; max-width: 720px;
    text-align: center;
  }
  .cat-tiles-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  @media (max-width: 980px) { .cat-tiles-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .cat-tiles-grid { grid-template-columns: 1fr; } }
  .cat-tile {
    display: flex;
    flex-direction: column;
    min-height: 176px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .cat-tile:hover { transform: translateY(-3px); box-shadow: 0 22px 40px -26px rgba(20, 32, 46, 0.42); border-color: #D8C8A4; }
  .cat-tile-top { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 14px; }
  .cat-tile-emoji { font-size: 24px; line-height: 1; }
  .cat-tile-code { font-family: var(--font-mono); font-size: 12px; font-weight: 600; color: var(--gold-deep); }
  .cat-tile-title { font-family: var(--font-display); font-size: 19px; font-weight: 500; line-height: 1.14; letter-spacing: -0.01em; color: var(--navy-dark); margin-bottom: 8px; }
  .cat-tile-desc { font-size: 13px; line-height: 1.5; color: var(--text-3); flex: 1; }
  .cat-tile-foot { display: flex; align-items: center; justify-content: space-between; gap: 10px; border-top: 1px solid #EFE8DB; padding-top: 12px; margin-top: 14px; }
  .cat-tile-price { font-family: var(--font-mono); font-size: 11.5px; font-weight: 600; color: var(--gold-deep); }
  .cat-tile-price--ask { color: #9AA3AD; font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; font-size: 11px; }
  .cat-tile-arrow { color: var(--gold); font-size: 15px; }
</style>
