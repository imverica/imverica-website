---
import { NAV, LOCALES, SUPPORTED_LOCALES, localizedPathSafe, type Locale } from '~/data/i18n';

interface Props {
  lang?: Locale;
  /** Current page slug (e.g. '/i-485-help') — used to build correct alternate-language URLs in the language switcher. */
  currentSlug?: string;
}
const { lang = 'en', currentSlug = '/' } = Astro.props;

const t = NAV[lang];
const prefix = LOCALES[lang].prefix;
---
<header class="site-header">
  <div class="site-topbar" aria-label="Contact">
    <a href="tel:+19163993992">Call/Text +1 (916) 399-3992</a>
    <span>Document preparation only · No legal advice</span>
  </div>
  <div class="site-header-inner">
    <a class="site-brand" href={prefix + '/'} aria-label="Imverica Legal Solutions">
      <img class="site-brand-logo" src="/logo-nav.png" alt="Imverica Legal Solutions" width="279" height="92" />
    </a>
    <nav class="site-nav" aria-label="Main">
      <a href={prefix + '/#services-detail'}>{t.uscis}</a>
      <a href={localizedPathSafe(lang, '/california-family-law')}>{t.family}</a>
      <a href={localizedPathSafe(lang, '/california-small-claims')}>{t.civil}</a>
      <a href={prefix + '/#business-filings'}>{t.business}</a>
      <a href={localizedPathSafe(lang, '/california-legal-document-assistant')}>{t.about}</a>
      <a href="/account.html">{t.portal}</a>
    </nav>
    <div class="site-lang" aria-label="Language">
      {SUPPORTED_LOCALES.map((locale) => (
        <a
          href={localizedPathSafe(locale, currentSlug)}
          class={lang === locale ? 'active' : ''}
          aria-label={`${LOCALES[locale].label} language`}
        >
          <span class="site-lang-flag" aria-hidden="true">{LOCALES[locale].flag}</span>
          <span class="site-lang-label">{LOCALES[locale].label}</span>
        </a>
      ))}
    </div>
    <a class="btn btn-accent" href={prefix + '/#get-started'}>{t.quote}</a>
  </div>
</header>

<style>
  .site-topbar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    padding: 0.48rem 1rem;
    background: #111e30;
    color: #d8e6f6;
    font-size: 0.82rem;
    line-height: 1.3;
  }

  .site-topbar a {
    color: #fff;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-decoration: none;
  }

  .site-topbar a:hover {
    color: #f7d7b1;
  }

  @media (max-width: 720px) {
    .site-topbar {
      justify-content: space-between;
      gap: 0.75rem;
      font-size: 0.76rem;
    }

    .site-topbar span {
      text-align: right;
    }
  }
</style>
