---
import { NAV, LOCALES, SUPPORTED_LOCALES, localizedPath, localizedPathSafe, type Locale } from '~/data/i18n';

interface Props {
  lang?: Locale;
  /** Current page slug (e.g. '/i-485-help') — used to build correct alternate-language URLs in the language switcher. */
  currentSlug?: string;
  /** Locales with this exact slug available. Unsupported locale buttons fall back to that locale's homepage. */
  availableLocales?: Locale[];
}
const { lang = 'en', currentSlug = '/', availableLocales = SUPPORTED_LOCALES } = Astro.props;

const t = NAV[lang];
const prefix = LOCALES[lang].prefix;

// Map currentSlug → nav key so we can mark the active link with
// aria-current="page" and a visible underline pill. We match by prefix
// (e.g. /fl-100-divorce → 'family', /i-485-help → 'uscis') so detail
// pages still light up their parent category.
//   /about → main About-the-company page (nav link target)
//   /lda   → educational LDA explainer (also under "About" in the nav
//            so the indicator stays consistent if a visitor lands there)
//   /pricing → standalone pricing page
const slug = String(currentSlug || '/').toLowerCase();
function activeNav() {
  if (slug.startsWith('/pricing')) return 'pricing';
  if (slug.startsWith('/for-attorneys')) return 'for-attorneys';
  if (slug.startsWith('/about') || slug.startsWith('/lda')) return 'about';
  if (slug.startsWith('/business') || slug.startsWith('/llc') || slug.startsWith('/fbn')) return 'business';
  if (slug.startsWith('/sc') || slug.startsWith('/civil') || slug.startsWith('/california-name-change')) return 'civil';
  if (slug.startsWith('/criminal') || slug.startsWith('/california-expungement') || slug.startsWith('/expungement') || slug.startsWith('/record-clearing')) return 'criminal';
  if (slug.startsWith('/fl') || slug.startsWith('/family') || slug.startsWith('/california-divorce')) return 'family';
  if (slug.startsWith('/i-') || slug.startsWith('/n-') || slug.startsWith('/g-') || slug.startsWith('/immigration') || slug.startsWith('/eoir') || slug.startsWith('/uscis')) return 'uscis';
  return '';
}
const active = activeNav();
function localeHref(locale: Locale) {
  if (availableLocales.includes(locale)) return localizedPath(locale, currentSlug || '/');
  return localizedPath(locale, '/');
}
---
<header class="site-header">
  <div class="site-utility" aria-label="Utility">
    <div class="site-utility-inner">
      <div class="site-utility-left">
        <a class="site-utility-call" href="tel:+19163993992">
          <span class="site-utility-dot" aria-hidden="true">●</span><span class="site-utility-call-prefix">Call · </span>+1 (916) 399-3992
        </a>
        <span class="site-utility-pipe" aria-hidden="true">|</span>
        <a class="site-utility-sec" href="sms:+19163993992">Message Us</a>
        <span class="site-utility-pipe" aria-hidden="true">|</span>
        <a class="site-utility-sec" href={localizedPath(lang, '/schedule')}>{t.schedule}</a>
      </div>
      <div class="site-utility-right">
        <div class="site-utility-langs" aria-label="Language">
          {SUPPORTED_LOCALES.map((locale) => (
            <a
              href={localeHref(locale)}
              class={`site-utility-lang${lang === locale ? ' is-active' : ''}`}
              aria-label={`${LOCALES[locale].label} language`}
            >{LOCALES[locale].label}</a>
          ))}
        </div>
        <a class="site-utility-portal" href="/account.html" aria-label={t.portal}>
          <span aria-hidden="true">◔</span> <span class="site-utility-portal-label">{t.portal}</span>
        </a>
      </div>
    </div>
  </div>
  <div class="site-header-inner">
    <a class="site-brand" href={prefix + '/'} aria-label="Imverica Legal Solutions">
      <img class="site-brand-logo" src="/logo-nav.png" alt="Imverica Legal Solutions" width="279" height="92" />
    </a>
    <nav class="site-nav" aria-label="Main">
      <a href={localizedPathSafe(lang, '/immigration')} data-nav="uscis" aria-current={active === 'uscis' ? 'page' : undefined}>{t.uscis}</a>
      <a href={localizedPathSafe(lang, '/fl')} data-nav="family" aria-current={active === 'family' ? 'page' : undefined}>{t.family}</a>
      <a href={localizedPathSafe(lang, '/sc')} data-nav="civil" aria-current={active === 'civil' ? 'page' : undefined}>{t.civil}</a>
      <a href={localizedPathSafe(lang, '/criminal')} data-nav="criminal" aria-current={active === 'criminal' ? 'page' : undefined}>{t.criminal}</a>
      <a href={localizedPathSafe(lang, '/business')} data-nav="business" aria-current={active === 'business' ? 'page' : undefined}>{t.business}</a>
      <a href={localizedPathSafe(lang, '/pricing')} data-nav="pricing" aria-current={active === 'pricing' ? 'page' : undefined}>{t.pricing}</a>
      <a href={localizedPathSafe(lang, '/for-attorneys')} data-nav="for-attorneys" class="site-nav-accent" aria-current={active === 'for-attorneys' ? 'page' : undefined}>{t.forAttorneys}</a>
      <a href={localizedPathSafe(lang, '/about')} data-nav="about" aria-current={active === 'about' ? 'page' : undefined}>{t.about}</a>
    </nav>
    <a class="btn btn-accent site-quote" href={prefix + '/#get-started'}>{t.quote} →</a>
    <button class="site-burger" id="siteBurger" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="siteMobileMenu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="site-mobile-menu" id="siteMobileMenu" aria-label="Mobile navigation" hidden>
    <a href={localizedPathSafe(lang, '/immigration')}>{t.uscis}</a>
    <a href={localizedPathSafe(lang, '/fl')}>{t.family}</a>
    <a href={localizedPathSafe(lang, '/sc')}>{t.civil}</a>
    <a href={localizedPathSafe(lang, '/criminal')}>{t.criminal}</a>
    <a href={localizedPathSafe(lang, '/business')}>{t.business}</a>
    <a href={localizedPathSafe(lang, '/pricing')}>{t.pricing}</a>
    <a href={localizedPathSafe(lang, '/for-attorneys')}>{t.forAttorneys}</a>
    <a href={localizedPathSafe(lang, '/about')}>{t.about}</a>
    <a href="sms:+19163993992">💬 Message Us</a>
    <a href={localizedPath(lang, '/schedule')}>▣ {t.schedule}</a>
    <a href="/account.html">👤 {t.portal}</a>
    <a class="btn btn-accent" href={prefix + '/#get-started'}>{t.quote}</a>
  </nav>
</header>

<script>
  (function () {
    var burger = document.getElementById('siteBurger');
    var menu = document.getElementById('siteMobileMenu');
    if (!burger || !menu) return;
    var burgerEl = burger;
    var menuEl = menu;
    function setOpen(open: boolean) {
      menuEl.hidden = !open;
      burgerEl.setAttribute('aria-expanded', open ? 'true' : 'false');
      burgerEl.classList.toggle('open', open);
    }
    burgerEl.addEventListener('click', function () {
      setOpen(menuEl.hidden);
    });
    // Close when a link is tapped or on Escape.
    menuEl.addEventListener('click', function (e) {
      if (e.target instanceof HTMLAnchorElement) setOpen(false);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') setOpen(false);
    });
  })();
</script>

<style>
  /* Top utility bar — contact links (left) + language pills & Client Portal
     (right), sitting ABOVE the main nav as in the brand design. */
  .site-utility {
    background: #11202E;
    color: #C9D2DC;
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0.01em;
  }
  .site-utility-inner {
    max-width: 1480px;
    margin: 0 auto;
    padding: 9px 0.9rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .site-utility-left { display: flex; align-items: center; gap: 14px; min-width: 0; }
  .site-utility-left a { color: #C9D2DC; text-decoration: none; white-space: nowrap; }
  .site-utility-left a:hover, .site-utility-portal:hover { color: #f7d7b1; }
  .site-utility-call { color: #EBE2CE; font-weight: 600; display: inline-flex; align-items: center; gap: 7px; }
  .site-utility-dot { color: var(--gold); font-size: 9px; }
  .site-utility-pipe { opacity: 0.35; }
  .site-utility-right { display: flex; align-items: center; gap: 14px; flex-shrink: 0; }
  .site-utility-langs {
    display: flex;
    align-items: center;
    gap: 3px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    padding: 3px;
  }
  .site-utility-lang {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: 999px;
    padding: 5px 11px;
    color: #9AA8B4;
    text-decoration: none;
  }
  .site-utility-lang:hover { color: #EBE2CE; }
  .site-utility-lang.is-active { background: var(--gold); color: #11202E; }
  .site-utility-portal { color: #EBE2CE; font-weight: 600; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; white-space: nowrap; }
  .site-utility-portal span[aria-hidden] { font-size: 13px; }

  @media (max-width: 760px) {
    .site-utility { font-size: 11.5px; }
    .site-utility-inner { padding: 7px 0.85rem; gap: 10px; }
    .site-utility-sec, .site-utility-pipe { display: none; }
    .site-utility-portal-label { display: none; }
  }
  @media (max-width: 430px) {
    .site-utility-call-prefix { display: none; }
  }
</style>
