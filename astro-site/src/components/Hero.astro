---
import { CTA as CTA_STRINGS, type Locale } from '~/data/i18n';

interface Props {
  eyebrow?: string;
  heading: string;
  sub?: string;
  ctaPrimary?: { href: string; text: string };
  ctaSecondary?: { href: string; text: string };
  lang?: Locale;
  showActions?: boolean;
  /** Social-proof pill rendered above the eyebrow (CourtLinked-style). */
  trustPill?: string;
}
const { eyebrow, heading, sub, ctaPrimary, ctaSecondary, lang = 'en', showActions = true, trustPill } = Astro.props;
// Defaults pulled from the i18n table when caller omits CTAs.
const defaultPrimary = { href: '/#get-started', text: CTA_STRINGS[lang].startBtn };
const defaultSecondary = { href: 'tel:+19163993992', text: '📞 +1 (916) 399-3992' };
const primary = ctaPrimary || defaultPrimary;
const secondary = ctaSecondary || defaultSecondary;
---
<section class="hero-wrap">
  <div class="hero">
    {trustPill && <div class="hero-pill"><span aria-hidden="true">★</span> {trustPill} <span aria-hidden="true">★</span></div>}
    {eyebrow && <div class="hero-eyebrow">{eyebrow}</div>}
    <h1>{heading}</h1>
    {sub && <p class="hero-sub">{sub}</p>}
    {showActions && (
      <div class="hero-actions">
        <a class="btn btn-accent" href={primary.href}>{primary.text}</a>
        <a class="btn btn-ghost" href={secondary.href}>{secondary.text}</a>
      </div>
    )}
    <slot />
  </div>
</section>
