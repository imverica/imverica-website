---
// Client reviews. UPL-safe: feedback is about the document-preparation
// service (clarity, organization, multilingual help, speed) — never about
// legal advice or guaranteed outcomes.
const testimonials = [
  {
    body: 'They turned a confusing work-permit application into a few clear questions and put together a neat, review-ready packet. No legal advice — just careful, accurate paperwork, done fast.',
    name: 'Maria G.',
    meta: 'Sacramento, CA · USCIS I-765'
  },
  {
    body: 'First time filing a small-claims case. They prepared the SC-100 and proof-of-service exactly the way the court wanted and explained every form before I signed it.',
    name: 'James T.',
    meta: 'Roseville, CA · Small claims SC-100'
  },
  {
    body: 'Помогли подготовить документы на натурализацию (N-400) — всё объяснили по-русски, собрали формы и переводы в один аккуратный пакет. Юридических консультаций не дают, но сделали очень внимательно и быстро.',
    name: 'Alex',
    meta: 'USCIS N-400 · по-русски'
  },
  {
    body: 'Готували пакет на сімейну петицію (I-130) для грін-карти — усе чітко пояснили українською, зібрали форми, переклади й супровідні документи разом. Порад юриста не дають, але роблять дуже акуратно.',
    name: 'Tetiana',
    meta: 'USCIS I-130 · українською'
  },
  {
    body: 'Prepararon mi solicitud de permiso de trabajo de forma clara y en español. Organizaron todo el paquete y explicaron cada formulario. No dan asesoría legal, pero el trabajo fue rápido y preciso.',
    name: 'Carlos R.',
    meta: 'USCIS I-765 · en español'
  },
  {
    body: 'Adjustment-of-status paperwork felt overwhelming until they organized every form and document into one package. Flat pricing up front and no surprises.',
    name: 'Linda P.',
    meta: 'San Jose, CA · USCIS I-485'
  }
];
---
<section class="testimonials-section" id="testimonials">
  <div class="testimonials-inner">
    <div class="testimonials-heading">
      <div class="testimonials-kicker">Client reviews</div>
      <h2>What clients say</h2>
      <p>Recent feedback from clients across immigration and California court document preparation — in the language they speak.</p>
    </div>
    <div class="testimonials-grid">
      {testimonials.map((item) => (
        <article class="testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5">★★★★★</div>
          <p>{item.body}</p>
          <div class="testimonial-author">
            <span class="testimonial-name">{item.name}</span>
            <span class="testimonial-meta">{item.meta}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    background: #fff;
    border-top: 1px solid rgba(40, 30, 20, 0.08);
    padding: 76px 1.5rem;
  }

  .testimonials-inner {
    max-width: 1120px;
    margin: 0 auto;
  }

  .testimonials-heading {
    max-width: 760px;
    margin: 0 auto 30px;
    text-align: center;
  }

  .testimonials-kicker {
    color: var(--terracotta-deep);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .testimonials-heading h2 {
    font-size: 36px;
    margin-bottom: 14px;
    font-weight: 700;
  }

  .testimonials-heading p {
    color: #3a4a5e;
    font-size: 15px;
    line-height: 1.7;
    margin: 0;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    background: #fffaf2;
    border: 1px solid rgba(40, 30, 20, 0.1);
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 6px 20px rgba(40, 30, 20, 0.04);
  }

  .testimonial-stars {
    color: #e0a64a;
    font-size: 15px;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }

  .testimonial-card p {
    color: #2a3140;
    font-size: 14.5px;
    line-height: 1.65;
    margin: 0 0 18px;
    flex: 1;
  }

  .testimonial-author {
    border-top: 1px solid rgba(40, 30, 20, 0.08);
    padding-top: 12px;
  }

  .testimonial-name {
    display: block;
    font-weight: 700;
    font-size: 14px;
    color: var(--navy-dark);
  }

  .testimonial-meta {
    display: block;
    font-size: 12px;
    color: var(--muted);
    margin-top: 2px;
  }

  @media (max-width: 820px) {
    .testimonials-section {
      padding: 56px 1.25rem;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
