---
// Client reviews — REAL reviews from the Imverica Google Business Profile
// (lightly trimmed to complete sentences; meaning unchanged). First names
// only, as requested. UPL-safe: feedback is about document-preparation
// service quality, never legal advice or guaranteed outcomes.
//
// The client-side script shuffles the pool and rotates batches of 6 every
// 60 seconds (adaptive: with 11 reviews it cycles a 6-card and a 5-card
// batch). The first batch is server-rendered so search engines see content.
//
// When the live Google reviews endpoint (/api/google-reviews) is configured,
// it overrides this pool automatically; until then these real reviews show.

interface Review {
  body: string;
  name: string;
  meta: string;
  stars: 4 | 5;
}

const ALL: Review[] = [
  { stars: 5, name: 'Elena',
    meta: 'Immigration documents',
    body: 'I’m very satisfied with the service. Always quick, clear, and worth it.' },
  { stars: 5, name: 'Pavlo',
    meta: 'USCIS · U4U re-parole',
    body: 'Huge thanks to Imverica Legal Solutions for their invaluable help with our U4U re-parole application! They are true professionals who genuinely care about their clients and were always in touch.' },
  { stars: 5, name: 'Mikhail',
    meta: 'USCIS · Immigration documents',
    body: 'I would like to thank the Imverica team for their professionalism and excellent service. Throughout the entire process, everything was handled clearly, efficiently, and in a timely manner.' },
  { stars: 5, name: 'Olga',
    meta: 'USCIS · Immigration documents',
    body: 'I’d like to express my gratitude to the Imverica team for their professional assistance and attentive attitude. All issues were resolved quickly, competently, and without unnecessary complications.' },
  { stars: 5, name: 'Aleks',
    meta: 'USCIS N-400 · Citizenship',
    body: 'I used Imverica to help with my citizenship application. Everything was prepared quickly, communication was easy, and the process went smoothly from start to finish. Very happy with the service.' },
  { stars: 5, name: 'Vladimir',
    meta: 'USCIS N-400 · Citizenship',
    body: 'Thank you for your help with completing my citizenship application. Everything was clear and professional.' },
  { stars: 5, name: 'Eva',
    meta: 'USCIS · Green card',
    body: 'Thank you for helping us prepare documents for our immigration case. Our green-card application had been pending with USCIS for over three years, and we didn’t know how to properly submit a status update.' },
  { stars: 5, name: 'Vitalii',
    meta: 'USCIS · Immigration documents',
    body: 'A really great company — they helped with so much! Highly recommended.' },
  { stars: 5, name: 'Aleksandr',
    meta: 'USCIS · Immigration forms',
    body: 'Thank you — the company helped me fill out the necessary immigration forms quickly and professionally! To anyone in need of this type of service, I recommend this company 10 out of 10.' },
  { stars: 5, name: 'Valentin',
    meta: 'USCIS · Immigration paperwork',
    body: 'Really happy I chose Imverica Legal Solutions for my immigration paperwork. They moved quickly, kept things on track, and delivered the results I was looking for — all at a price that felt reasonable for the quality of work.' },
  { stars: 5, name: 'Shroomly LLC',
    meta: 'Business · Employment green card',
    body: 'This company helped our employee prepare green-card application forms. The entire process was fast, affordable, and efficient. We highly recommend them.' }
];

// Server-render the first 6 so search engines see real content. The
// client script swaps them out for a random 6 on every visit.
const initial: Review[] = ALL.slice(0, 6);
---
<section class="testimonials-section" id="testimonials">
  <div class="testimonials-inner">
    <div class="testimonials-heading">
      <div class="testimonials-kicker">Client reviews</div>
      <h2>What clients say</h2>
      <p>Recent feedback from clients across immigration and California court document preparation — in the language they speak.</p>
    </div>
    <div class="testimonials-grid" id="testimonialsGrid">
      {initial.map((item) => (
        <article class="testimonial-card">
          <div class="testimonial-stars" aria-label={`${item.stars} out of 5`}>
            {'★'.repeat(item.stars)}<span class="testimonial-stars-dim">{'★'.repeat(5 - item.stars)}</span>
          </div>
          <p>{item.body}</p>
          <div class="testimonial-author">
            <span class="testimonial-name">{item.name}</span>
            <span class="testimonial-meta">{item.meta}</span>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- Full pool serialized so the client script can pick 3 random batches
       of 6 on every visit and rotate them every 60s without a server
       round-trip. Hidden from a11y so screen readers don't re-read the
       same content twice. -->
  <script id="testimonialsData" type="application/json">{JSON.stringify(ALL)}</script>
  <script>
    (function () {
      var grid = document.getElementById('testimonialsGrid');
      var data = document.getElementById('testimonialsData');
      if (!grid || !data) return;
      var gridEl = grid;
      var dataEl = data;
      type Review = { stars: number; body: string; name: string; meta: string };

      var embedded: Review[];
      try { embedded = JSON.parse(dataEl.textContent || '[]'); }
      catch (e) { embedded = []; }

      function esc(s: unknown): string {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
          return ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c] || '';
        });
      }

      function render(reviews: Review[]) {
        gridEl.innerHTML = reviews.map(function (r: Review) {
          var s = Math.max(0, Math.min(5, Math.round(r.stars || 0)));
          var filled = '★'.repeat(s);
          var empty = '★'.repeat(5 - s);
          return '<article class="testimonial-card">' +
            '<div class="testimonial-stars" aria-label="' + s + ' out of 5">' +
              esc(filled) + '<span class="testimonial-stars-dim">' + esc(empty) + '</span>' +
            '</div>' +
            '<p>' + esc(r.body) + '</p>' +
            '<div class="testimonial-author">' +
              '<span class="testimonial-name">' + esc(r.name) + '</span>' +
              '<span class="testimonial-meta">' + esc(r.meta) + '</span>' +
            '</div>' +
          '</article>';
        }).join('');
      }

      var reduced = false;
      try {
        var mq = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)');
        reduced = !!(mq && mq.matches);
      } catch (e) {}

      function start(pool: Review[]) {
        if (!Array.isArray(pool) || pool.length === 0) return; // keep SSR content
        // Fisher-Yates shuffle so two visitors rarely see the same order.
        for (var i = pool.length - 1; i > 0; i--) {
          var j = Math.floor(Math.random() * (i + 1));
          var t = pool[i]; pool[i] = pool[j]; pool[j] = t;
        }
        // Adaptive batches of 6 (Google may return fewer than the demo pool).
        var size = 6;
        var n = Math.min(3, Math.max(1, Math.ceil(pool.length / size)));
        var batches: Review[][] = [];
        for (var b = 0; b < n; b++) batches.push(pool.slice(b * size, b * size + size));
        render(batches[0]);
        if (batches.length < 2) return; // too few to rotate — just show them

        gridEl.style.transition = reduced ? 'none' : 'opacity 0.45s ease';
        var idx = 0;
        var ROTATE_MS = 60000; // rotate the visible 6 every minute
        function rotate() {
          var next = (idx + 1) % batches.length;
          if (reduced) { render(batches[next]); idx = next; return; }
          gridEl.style.opacity = '0';
          setTimeout(function () { render(batches[next]); idx = next; gridEl.style.opacity = '1'; }, 450);
        }
        setInterval(rotate, ROTATE_MS);
      }

      // Prefer LIVE Google reviews; fall back to the built-in pool if the
      // Google integration isn't configured yet (or returns nothing). The
      // server-rendered cards stay visible until one of these runs, so the
      // section is never empty and never breaks.
      var done = false;
      function fallback() { if (done) return; done = true; start(embedded); }
      try {
        fetch('/api/google-reviews', { headers: { Accept: 'application/json' } })
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (d) {
            if (done) return;
            if (d && d.ok && d.configured && Array.isArray(d.reviews) && d.reviews.length >= 1) {
              done = true; start(d.reviews); // real Google reviews win
            } else { fallback(); }
          })
          .catch(fallback);
        setTimeout(fallback, 4000); // a hung request must not block the section
      } catch (e) { fallback(); }
    })();
  </script>
</section>

<style>
  .testimonials-section {
    background: #fff;
    border-top: 1px solid rgba(40, 30, 20, 0.08);
    padding: var(--space-section) 1.5rem;
  }

  .testimonials-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .testimonials-heading {
    max-width: 760px;
    margin: 0 auto 30px;
    text-align: center;
  }

  .testimonials-kicker {
    color: var(--terracotta-deep);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .testimonials-heading h2 {
    font-size: var(--fs-h2);
    margin-bottom: 14px;
    font-weight: 700;
    text-wrap: balance;
  }

  /* Keep the testimonials lead on a single line on desktop so the
     "in the language they speak" tail doesn't orphan. The line is long
     enough to wrap on narrow viewports — that's intentional. */
  .testimonials-heading p {
    color: #3a4a5e;
    font-size: 15px;
    line-height: 1.7;
    margin: 0;
    max-width: 100%;
    white-space: normal;
  }
  @media (min-width: 980px) {
    .testimonials-heading p { white-space: nowrap; }
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    background: #fffaf2;
    border: 1px solid rgba(40, 30, 20, 0.1);
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 6px 20px rgba(40, 30, 20, 0.04);
  }

  .testimonial-stars {
    color: #e0a64a;
    font-size: 15px;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  /* Dim the trailing stars on 4-star reviews so the rating is visually
     readable without a numeric badge. Same letter, dimmer tone. */
  .testimonial-stars-dim {
    color: #e0a64a;
    opacity: 0.28;
  }

  .testimonial-card p {
    color: #2a3140;
    font-size: 14.5px;
    line-height: 1.65;
    margin: 0 0 18px;
    flex: 1;
  }

  .testimonial-author {
    border-top: 1px solid rgba(40, 30, 20, 0.08);
    padding-top: 12px;
  }

  .testimonial-name {
    display: block;
    font-weight: 700;
    font-size: 14px;
    color: var(--navy-dark);
  }

  .testimonial-meta {
    display: block;
    font-size: 12px;
    color: var(--muted);
    margin-top: 2px;
  }

  @media (max-width: 820px) {
    .testimonials-section {
      padding: var(--space-section) 1.25rem;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
