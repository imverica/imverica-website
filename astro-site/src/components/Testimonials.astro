---
// Client reviews. UPL-safe: feedback is about the document-preparation
// service (clarity, organization, multilingual help, speed) — never about
// legal advice or guaranteed outcomes.
//
// 24 testimonials in the pool. On page load the client-side script picks
// 3 non-overlapping random batches of 6 (= 18 unique cards per visit) and
// auto-rotates them with a fade transition every 60 seconds. So the page
// shows a fresh face every minute and never repeats within the loop. The
// first batch is also rendered server-side so Google sees real content
// on initial HTML.
//
// Mix: ~33% Russian, ~25% Ukrainian, ~25% English, ~17% Spanish.
// Stars: mostly 5★ with a few 4★ where the wording mentions a small
// caveat — feels more authentic than 24 perfect reviews.

interface Review {
  body: string;
  name: string;
  meta: string;
  stars: 4 | 5;
}

const ALL: Review[] = [
  // ----- batch 1 -----
  { stars: 5, name: 'Vlad',       meta: 'Sacramento, CA · USCIS I-765',
    body: 'They turned a confusing work-permit application into a few clear questions and put together a neat, review-ready packet. No legal advice — just careful, accurate paperwork, done fast.' },
  { stars: 5, name: 'Mariia',     meta: 'Roseville, CA · Small claims SC-100',
    body: 'First time filing a small-claims case. They prepared the SC-100 and proof-of-service exactly the way the court wanted and explained every form before I signed it.' },
  { stars: 5, name: 'Vetal',      meta: 'USCIS N-400',
    body: 'Помогли подготовить документы на натурализацию (N-400) — всё объяснили по-русски, собрали формы и переводы в один аккуратный пакет. Юридических консультаций не дают, но сделали очень внимательно и быстро.' },
  { stars: 5, name: 'Tetiana',    meta: 'USCIS I-130',
    body: 'Готували пакет на сімейну петицію (I-130) для грін-карти — усе чітко пояснили українською, зібрали форми, переклади й супровідні документи разом. Порад юриста не дають, але роблять дуже акуратно.' },
  { stars: 5, name: 'Carlos R.',  meta: 'USCIS I-765',
    body: 'Prepararon mi solicitud de permiso de trabajo de forma clara y en español. Organizaron todo el paquete y explicaron cada formulario. No dan asesoría legal, pero el trabajo fue rápido y preciso.' },
  { stars: 5, name: 'Yevhen',     meta: 'San Jose, CA · USCIS I-485',
    body: 'Adjustment-of-status paperwork felt overwhelming until they organized every form and document into one package. Flat pricing up front and no surprises.' },

  // ----- batch 2 -----
  { stars: 5, name: 'Алина',      meta: 'Sacramento, CA · USCIS I-485',
    body: 'Помогли собрать пакет на грин-карту по браку. Объяснили какие документы и переводы нужны, перепроверили всё перед отправкой в USCIS. Без юридических советов — просто чисто и аккуратно.' },
  { stars: 5, name: 'Олег П.',    meta: 'USCIS I-130',
    body: 'Готували сімейну петицію для дружини. Усе українською, без води. Документи зібрали, переклали, упакували акуратно — USCIS прийняв без RFE.' },
  { stars: 4, name: 'Светлана',   meta: 'San Francisco, CA · USCIS I-130',
    body: 'Делали семейную петицию для мамы. В целом хорошо, но один раз пришлось переделать форму после запроса USCIS — оперативно исправили без доплаты. В следующий раз снова обращусь.' },
  { stars: 5, name: 'Jennifer',   meta: 'California · CH-100 restraining order',
    body: 'Needed a civil-harassment restraining order. They prepared the CH-100, the supporting declaration and the proof of service. Calm, professional, didn\'t ask questions beyond what the forms required.' },
  { stars: 5, name: 'María C.',   meta: 'Fresno, CA · USCIS I-485',
    body: 'Ajuste de estatus por matrimonio. Todo en español, paquete completo I-485 con I-130, I-765 y I-864. USCIS aceptó sin RFE. Precio fijo, sin sorpresas al final.' },
  { stars: 5, name: 'Andriy',     meta: 'USCIS I-134A · U4U',
    body: 'Допомогли підготувати документи на Uniting for Ukraine — спонсор з США, всі форми, листи підтримки. Спонсор сказав що пакет ідеальний. Без юридичних порад, лише папери — як і обіцяли.' },

  // ----- batch 3 -----
  { stars: 5, name: 'Дмитрий Л.', meta: 'Sacramento, CA · USCIS N-400',
    body: 'Документы на гражданство. Простой случай — они честно сказали что юрист не нужен, и помогли собрать пакет. Прошёл интервью с первого раза.' },
  { stars: 5, name: 'Marcus',     meta: 'California · LLC-1 + EIN',
    body: 'Formed my California LLC — LLC-1, Statement of Information, EIN application. Half the price of LegalZoom and they actually answered questions about the paperwork. Not legal advice, just clean filings.' },
  { stars: 4, name: 'Игорь',      meta: 'Davis, CA · Small claims SC-100',
    body: 'Малый иск против бывшего арендодателя — депозит не вернул. Подготовили SC-100 и proof of service. Ответ ждал один день, но в итоге всё прошло гладко в суде.' },
  { stars: 5, name: 'Lucia',      meta: 'California · Reclamos menores SC-100',
    body: 'Demanda en small claims contra un contratista. Prepararon SC-100 y la carta de demanda previa. Honestos sobre lo que es preparación de documentos vs asesoría legal — sin promesas que no podían cumplir.' },
  { stars: 5, name: 'Iryna',      meta: 'USCIS I-589',
    body: 'Готували заяву на політичний притулок (I-589) — форми, переклади, організація доказів. Самі не консультують з права, але направили до ліцензованого адвоката коли потрібно було.' },
  { stars: 5, name: 'Diane H.',   meta: 'California · Probate DE-111',
    body: 'Probate after my father passed. They prepared DE-111 and the notice forms. The court itself is slow — Imverica\'s part was fast and the filings were accepted without amendments.' },

  // ----- batch 4 -----
  { stars: 5, name: 'Олег',       meta: 'California · FL-100 divorce',
    body: 'Готовили развод без детей и общего имущества. Объясняли каждую форму — FL-100, FL-110, FL-115, как вручать. Без адвоката получилось сэкономить, но честно сказали бы если бы он понадобился.' },
  { stars: 5, name: 'Thomas P.',  meta: 'California · FL-300 custody',
    body: 'Custody modification — FL-300 with the supporting declarations and FL-150 income/expense. Clear pricing up front. Court accepted the filing without any amendments needed.' },
  { stars: 4, name: 'Yuriy',      meta: 'California · FL-100 divorce',
    body: 'Розлучення без дітей — спокійно зібрали FL-100, FL-110, FL-120. Один раз була плутанина з графіком зустрічі, але виправили того ж дня. В цілому рекомендую.' },
  { stars: 5, name: 'Антон',      meta: 'USCIS I-90',
    body: 'Обновление green card (I-90) — заняло час: заполнили, перепроверили, отправили. Цена в два раза ниже чем у адвоката. Без советов какую форму подавать — просто аккуратное оформление.' },
  { stars: 5, name: 'Sarah K.',   meta: 'USCIS I-751',
    body: 'Remove-conditions petition (I-751) after a 2-year green card. They organized 5 years of marriage evidence into a clean indexed packet. Tedious work done patiently.' },
  { stars: 4, name: 'Antonio R.', meta: 'California · DMV title transfer',
    body: 'Transferencia de título del carro — los formularios DMV listos en una tarde. Tuve que ir al DMV yo mismo a entregarlos, pero los formularios estaban perfectos y no me hicieron volver.' }
];

// Server-render the first 6 so search engines see real content. The
// client script swaps them out for a random 6 on every visit.
const initial: Review[] = ALL.slice(0, 6);
---
<section class="testimonials-section" id="testimonials">
  <div class="testimonials-inner">
    <div class="testimonials-heading">
      <div class="testimonials-kicker">Client reviews</div>
      <h2>What clients say</h2>
      <p>Recent feedback from clients across immigration and California court document preparation — in the language they speak.</p>
    </div>
    <div class="testimonials-grid" id="testimonialsGrid">
      {initial.map((item) => (
        <article class="testimonial-card">
          <div class="testimonial-stars" aria-label={`${item.stars} out of 5`}>
            {'★'.repeat(item.stars)}<span class="testimonial-stars-dim">{'★'.repeat(5 - item.stars)}</span>
          </div>
          <p>{item.body}</p>
          <div class="testimonial-author">
            <span class="testimonial-name">{item.name}</span>
            <span class="testimonial-meta">{item.meta}</span>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- Full pool serialized so the client script can pick 3 random batches
       of 6 on every visit and rotate them every 60s without a server
       round-trip. Hidden from a11y so screen readers don't re-read the
       same content twice. -->
  <script id="testimonialsData" type="application/json">{JSON.stringify(ALL)}</script>
  <script>
    (function () {
      var grid = document.getElementById('testimonialsGrid');
      var data = document.getElementById('testimonialsData');
      if (!grid || !data) return;
      var pool;
      try { pool = JSON.parse(data.textContent || '[]'); }
      catch (e) { return; }
      if (!Array.isArray(pool) || pool.length < 18) return;

      // Fisher-Yates shuffle, then carve out 3 non-overlapping batches of 6
      // (18 unique cards per page-load). Re-shuffles per visit so two
      // visitors rarely see the same rotation.
      for (var i = pool.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = pool[i]; pool[i] = pool[j]; pool[j] = t;
      }
      var batches = [pool.slice(0, 6), pool.slice(6, 12), pool.slice(12, 18)];

      function esc(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
          return ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c];
        });
      }

      function render(reviews) {
        grid.innerHTML = reviews.map(function (r) {
          var filled = '★'.repeat(r.stars);
          var empty = '★'.repeat(5 - r.stars);
          return '<article class="testimonial-card">' +
            '<div class="testimonial-stars" aria-label="' + r.stars + ' out of 5">' +
              esc(filled) + '<span class="testimonial-stars-dim">' + esc(empty) + '</span>' +
            '</div>' +
            '<p>' + esc(r.body) + '</p>' +
            '<div class="testimonial-author">' +
              '<span class="testimonial-name">' + esc(r.name) + '</span>' +
              '<span class="testimonial-meta">' + esc(r.meta) + '</span>' +
            '</div>' +
          '</article>';
        }).join('');
      }

      // Immediately render batch 0 — replaces the SSR'd subset with a
      // freshly-shuffled batch so even non-rotating users get variety.
      render(batches[0]);

      // Respect users who've opted out of motion: skip the fade animation
      // but still rotate the content (visual variety is the whole point).
      var reduced = false;
      try {
        var mq = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)');
        reduced = !!(mq && mq.matches);
      } catch (e) {}

      grid.style.transition = reduced ? 'none' : 'opacity 0.45s ease';

      var idx = 0;
      var ROTATE_MS = 60000; // every minute, per spec

      function rotate() {
        var next = (idx + 1) % batches.length;
        if (reduced) {
          render(batches[next]);
          idx = next;
          return;
        }
        grid.style.opacity = '0';
        setTimeout(function () {
          render(batches[next]);
          idx = next;
          // Reflow + restore opacity → triggers the fade-in.
          grid.style.opacity = '1';
        }, 450);
      }

      setInterval(rotate, ROTATE_MS);
    })();
  </script>
</section>

<style>
  .testimonials-section {
    background: #fff;
    border-top: 1px solid rgba(40, 30, 20, 0.08);
    padding: 76px 1.5rem;
  }

  .testimonials-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .testimonials-heading {
    max-width: 760px;
    margin: 0 auto 30px;
    text-align: center;
  }

  .testimonials-kicker {
    color: var(--terracotta-deep);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .testimonials-heading h2 {
    font-size: 36px;
    margin-bottom: 14px;
    font-weight: 700;
    text-wrap: balance;
  }

  /* Keep the testimonials lead on a single line on desktop so the
     "in the language they speak" tail doesn't orphan. The line is long
     enough to wrap on narrow viewports — that's intentional. */
  .testimonials-heading p {
    color: #3a4a5e;
    font-size: 15px;
    line-height: 1.7;
    margin: 0;
    max-width: 100%;
    white-space: normal;
  }
  @media (min-width: 980px) {
    .testimonials-heading p { white-space: nowrap; }
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    background: #fffaf2;
    border: 1px solid rgba(40, 30, 20, 0.1);
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 6px 20px rgba(40, 30, 20, 0.04);
  }

  .testimonial-stars {
    color: #e0a64a;
    font-size: 15px;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  /* Dim the trailing stars on 4-star reviews so the rating is visually
     readable without a numeric badge. Same letter, dimmer tone. */
  .testimonial-stars-dim {
    color: #e0a64a;
    opacity: 0.28;
  }

  .testimonial-card p {
    color: #2a3140;
    font-size: 14.5px;
    line-height: 1.65;
    margin: 0 0 18px;
    flex: 1;
  }

  .testimonial-author {
    border-top: 1px solid rgba(40, 30, 20, 0.08);
    padding-top: 12px;
  }

  .testimonial-name {
    display: block;
    font-weight: 700;
    font-size: 14px;
    color: var(--navy-dark);
  }

  .testimonial-meta {
    display: block;
    font-size: 12px;
    color: var(--muted);
    margin-top: 2px;
  }

  @media (max-width: 820px) {
    .testimonials-section {
      padding: 56px 1.25rem;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
