---
// Homepage reviews — shows the freshest 6 (3×2) and rotates them; the full
// pool (including older reviews) lives on the /testimonials page behind the
// "Read more reviews" button. Data is shared from ~/data/reviews.ts so the
// homepage and the full page never drift apart.
//
// The client-side script shuffles the pool and rotates batches of 6 every
// 60 seconds. The first batch is server-rendered so search engines see content.
// When /api/google-reviews is configured it overrides this pool automatically.

import { REVIEWS, GOOGLE_REVIEWS_URL, type Review } from '~/data/reviews';

const ALL: Review[] = REVIEWS;
// Server-render the first 6 so search engines (and no-JS visitors) see content.
const initial: Review[] = ALL.slice(0, 6);
---
<section class="testimonials-section" id="testimonials">
  <div class="testimonials-inner">
    <div class="testimonials-heading">
      <div class="testimonials-kicker">Client reviews</div>
      <h2>What clients say</h2>
      <p>Recent feedback from clients across immigration and California court document preparation — in the language they speak.</p>
    </div>
    <div class="testimonials-grid" id="testimonialsGrid">
      {initial.map((item) => (
        <article class="testimonial-card">
          <div class="testimonial-stars" aria-label={`${item.stars} out of 5`}>
            {'★'.repeat(item.stars)}<span class="testimonial-stars-dim">{'★'.repeat(5 - item.stars)}</span>
          </div>
          <p>{item.body}</p>
          <div class="testimonial-author">
            <span class="testimonial-name">{item.name}</span>
            <span class="testimonial-meta">{item.meta}</span>
          </div>
        </article>
      ))}
    </div>

    <div class="testimonials-actions">
      <a class="testimonials-more" href="/testimonials">Read more reviews <span aria-hidden="true">→</span></a>
      <a class="testimonials-google" href={GOOGLE_REVIEWS_URL} target="_blank" rel="noopener noreferrer">
        <span class="testimonials-google-stars" aria-hidden="true">★★★★★</span> See all reviews on Google
      </a>
    </div>
  </div>

  <!-- Full pool serialized so the client script can rotate the visible 6 every
       60s without a server round-trip. Hidden from a11y so screen readers don't
       re-read the same content twice. -->
  <script id="testimonialsData" type="application/json">{JSON.stringify(ALL)}</script>
  <script>
    (function () {
      var grid = document.getElementById('testimonialsGrid');
      var data = document.getElementById('testimonialsData');
      if (!grid || !data) return;
      var gridEl = grid;
      var dataEl = data;
      type Review = { stars: number; body: string; name: string; meta: string };

      var embedded: Review[];
      try { embedded = JSON.parse(dataEl.textContent || '[]'); }
      catch (e) { embedded = []; }

      function esc(s: unknown): string {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
          return ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c] || '';
        });
      }

      function render(reviews: Review[]) {
        gridEl.innerHTML = reviews.map(function (r: Review) {
          var s = Math.max(0, Math.min(5, Math.round(r.stars || 0)));
          var filled = '★'.repeat(s);
          var empty = '★'.repeat(5 - s);
          return '<article class="testimonial-card">' +
            '<div class="testimonial-stars" aria-label="' + s + ' out of 5">' +
              esc(filled) + '<span class="testimonial-stars-dim">' + esc(empty) + '</span>' +
            '</div>' +
            '<p>' + esc(r.body) + '</p>' +
            '<div class="testimonial-author">' +
              '<span class="testimonial-name">' + esc(r.name) + '</span>' +
              '<span class="testimonial-meta">' + esc(r.meta) + '</span>' +
            '</div>' +
          '</article>';
        }).join('');
      }

      var reduced = false;
      try {
        var mq = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)');
        reduced = !!(mq && mq.matches);
      } catch (e) {}

      function start(pool: Review[]) {
        if (!Array.isArray(pool) || pool.length === 0) return; // keep SSR content
        // Homepage stays fresh: only rotate the newest dozen; the rest live on
        // the /testimonials page.
        pool = pool.slice(0, 12);
        // Fisher-Yates shuffle so two visitors rarely see the same order.
        for (var i = pool.length - 1; i > 0; i--) {
          var j = Math.floor(Math.random() * (i + 1));
          var t = pool[i]; pool[i] = pool[j]; pool[j] = t;
        }
        var size = 6;
        var n = Math.min(3, Math.max(1, Math.ceil(pool.length / size)));
        var batches: Review[][] = [];
        for (var b = 0; b < n; b++) batches.push(pool.slice(b * size, b * size + size));
        render(batches[0]);
        if (batches.length < 2) return; // too few to rotate — just show them

        gridEl.style.transition = reduced ? 'none' : 'opacity 0.45s ease';
        var idx = 0;
        var ROTATE_MS = 60000; // rotate the visible 6 every minute
        function rotate() {
          var next = (idx + 1) % batches.length;
          if (reduced) { render(batches[next]); idx = next; return; }
          gridEl.style.opacity = '0';
          setTimeout(function () { render(batches[next]); idx = next; gridEl.style.opacity = '1'; }, 450);
        }
        setInterval(rotate, ROTATE_MS);
      }

      // Prefer LIVE Google reviews; fall back to the built-in pool if the
      // Google integration isn't configured yet (or returns nothing).
      var done = false;
      function fallback() { if (done) return; done = true; start(embedded); }
      try {
        fetch('/api/google-reviews', { headers: { Accept: 'application/json' } })
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (d) {
            if (done) return;
            if (d && d.ok && d.configured && Array.isArray(d.reviews) && d.reviews.length >= 1) {
              done = true; start(d.reviews); // real Google reviews win
            } else { fallback(); }
          })
          .catch(fallback);
        setTimeout(fallback, 4000); // a hung request must not block the section
      } catch (e) { fallback(); }
    })();
  </script>
</section>

<style>
  .testimonials-section {
    background: #fff;
    border-top: 1px solid rgba(40, 30, 20, 0.08);
    padding: var(--space-section) 1.5rem;
  }

  .testimonials-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .testimonials-heading {
    max-width: 760px;
    margin: 0 auto 30px;
    text-align: center;
  }

  .testimonials-kicker {
    color: var(--terracotta-deep);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .testimonials-heading h2 {
    font-size: var(--fs-h2);
    margin-bottom: 14px;
    font-weight: 700;
    text-wrap: balance;
  }

  .testimonials-heading p {
    color: #3a4a5e;
    font-size: 15px;
    line-height: 1.7;
    margin: 0;
    max-width: 100%;
    white-space: normal;
  }
  @media (min-width: 980px) {
    .testimonials-heading p { white-space: nowrap; }
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    background: #fffaf2;
    border: 1px solid rgba(40, 30, 20, 0.1);
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 6px 20px rgba(40, 30, 20, 0.04);
  }

  .testimonial-stars {
    color: #e0a64a;
    font-size: 15px;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  .testimonial-stars-dim {
    color: #e0a64a;
    opacity: 0.28;
  }

  .testimonial-card p {
    color: #2a3140;
    font-size: 14.5px;
    line-height: 1.65;
    margin: 0 0 18px;
    flex: 1;
  }

  .testimonial-author {
    border-top: 1px solid rgba(40, 30, 20, 0.08);
    padding-top: 12px;
  }

  .testimonial-name {
    display: block;
    font-weight: 700;
    font-size: 14px;
    color: var(--navy-dark);
  }

  .testimonial-meta {
    display: block;
    font-size: 12px;
    color: var(--muted);
    margin-top: 2px;
  }

  .testimonials-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 14px 22px;
    margin-top: 30px;
  }

  .testimonials-more {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--navy);
    color: #fff;
    font-weight: 700;
    font-size: 14.5px;
    text-decoration: none;
    padding: 12px 24px;
    border-radius: 10px;
    border: 1px solid var(--navy);
    transition: background 0.18s ease, transform 0.18s ease;
  }
  .testimonials-more:hover { background: var(--navy-dark); transform: translateY(-1px); }
  .testimonials-more span { color: var(--gold); }

  .testimonials-google {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: #3a4a5e;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .testimonials-google:hover { color: var(--navy-dark); border-bottom-color: var(--gold); }
  .testimonials-google-stars { color: #e0a64a; letter-spacing: 1px; }

  @media (max-width: 820px) {
    .testimonials-section { padding: var(--space-section) 1.25rem; }
    .testimonials-grid { grid-template-columns: 1fr; }
  }
</style>
