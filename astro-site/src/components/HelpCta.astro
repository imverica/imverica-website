---
import { LOCALES, type Locale } from '~/data/i18n';

interface Props {
  lang?: Locale;
  heading?: string;
  text?: string;
}
const { lang = 'en', heading, text } = Astro.props;

const STR: Record<Locale, { h: string; p: string; start: string; call: string }> = {
  en: {
    h: 'Not sure which form you need?',
    p: "Tell us your situation and any deadline or USCIS / court notice — we'll point you to the matching forms. General information, not legal advice.",
    start: 'Start your case →',
    call: 'Call +1 (916) 399-3992'
  },
  ru: {
    h: 'Не уверены, какая форма вам нужна?',
    p: 'Опишите ситуацию и любые сроки или уведомление USCIS / суда — мы подскажем подходящие формы. Общая информация, не юридическая консультация.',
    start: 'Начать кейс →',
    call: 'Звонок +1 (916) 399-3992'
  },
  uk: {
    h: 'Не впевнені, яка форма вам потрібна?',
    p: 'Опишіть ситуацію та будь-які терміни чи повідомлення USCIS / суду — ми підкажемо відповідні форми. Загальна інформація, не юридична консультація.',
    start: 'Почати кейс →',
    call: 'Дзвінок +1 (916) 399-3992'
  },
  es: {
    h: '¿No está seguro de qué formulario necesita?',
    p: 'Cuéntenos su situación y cualquier fecha límite o aviso de USCIS / corte — le indicaremos los formularios correspondientes. Información general, no asesoría legal.',
    start: 'Iniciar su caso →',
    call: 'Llamar +1 (916) 399-3992'
  }
};
const t = STR[lang] || STR.en;
const startHref = LOCALES[lang].prefix + '/#get-started';
---
<section class="help-cta">
  <div class="help-cta-inner">
    <div class="help-cta-copy">
      <h2>{heading || t.h}</h2>
      <p>{text || t.p}</p>
    </div>
    <div class="help-cta-actions">
      <a class="btn btn-accent" href={startHref}>{t.start}</a>
      <a class="btn btn-ghost" href="tel:+19163993992">{t.call}</a>
    </div>
  </div>
</section>

<style>
  .help-cta {
    background: var(--paper-alt);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 54px 2rem;
  }
  .help-cta-inner {
    max-width: 1220px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 32px;
    align-items: center;
  }
  .help-cta-copy h2 {
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--navy-dark);
    margin: 0 0 10px;
  }
  .help-cta-copy p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-2);
    margin: 0;
    max-width: 560px;
    text-wrap: pretty;
  }
  .help-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: flex-end;
  }
  .help-cta-actions .btn { font-size: 14.5px; padding: 13px 22px; }
  @media (max-width: 820px) {
    .help-cta { padding: 40px 1.25rem; }
    .help-cta-inner { grid-template-columns: 1fr; gap: 20px; }
    .help-cta-actions { justify-content: flex-start; }
  }
</style>
