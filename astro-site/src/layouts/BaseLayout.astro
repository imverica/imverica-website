---
import '~/styles/site.css';
import SiteHeader from '~/components/SiteHeader.astro';
import SiteFooter from '~/components/SiteFooter.astro';
import IntakeWizard from '~/components/IntakeWizard.astro';
import QuickIntakeModal from '~/components/QuickIntakeModal.astro';
import ChatWidget from '~/components/ChatWidget.astro';
import { LOCALES, localizedPath, type Locale } from '~/data/i18n';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: object[];
  lang?: Locale;
  /** Slug shared across all language variants — used for hreflang alternates. */
  slug?: string;
  /** Locales that actually have a translated page for this slug. Defaults to ['en'] — English-only pages skip hreflang entirely. */
  availableLocales?: Locale[];
}

const {
  title,
  description,
  canonical = Astro.url.toString(),
  ogImage = '/logo-nav.png',
  noindex = false,
  jsonLd = [],
  lang = 'en',
  slug,
  availableLocales = ['en']
} = Astro.props;

const fullTitle = title.includes('Imverica') ? title : `${title} | Imverica Legal Solutions`;
const localeMeta = LOCALES[lang];
const alternates = slug && availableLocales.length > 1
  ? availableLocales.map((alt) => ({
      locale: alt,
      htmlLang: LOCALES[alt].htmlLang,
      href: 'https://imverica.com' + localizedPath(alt, slug)
    }))
  : [];
---
<!doctype html>
<html lang={localeMeta.htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}

  <!-- Brand mark (scales from the site logo) for tabs and iOS home screen. -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="Imverica" />
  <meta name="theme-color" content="#143254" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content={localeMeta.ogLocale} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />

  {alternates.map((alt) => (
    <link rel="alternate" hreflang={alt.htmlLang} href={alt.href} />
  ))}
  {alternates.length > 0 && (
    <link rel="alternate" hreflang="x-default" href={alternates[0].href} />
  )}

  <!-- Typography: editorial brand system — Newsreader (serif) for display
       headings, Archivo (sans) for body/UI, IBM Plex Mono for kickers and
       labels. display=swap keeps text visible while the webfonts load. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Archivo:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" />

  {jsonLd.map((schema) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body>
  <SiteHeader lang={lang} currentSlug={slug} availableLocales={availableLocales} />
  <main>
    <slot />
  </main>
  <SiteFooter lang={lang} />
  <!-- IntakeWizard runs first and registers window.openIntakeModal for
       the long Q&A. QuickIntakeModal loads AFTER it and re-assigns the
       same global to the new one-screen form — this wins for every
       homepage / landing-page CTA. The long wizard is still reachable
       from the cabinet via window.openIntakeWizard (or a direct call to
       the legacy modal when the user is mid-flow on an existing order). -->
  <IntakeWizard />
  <QuickIntakeModal />
  <ChatWidget />

  <style is:global>
    /* Reveal-on-scroll. The hidden state is only applied once JS confirms
       IntersectionObserver + no reduce-motion (html.reveal-init), so content
       is always visible if JS is disabled or motion is reduced. */
    html.reveal-init .reveal {
      opacity: 0;
      transform: translateY(26px);
      transition: opacity 0.55s ease, transform 0.55s ease;
      will-change: opacity, transform;
    }
    html.reveal-init .reveal.in {
      opacity: 1;
      transform: none;
    }
  </style>
  <script>
    (function () {
      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) return;

      /* .stat-item intentionally excluded — stats sit just under the hero
         and must be visible immediately, without a scroll-reveal flash. */
      var SELECTORS = '.ourserv-card, .svc-card, .faq-item, .why-list li, .news-card, .vt, .testi-card, .form-list, .lb-related, .lb-cta-card, .about-card, .imm-cat, .cat-tile';

      function setupReveal() {
        var els = Array.prototype.slice.call(document.querySelectorAll(SELECTORS));
        if (!els.length) return;
        document.documentElement.classList.add('reveal-init');

        // Stagger each element by its index within its own parent container.
        var counts = new Map();
        els.forEach(function (el) {
          if (el.classList.contains('reveal')) return;
          el.classList.add('reveal');
          var parent = el.parentElement;
          var i = counts.get(parent) || 0;
          counts.set(parent, i + 1);
          el.style.transitionDelay = Math.min(i, 8) * 60 + 'ms';
        });

        var obs = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('in');
              obs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });

        els.forEach(function (el) { obs.observe(el); });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupReveal);
      } else {
        setupReveal();
      }
      document.addEventListener('astro:after-swap', setupReveal);
    })();
  </script>
</body>
</html>
