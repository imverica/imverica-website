{
  "form": "i-485",
  "defaultStrategy": "safe_blank_unless_answered",
  "flags": {
    "hasAttorney": false,
    "hasInterpreter": false,
    "hasPreparer": false,
    "receivedPublicBenefits": false,
    "institutionalizedAtGovernmentExpense": false,
    "hasCriminalOrInadmissibilityYes": false,
    "eligibilityCategorySelected": false
  },
  "conditionalSections": {
    "attorney": {
      "enabledBy": "hasAttorney",
      "controls": [
        "g28",
        "g_28",
        "g-28",
        "selectthisbox",
        "volag",
        "attorney",
        "representative",
        "statebar",
        "barnumber",
        "uscisonlineacctnumber"
      ]
    },
    "interpreter": {
      "enabledBy": "hasInterpreter",
      "controls": [
        "pt11",
        "part11",
        "interpreter"
      ]
    },
    "preparer": {
      "enabledBy": "hasPreparer",
      "controls": [
        "pt12",
        "part12",
        "preparer"
      ]
    },
    "signatureAtInterview": {
      "enabledBy": "never",
      "controls": [
        "pt13",
        "part13",
        "uscisofficer",
        "uscissignature",
        "applicantsignature",
        "corrections",
        "pages"
      ]
    },
    "publicChargeTables": {
      "enabledByAny": [
        "receivedPublicBenefits",
        "institutionalizedAtGovernmentExpense"
      ],
      "controls": [
        "pt8line68c",
        "pt8line68d",
        "pt9line65",
        "pt9line66",
        "line65",
        "line66"
      ]
    },
    "eligibilityCategories": {
      "enabledBy": "eligibilityCategorySelected",
      "pages": [5, 6, 7, 8, 18],
      "choiceOnly": true
    }
  },
  "defaultNoPages": [14, 15, 16, 17, 18, 19, 20, 21],
  "notes": [
    "Attorney fields stay available but must remain blank unless hasAttorney is true.",
    "G-28 checkbox may be used only when attorney representation exists.",
    "Attorney State Bar Number may be used only when hasAttorney is true.",
    "Interpreter fields must remain blank unless hasInterpreter is true.",
    "Preparer fields must remain blank unless hasPreparer is true.",
    "Part 13 Signature at Interview must never be filled before the interview.",
    "Public benefit and institutionalization tables must remain blank unless the triggering answer is Yes.",
    "Eligibility category must be selected intentionally and must not be mass-selected.",
    "Criminal and inadmissibility questions default to No unless the applicant answers Yes."
  ]
}
